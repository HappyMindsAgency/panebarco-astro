---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import commercialsPageScriptUrl from "../../scripts/pages/commercials.js?url";

const lang = "it" as const;

const communicationModes = [
  "Sviluppare",
  "Produrre",
  "Coordinare",
  "Accompagnare",
] as const;

const modeDescriptions = {
  Sviluppare:
    "Entriamo nel progetto quando serve una base solida: concept, organizzazione e impostazione del lavoro per far partire bene ogni fase.",
  Produrre:
    "Affianchiamo produzioni e partner nella realizzazione di contenuti 2D e 3D, con un supporto operativo che tiene insieme tempi, qualita e continuita.",
  Coordinare:
    "Gestiamo il lavoro condiviso tra team interni, collaboratori e partner esterni, mantenendo il flusso leggibile e sostenibile per tutti.",
  Accompagnare:
    "Restiamo dentro il processo anche quando cambia forma, con un supporto pratico che segue il progetto fino alla consegna.",
} as const;

const modeImageSets = {
  Sviluppare: [
    "/images/spiegare-01.png",
    "/images/raccontare-02.jpg",
    "/images/promuovere-03.png",
    "/images/coinvolgere-03.jpg",
  ],
  Produrre: [
    "/images/promuovere-03.png",
    "/images/spiegare-02.png",
    "/images/raccontare-03.jpg",
    "/images/coinvolgere-02.jpg",
  ],
  Coordinare: [
    "/images/coinvolgere-03.jpg",
    "/images/raccontare-04.jpg",
    "/images/spiegare-03.png",
    "/images/promuovere-02.png",
  ],
  Accompagnare: [
    "/images/raccontare-02.jpg",
    "/images/coinvolgere-01.jpg",
    "/images/spiegare-04.png",
    "/images/promuovere-01.png",
  ],
} as const;

const modeBubbleSets = {
  Sviluppare: "/images/raccontare.png",
  Produrre: "/images/spiegare.png",
  Coordinare: "/images/promuovere.png",
  Accompagnare: "/images/coinvolgere.png",
} as const;
---

<Layout
  title="Service - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="commercials-page studio-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/panebarco-studio-video.mp4"
      bgWord="SERVICE"
      title="SERVICE"
      subtitle="Supporto creativo, produttivo e operativo lungo tutto il processo"
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
      showSideImage={false}
    />

    <section class="page-main page-main--studio">
      <div class="w-100">
        <div class="container">
          <div class="row">
            <div class="col-12 text-lg-center text-start">
              <h2 class="page-title-uniform mb-4 text-body">Service che entra nel flusso e lo tiene insieme</h2>
              <p class="mb-4">
                Affianchiamo produzioni, agenzie e partner creativi quando serve una squadra capace di entrare nel processo
                con metodo, flessibilita e continuita, senza appesantire il lavoro.
              </p>
              <p class="mb-0">
                Possiamo intervenire nello sviluppo, nella produzione di contenuti, nel coordinamento operativo e nella
                gestione del lavoro condiviso, adattandoci al contesto e ai bisogni reali del progetto.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--tight pt-0">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <h2 class="page-title-uniform text-primary mb-5 text-lg-center">QUATTRO MODI DI AFFIANCARE.</h2>
            {communicationModes.map((mode, index) => {
              const scenes = modeImageSets[mode];
              const bubble = modeBubbleSets[mode];

              return (
                <article class:list={[index > 0 && "mt-5 mt-lg-6 pt-3 pt-lg-4", index === communicationModes.length - 1 && "mb-4 pb-4 mb-md-5 pb-md-4"]}>
                  <div class="commercial-mode-heading" data-commercial-mode-heading>
                    <h3 class="fw-bold text-body display-5 display-lg-4">{mode}</h3>
                    {bubble && (
                      <img
                        class="commercial-mode-bubble"
                        src={bubble}
                        alt=""
                        aria-hidden="true"
                        loading="lazy"
                        decoding="async"
                      />
                    )}
                  </div>
                  <p>{modeDescriptions[mode]}</p>

                  <div class="row g-3">
                    <div class="col-12 col-lg-8">
                      <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 1`}>
                        <img
                          class="img-fluid w-100"
                          src={scenes[0]}
                          alt={`${mode} scena 1`}
                          style="height: clamp(220px, 28vw, 300px); object-fit: cover;"
                        />
                        <div class="commercials-media-tags" aria-hidden="true">
                          <span class="commercials-media-tag">{mode}</span>
                          <span class="commercials-media-tag">Service</span>
                        </div>
                        <div class="commercials-media-overlay" aria-hidden="true">
                          <h4>{mode} 01</h4>
                          <p>Frame dal progetto {mode.toLowerCase()}.</p>
                        </div>
                      </article>
                    </div>
                    <div class="col-12 col-lg-4">
                      <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 2`}>
                        <img
                          class="img-fluid w-100"
                          src={scenes[1]}
                          alt={`${mode} scena 2`}
                          style="height: clamp(220px, 28vw, 300px); object-fit: cover;"
                        />
                        <div class="commercials-media-tags" aria-hidden="true">
                          <span class="commercials-media-tag">{mode}</span>
                          <span class="commercials-media-tag">Service</span>
                        </div>
                        <div class="commercials-media-overlay" aria-hidden="true">
                          <h4>{mode} 02</h4>
                          <p>Frame dal progetto {mode.toLowerCase()}.</p>
                        </div>
                      </article>
                    </div>
                    <div class="col-12 col-lg-4">
                      <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 3`}>
                        <img
                          class="img-fluid w-100"
                          src={scenes[2]}
                          alt={`${mode} scena 3`}
                          style="height: clamp(220px, 28vw, 300px); object-fit: cover;"
                        />
                        <div class="commercials-media-tags" aria-hidden="true">
                          <span class="commercials-media-tag">{mode}</span>
                          <span class="commercials-media-tag">Service</span>
                        </div>
                        <div class="commercials-media-overlay" aria-hidden="true">
                          <h4>{mode} 03</h4>
                          <p>Frame dal progetto {mode.toLowerCase()}.</p>
                        </div>
                      </article>
                    </div>
                    <div class="col-12 col-lg-8">
                      <article class="commercials-media-card" tabindex="0" aria-label={`${mode} scena 4`}>
                        <img
                          class="img-fluid w-100"
                          src={scenes[3]}
                          alt={`${mode} scena 4`}
                          style="height: clamp(220px, 28vw, 300px); object-fit: cover;"
                        />
                        <div class="commercials-media-tags" aria-hidden="true">
                          <span class="commercials-media-tag">{mode}</span>
                          <span class="commercials-media-tag">Service</span>
                        </div>
                        <div class="commercials-media-overlay" aria-hidden="true">
                          <h4>{mode} 04</h4>
                          <p>Frame dal progetto {mode.toLowerCase()}.</p>
                        </div>
                      </article>
                    </div>
                  </div>

                </article>
              );
            })}

            <section class="mt-5 mt-lg-6 pt-4 pt-lg-5">
              <ContactCtaBanner
                kicker="Hai bisogno di una squadra che entri nel flusso?"
                title="TI AFFIANCHIAMO NOI."
              />
            </section>
          </div>
        </div>
      </div>
    </section>
  </main>
  <script type="module" src={commercialsPageScriptUrl}></script>
</Layout>
