---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import { buildPath } from "../../i18n/routing";

const lang = "it" as const;

const specialProjects = [
  {
    title: "Curiosità e formati laterali",
    href: buildPath("paneblog", lang),
    image: "/images/curiosita-01.jpg",
    summary: "Contenuti nati per sperimentare linguaggi, toni e usi fuori dal perimetro più istituzionale.",
    tags: ["Special projects", "Format"],
  },
  {
    title: "Progetti editoriali e di racconto",
    href: buildPath("paneblogTravelDiary", lang),
    image: "/images/curiosita-02.jpg",
    summary: "Appunti visivi, materiali narrativi e piccoli mondi che tengono insieme processo, tono e identità.",
    tags: ["Editoriale", "Storytelling"],
  },
  {
    title: "Contenuti per librerie e archivi",
    href: buildPath("portfolio", lang),
    image: "/images/curiosita-03.jpg",
    summary: "Materiali modulari pensati per vivere su più canali, nel tempo, con una logica di collezione e riuso.",
    tags: ["Library", "Content"],
  },
] as const;

const specialProjectsGrid = [...specialProjects.slice(0, 2), ...specialProjects.slice(0, 2)];

const mindItems = [
  {
    eyebrow: "Paneblog",
    headline: "Articoli, backstage e note editoriali",
    href: buildPath("paneblog", lang),
    summary:
      "Il lato più ragionato del nostro flusso: riflessioni, riferimenti, piccoli processi e contenuti da tenere vicini.",
    cta: "Vai al Paneblog",
  },
  {
    eyebrow: "Diario di viaggio",
    headline: "Appunti rapidi da lavorazioni, eventi e studio",
    href: buildPath("paneblogTravelDiary", lang),
    summary:
      "Flash, annotazioni e materiali raccolti lungo il percorso, per fermare cose piccole ma spesso decisive.",
    cta: "Apri il diario",
  },
  {
    eyebrow: "Newsletter",
    headline: "Aggiornamenti essenziali, senza rumore",
    href: buildPath("contacts", lang),
    summary:
      "Un formato leggero per restare in contatto con nuovi progetti, contenuti utili e uscite che vale la pena seguire.",
    cta: "Iscriviti",
  },
] as const;
---

<Layout
  title="...E tanto altro - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="studio-page extras-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/1021768637.mp4"
      bgWord="ALTRE STORIE"
      title="...E TANTO ALTRO"
      showSideImage={false}
      subtitle="Progetti speciali, contenuti laterali e idee che tengono vivo il laboratorio"
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
    />

    <section class="page-main page-main--studio extras-intro">
      <div class="container">
        <div class="row g-4 g-xl-5 align-items-center">
          <div class="col-12 col-xl-7">
            <div class="extras-intro-copy">
              <h2 class="page-title-uniform">Qui finiscono le etichette e iniziano le deviazioni interessanti.</h2>
              <p>
                Oltre ai servizi più riconoscibili ci sono territori che usiamo per allargare il linguaggio, testare idee,
                costruire contenuti editoriali e mettere in circolo materiali che non stanno in una sola categoria.
              </p>
              <p>
                È uno spazio più aperto, ma non meno progettato: raccoglie progetti speciali, contenuti laterali, strumenti
                per raccontarci meglio e una libreria viva di cose che possono tornare utili anche ad altri.
              </p>
            </div>
          </div>

          <div class="col-12 col-xl-5">
            <div class="extras-intro-art">
              <img class="img-fluid d-block mx-auto" src="/images/paneblog-pensieri.png" alt="Pensieri che ci frullano in testa">
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft extras-special-projects" aria-labelledby="specialProjectsTitle">
      <div class="container">
        <div class="row justify-content-center text-center mb-2 mb-lg-3">
          <div class="col-12 col-xl-8">
            <h2 id="specialProjectsTitle" class="page-title-uniform">Progetti speciali</h2>
            <p class="extras-section-intro mb-0">
              Formati ibridi, iniziative editoriali, contenuti nati per testare nuove direzioni o tenere insieme materiali che
              meritano una vita più lunga e meno prevedibile.
            </p>
            <div class="mt-3 mt-lg-4 mb-4 mb-lg-5">
              <a class="btn btn-cta btn-cta--blue btn-pill" href={buildPath("contacts", lang)}>Parliamone</a>
            </div>
          </div>
        </div>

        <div class="row g-4 g-xl-5 extras-special-projects__grid">
          {specialProjectsGrid.map((item) => (
            <div class="col-12 col-lg-6">
              <a class="extras-case-card d-block h-100 text-decoration-none" href={item.href}>
                <div class="extras-case-card__media">
                  <img src={item.image} alt={item.title} loading="lazy" decoding="async" />
                </div>
                <div class="extras-case-card__body">
                  <div class="extras-case-card__eyebrow small fw-bold text-uppercase" aria-hidden="true">{item.tags.join(" · ")}</div>
                  <h3 class="h2 lh-1 fw-bold">{item.title}</h3>
                  <p class="h5 lh-base fw-bold mb-0">{item.summary}</p>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="extras-mind" aria-labelledby="extrasMindTitle">
      <div class="container">
        <div class="row justify-content-center text-center">
          <div class="col-12">
            <h2 id="extrasMindTitle" class="section-title section-title-reveal extras-mind-title" data-extras-mind-title>
              <span class="section-title-text">Pensieri che ci frullano in testa</span>
              <span class="extras-mind-title__balloons" aria-hidden="true">
                <span class="extras-mind-bubble extras-mind-bubble--green">Pensieri</span>
                <span class="extras-mind-bubble extras-mind-bubble--red">Che ci frullano in testa</span>
              </span>
            </h2>
          </div>
        </div>

        <div class="row g-4 mt-3 mt-lg-4 mb-5 extras-mind-grid">
          {mindItems.map((item) => (
            <div class="col-12 col-md-6 col-xl-4">
              <a class="extras-mind-card h-100 text-decoration-none" href={item.href}>
                <div class="extras-mind-card__body">
                  <span class="extras-mind-card__eyebrow small fw-bold text-uppercase">{item.eyebrow}</span>
                  <h3 class="h2 lh-1 fw-bold">{item.headline}</h3>
                  <p class="h5 lh-base fw-bold mb-0">{item.summary}</p>
                  <span class="extras-mind-card__link fs-6 fw-bold">
                    {item.cta} <i class="bi bi-arrow-right" aria-hidden="true"></i>
                  </span>
                </div>
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft extras-social-library">
      <div class="container">
        <div class="extras-social-library__inner">
          <div class="row g-4 g-lg-5 align-items-center">
            <div class="col-12 col-lg-7">
              <div class="extras-social-library__copy">
                <h2 class="page-title-uniform">Panebarco Social Library</h2>
                <p>
                  Una raccolta in movimento di contenuti, frammenti, materiali e piccoli formati da usare come archivio vivo:
                  utile per raccontare meglio il lavoro, attivare conversazioni e dare continuità ai progetti anche fuori dal set.
                </p>
                <a class="btn btn-cta btn-cta--blue btn-pill" href={buildPath("contacts", lang)}>Chiedici la social library</a>
              </div>
            </div>

            <div class="col-12 col-lg-5">
              <div class="extras-social-library__stack">
                <img class="extras-social-library__card extras-social-library__card--one" src="/images/curiosita-01.jpg" alt="">
                <img class="extras-social-library__card extras-social-library__card--two" src="/images/curiosita-02.jpg" alt="">
                <img class="extras-social-library__card extras-social-library__card--three" src="/images/curiosita-03.jpg" alt="">
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--tight pt-2 pt-md-3 pt-lg-4">
      <div class="container">
        <ContactCtaBanner
          kicker="Hai in mente un formato meno prevedibile?"
          title="LO COSTRUIAMO NOI."
        />
      </div>
    </section>
  </main>

  <script is:inline>
    (function () {
      var cleanupExtrasMindTitle = window.__cleanupExtrasMindTitle || function () {};

      function setupExtrasMindTitleReveal(cleanups) {
        var revealTitles = document.querySelectorAll("[data-extras-mind-title]");
        if (!revealTitles.length) return;

        if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          revealTitles.forEach(function (title) {
            title.classList.add("is-in-view");
          });
          return;
        }

        var lastScrollY = window.scrollY;
        var observer = new IntersectionObserver(
          function (entries) {
            var currentScrollY = window.scrollY;
            var isScrollingUp = currentScrollY < lastScrollY;
            lastScrollY = currentScrollY;

            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-in-view");
                return;
              }

              if (isScrollingUp) {
                entry.target.classList.remove("is-in-view");
              }
            });
          },
          {
            threshold: 0.01,
            rootMargin: "-35% 0px -35% 0px",
          }
        );

        revealTitles.forEach(function (title) {
          observer.observe(title);
        });

        cleanups.push(function () {
          observer.disconnect();
        });
      }

      function initExtrasPage() {
        cleanupExtrasMindTitle();

        var cleanups = [];
        setupExtrasMindTitleReveal(cleanups);

        cleanupExtrasMindTitle = function () {
          cleanups.forEach(function (dispose) {
            dispose();
          });
        };

        window.__cleanupExtrasMindTitle = cleanupExtrasMindTitle;
      }

      if (!window.__extrasMindTitleBound) {
        document.addEventListener("astro:before-swap", function () {
          cleanupExtrasMindTitle();
        });

        document.addEventListener("astro:page-load", initExtrasPage);
        window.__extrasMindTitleBound = true;
      }

      initExtrasPage();
    })();
  </script>
</Layout>
