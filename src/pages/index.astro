---
import Layout from "../layouts/Layout.astro";
import HeroStyHome from "../components/HeroStyHome.astro";
import OriginalsShowcase from "../components/OriginalsShowcase.astro";
import PortfolioShowcase from "../components/PortfolioShowcase.astro";
import ServicesShowcase from "../components/ServicesShowcase.astro";
import mainScriptUrl from "../scripts/main.js?url";
import { buildPath, getLangFromPath } from "../i18n/routing";
import { getHomeOriginalsShowcaseContent, getHomePageContent, getPortfolioShowcaseContent } from "../lib/site-content";
import { getPaneblogPreviewArticles } from "../lib/paneblog-content";

const lang = getLangFromPath(Astro.url.pathname);
const homeFallback = {
  header: {
    title: "",
    subtitle: "",
    videoSrc: "/images/1021768637.mp4",
    cta: {
      label: "",
      href: buildPath("originals", lang),
    },
  },
  intro: {
    title: "",
    typingWords: [],
    paragraphs: [],
    imageSrc: "/images/siamo-teams.png",
    imageAlt: "",
    button: {
      label: "",
      href: buildPath("studioTeam", lang),
    },
  },
  services: {
    title: "",
    stickerSrc: "/images/cose che sappiamo fare.png",
    stickerAlt: "",
    items: Array.from({ length: 4 }, () => ({
      title: "",
      href: buildPath("servicesPost", lang),
      image: "/images/servizi-cover-02-340x487.jpg",
      summary: "",
    })),
  },
  originals: "",
  seo: {
    title: "",
    description: "",
  },
};
const homeContent = await getHomePageContent({ lang, fallback: homeFallback });
const originalsShowcase = await getHomeOriginalsShowcaseContent({
  lang,
  fallback: {
    baseHref: buildPath("originals", lang),
    items: [],
  },
});
const portfolioShowcaseFallback = {
  title: "Portfolio",
  stickerSrc: "/images/cose belle che abbiamo fatto.png",
  stickerAlt: "",
  ctaLabel: "Vai al Portfolio",
  ctaHref: buildPath("portfolio", lang),
  baseHref: buildPath("portfolio", lang),
  items: ["top-left", "top-right", "bottom-left", "bottom-right", "wide"].map((slot) => ({
    title: "",
    summary: "",
    image: "/images/portfolio-cover-03-695x391.jpg",
    imageAlt: "",
    slot,
    tags: [],
    href: undefined,
  })),
};
const portfolioShowcase = await getPortfolioShowcaseContent({
  lang,
  fallback: portfolioShowcaseFallback,
});
const homePaneblogArticles = await getPaneblogPreviewArticles({
  lang,
  limit: 3,
});
---

<Layout
  title={homeContent.seo.title}
  description={homeContent.seo.description}
  lang={lang}
  entita="pagina-home-page"
  headerProps={{ darkmode: false }}
>
    <main>
      <HeroStyHome
        id="studio"
        className="hero-wrap"
        showSlider={true}
        title={homeContent.header.title}
        subtitle={homeContent.header.subtitle}
        videoSrc={homeContent.header.videoSrc}
        ctaLabel={homeContent.header.cta.label}
        ctaHref={homeContent.header.cta.href}
      />
  
      <!-- Sezione "Siamo" con testo istituzionale e CTA -->
      <section class="section-space">
        <div class="container">
          <h2 class="section-title">
            {homeContent.intro.title} <br>
            <span
              id="typing-text"
              class="accent typing-text"
              data-words={homeContent.intro.typingWords.join("|")}
              aria-live="polite"
            ></span>
          </h2>
          <div class="row g-4 align-items-center">
            <div class="col-lg-6">
              {homeContent.intro.paragraphs.map((paragraph, index) => (
                <p class:list={[index === 0 && "about-text"]}>{paragraph}</p>
              ))}
              <div class="d-flex flex-wrap gap-2 mt-4 justify-content-center justify-content-lg-start">
                <a href={homeContent.intro.button.href} class="btn btn-cta btn-cta--blue btn-pill">{homeContent.intro.button.label}</a>
              </div>
            </div>
            <div class="col-lg-6">
              <div class="team-blob">
                <img src={homeContent.intro.imageSrc} alt={homeContent.intro.imageAlt}>
              </div>
            </div>
          </div>
        </div>
      </section>
  
      <ServicesShowcase
        lang={lang}
        title={homeContent.services.title}
        stickerSrc={homeContent.services.stickerSrc}
        stickerAlt={homeContent.services.stickerAlt}
        items={homeContent.services.items}
      />
  
      <!-- Slider Panebarco Originals -->
      <OriginalsShowcase introText={homeContent.originals} items={originalsShowcase.items} />
  
      <PortfolioShowcase
        sectionId="portfolio"
        sectionClass="section-space"
        containerClass="container originals-stage portfolio-container"
        title={portfolioShowcase.title}
        stickerSrc={portfolioShowcase.stickerSrc}
        stickerAlt={portfolioShowcase.stickerAlt}
        items={portfolioShowcase.items}
        ctaHref={portfolioShowcase.ctaHref}
        ctaLabel={portfolioShowcase.ctaLabel}
      />
  
      <!-- Anteprima Paneblog -->
      <section id="paneblog" class="section-space section-space--tight">
        <div class="container">
          <h2 class="section-title section-title-reveal">
          <span class="section-title-text">PANEBLOG</span>
          <img class="section-title-sticker" src="/images/pensieri che ci frullano in testa.png" alt="" aria-hidden="true">
        </h2>
          <div class="row g-3">
            {homePaneblogArticles.map((article) => (
              <div class="col-12 col-sm-6 col-lg-4">
                <article class="card blog-card h-100">
                  <img src={article.image} alt={article.imageAlt}>
                  <div class="card-body">
                    <h3 class="blog-title">{article.title}</h3>
                    <p class="blog-date">{article.date}</p>
                    <p class="blog-abstract">{article.summary}</p>
                    <a class="blog-link stretched-link" href={article.href}>
                      Leggi di pi&ugrave; <i class="bi bi-arrow-right"></i>
                    </a>
                  </div>
                </article>
              </div>
            ))}
          </div>
          <div class="text-center mt-4">
            <a href={buildPath("paneblog", lang)} class="btn btn-cta btn-cta--blue btn-pill">LEGGI IL PANEBLOG</a>
          </div>
        </div>
      </section>
    </main>
    <script type="module" src={mainScriptUrl}></script>
</Layout>
