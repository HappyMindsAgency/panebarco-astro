---
import Layout from "../layouts/Layout.astro";
import HeroStyStudio from "../components/HeroStyStudio.astro";
import RitchText from "../components/RitchText.astro";
import { micromark } from "micromark";
import contactsPageScriptUrl from "../scripts/pages/contacts.js?url";
import { buildPath } from "../i18n/routing";
import { getContactsPageContent } from "../lib/site-content";
import { COUNTRIES_IT } from "../data/countries-it";

const lang = "it" as const;
const contactsFallback = {
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "/images/1021768637.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "",
  },
  contactDetails: {
    address: ["", ""],
    phones: ["", ""],
    email: "",
  },
  contactSection: {
    title: "",
    lead: "",
    cards: [
      { icon: "bi-envelope-paper-heart", title: "", text: "" },
      { icon: "bi-telephone-forward", title: "", text: "" },
      { icon: "bi-geo-alt", title: "", text: "" },
    ],
  },
  formSection: {
    title: "",
    lead: "",
  },
};

const contactsContent = await getContactsPageContent({ lang, fallback: contactsFallback });
const contactDetails = contactsFallback.contactDetails;
const contactCards = contactsContent.contactSection.cards;
const talentRoleOptions = ["animazione 2D", "animazione 3D", "compositing", "produzione", "illustrazione", "VFX", "montaggio"];
const talentApplicationOptions = ["Collaborazione", "Stage", "Tirocinio"];

function isExternalHref(href?: string) {
  return typeof href === "string" && href.startsWith("https");
}

function hasInlineLinks(value?: string) {
  if (typeof value !== "string") return false;
  return /<a\b|(?:mailto:|tel:|https?:\/\/)|\[[^\]]+\]\([^)]+\)/i.test(value);
}

function renderInlineRichText(value?: string) {
  if (typeof value !== "string" || !value.trim()) return "";

  return micromark(value, { allowDangerousHtml: true })
    .replace(/^<p>/i, "")
    .replace(/<\/p>\s*$/i, "");
}
---

<Layout title="Contatti - Panebarco" useInnerStyles={true} lang={lang} entita="pagina-contatti" headerProps={{ containerClass: "hero-fluid" }}>
  <main class="studio-page contacts-page">
    <HeroStyStudio backgroundVideoSrc={contactsContent.header.backgroundVideoSrc} bgWord={contactsContent.header.bgWord} title={contactsContent.header.title} subtitle={contactsContent.header.subtitle} sideImageSrc={contactsContent.header.sideImageSrc} sideImageAlt={contactsContent.header.sideImageAlt} className="hero-sty-studio page-hero page-hero--studio" showSideImage={false} />

    <section class="page-main page-main--studio contacts-content">
      <div class="container">
        {(contactsContent.contactSection.title || contactsContent.contactSection.lead || contactsContent.contactSection.content) && (
          <section class="contacts-intro contacts-block text-center" aria-labelledby="contactsIntroTitle">
            {contactsContent.contactSection.title && (
              <h2 id="contactsIntroTitle" class="page-title-uniform">{contactsContent.contactSection.title}</h2>
            )}
            {contactsContent.contactSection.lead && (
              <p class="contacts-intro__lead mx-auto mb-0">{contactsContent.contactSection.lead}</p>
            )}
            {contactsContent.contactSection.content && (
              <RitchText block={contactsContent.contactSection.content} className="contacts-intro__content mx-auto" />
            )}
          </section>
        )}

        <section class="contact-section contacts-block" aria-labelledby="contactsCardsTitle">
          <h2 id="contactsCardsTitle" class="visually-hidden">Informazioni di contatto</h2>
          <div class="contact-info-grid">
            {contactCards.map((item) => (
              <article class="contact-info-card contacts-info-card">
                <div class="contact-info-head">
                  <span class="contact-info-icon contacts-info-card__icon" aria-hidden="true">
                    <i class={`bi ${item.icon}`}></i>
                  </span>
                  <h3>{item.title}</h3>
                </div>
                <div class="contacts-info-card__body">
                  {item.text && <RitchText block={item.text} className="contacts-info-card__richtext" />}
                  {!hasInlineLinks(item.text) && (item.title === "Indirizzo" ? (
                    <address class="contacts-info-card__links mb-0">
                      {item.href ? (
                        <a href={item.href} target={isExternalHref(item.href) ? "_blank" : undefined} rel={isExternalHref(item.href) ? "noopener noreferrer" : undefined}>
                          {contactDetails.address[0]}
                          <br />
                          {contactDetails.address[1]}
                        </a>
                      ) : (
                        <>
                          {contactDetails.address[0]}
                          <br />
                          {contactDetails.address[1]}
                        </>
                      )}
                    </address>
                  ) : (
                    <div class="contacts-info-card__links">
                      {item.href ? (
                        <a href={item.href} target={isExternalHref(item.href) ? "_blank" : undefined} rel={isExternalHref(item.href) ? "noopener noreferrer" : undefined}>{item.linkLabel}</a>
                      ) : (
                        <span>{item.linkLabel}</span>
                      )}
                      {item.secondaryLink && <a href={item.secondaryLink.href}>{item.secondaryLink.label}</a>}
                    </div>
                  ))}
                </div>
              </article>
            ))}
          </div>
        </section>

        <section class="contacts-form-section contacts-block" aria-labelledby="contactsFormTitle">
          <div class="contacts-section-head contacts-section-head--center text-start mt-5">
            {contactsContent.formSection.content ? (
              <div id="contactsFormTitle" class="pt-5 mt-5">
                <RitchText block={contactsContent.formSection.content} className="contacts-form-section__intro" />
              </div>
            ) : (
              <>
                <h2 id="contactsFormTitle" class="page-title-uniform pt-5 mt-5" set:html={renderInlineRichText(contactsContent.formSection.title)}></h2>
                {contactsContent.formSection.lead && <RitchText block={contactsContent.formSection.lead} className="mb-0" />}
              </>
            )}
          </div>

          <div class="contacts-tabs-shell" data-contacts-tabs>
            <div class="contacts-tabs-nav" role="tablist" aria-label="Seleziona il tipo di richiesta">
              <button class="contacts-tab-button is-active" type="button" id="contacts-tab-contact" role="tab" aria-selected="true" aria-controls="contacts-panel-contact" data-contacts-tab="contact">
                <i class="bi bi-send" aria-hidden="true"></i>
                <span>Raccontaci la tua idea</span>
              </button>
              <button class="contacts-tab-button" type="button" id="contacts-tab-talent" role="tab" aria-selected="false" aria-controls="contacts-panel-talent" data-contacts-tab="talent" tabindex="-1">
                <i class="bi bi-stars" aria-hidden="true"></i>
                <span>Invia la tua candidatura</span>
              </button>
            </div>

            <section class="contacts-tab-panel is-active" id="contacts-panel-contact" role="tabpanel" aria-labelledby="contacts-tab-contact" data-contacts-panel="contact">
              <div class="contacts-tab-card contacts-tab-card--full">
                <div class="contacts-form-shell contacts-form-shell--wide">
                  <div class="contacts-brief-success" id="briefFormSuccess" hidden role="alert">
                    <span class="contacts-brief-success__icon" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                    <p class="contacts-brief-success__text">Grazie! Ti risponderemo al più presto.</p>
                  </div>

                  <form class="contacts-form contacts-form--brief" id="contactBriefForm" novalidate>
                    <div class="contacts-brief-apierror" id="briefFormApiError" hidden role="alert">
                      <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                      Si è verificato un errore. Riprova più tardi.
                    </div>

                    <fieldset class="contacts-brief-section">
                      <legend class="contacts-brief-section__legend">Contatti essenziali</legend>
                      <div class="row g-2 g-xl-3">
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefNome">Nome <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefNome" name="nome" type="text" required aria-required="true" autocomplete="given-name" />
                            <p class="contacts-field-error" id="briefNome-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefCognome">Cognome <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefCognome" name="cognome" type="text" required aria-required="true" autocomplete="family-name" />
                            <p class="contacts-field-error" id="briefCognome-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefEmail">Email <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefEmail" name="email" type="email" required aria-required="true" autocomplete="email" />
                            <p class="contacts-field-error" id="briefEmail-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefTelefono">Telefono <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefTelefono" name="telefono" type="text" required aria-required="true" autocomplete="tel" />
                            <p class="contacts-field-error" id="briefTelefono-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefAzienda">Azienda / Ente / Organizzazione <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefAzienda" name="azienda" type="text" required aria-required="true" autocomplete="organization" />
                            <p class="contacts-field-error" id="briefAzienda-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefRuolo">Ruolo / Funzione <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefRuolo" name="ruolo" type="text" required aria-required="true" autocomplete="organization-title" />
                            <p class="contacts-field-error" id="briefRuolo-error" role="alert" hidden></p>
                          </div>
                        </div>
                      </div>
                    </fieldset>

                    <fieldset class="contacts-brief-section">
                      <legend class="contacts-brief-section__legend">Contesto del progetto</legend>
                      <div class="row g-2 g-xl-3">
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefPaese">Paese / Nazione <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <select class="form-select" id="briefPaese" name="paese" required aria-required="true">
                              <option value="">Seleziona...</option>
                              {COUNTRIES_IT.map((country) => (
                                <option value={country} selected={country === "Italia"}>{country}</option>
                              ))}
                            </select>
                            <p class="contacts-field-error" id="briefPaese-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefCitta">Città <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="briefCitta" name="citta" type="text" required aria-required="true" autocomplete="address-level2" />
                            <p class="contacts-field-error" id="briefCitta-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <p class="form-label contacts-brief-group-label" id="briefMotivoLabel">Di cosa hai bisogno? <span class="contacts-required-mark" aria-hidden="true">*</span></p>
                            <div class="contacts-checkbox-group contacts-checkbox-group--compact" role="group" aria-labelledby="briefMotivoLabel" aria-describedby="briefMotivo-error" id="briefMotivoGroup">
                              {[
                                "Spot pubblicitario / Video promozionale",
                                "Intervento post produzione / VFX",
                                "Service / produzione esecutiva per prodotto cinematografico / audiovisivo",
                                "Co-produzione",
                                "Campagna di comunicazione",
                                "Consulenza creativa",
                                "Altro",
                              ].map((option, i) => (
                                <div class="form-check contacts-checkbox-item">
                                  <input class="form-check-input" type="checkbox" name="motivo" value={option} id={`briefMotivo-${i}`} />
                                  <label class="form-check-label" for={`briefMotivo-${i}`}>{option}</label>
                                </div>
                              ))}
                            </div>
                            <p class="contacts-field-error" id="briefMotivo-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-xl-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefTempistiche">Tempistiche previste</label>
                            <input class="form-control" id="briefTempistiche" name="tempistiche" type="text" placeholder="Quando vorresti partire o consegnare?" />
                          </div>
                        </div>
                        <div class="col-12 col-xl-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefEsempi">Link a esempi o ispirazioni</label>
                            <input class="form-control" id="briefEsempi" name="esempi_utili" type="text" placeholder="https:// oppure riferimenti utili" />
                          </div>
                        </div>
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefMateriali">Materiali utili</label>
                            <input class="form-control" id="briefMateriali" name="materiali_utili" type="text" placeholder="Brief, documenti, linee guida o cartelle condivise" />
                          </div>
                        </div>
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="briefMessaggio">Raccontaci qualcosa di più <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <textarea class="form-control" id="briefMessaggio" name="messaggio" rows="4" required aria-required="true" placeholder="Idea, contesto, obiettivi, pubblico e tono: bastano poche informazioni ben scelte per aiutarci a capire la richiesta."></textarea>
                            <p class="contacts-field-error" id="briefMessaggio-error" role="alert" hidden></p>
                          </div>
                        </div>
                      </div>
                    </fieldset>

                    <div class="contacts-brief-section contacts-brief-section--consents">
                      <div class="contacts-consent">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="briefNewsletter" name="newsletter" value="yes" />
                          <label class="form-check-label" for="briefNewsletter">Vuoi ricevere aggiornamenti sui nostri progetti?</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="briefPrivacy" name="privacy" value="accepted" required aria-required="true" />
                          <label class="form-check-label" for="briefPrivacy">
                            Acconsento al trattamento dei dati personali e all'iscrizione alla newsletter così come definito all'interno delle <a href={buildPath("privacyPolicy", lang)}>Privacy Policy</a>. <span class="contacts-required-mark" aria-hidden="true">*</span>
                          </label>
                        </div>
                        <p class="contacts-field-error" id="briefPrivacy-error" role="alert" hidden></p>
                      </div>
                    </div>

                    <div class="contacts-brief-actions">
                      <button class="btn btn-cta btn-cta--blue btn-pill contacts-brief-submit" type="submit" id="briefFormSubmit">
                        <span class="contacts-brief-submit__text">Invia richiesta</span>
                        <span class="contacts-brief-submit__loading" hidden aria-hidden="true">
                          <span class="contacts-brief-spinner"></span>
                          Invio in corso...
                        </span>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </section>

            <section class="contacts-tab-panel" id="contacts-panel-talent" role="tabpanel" aria-labelledby="contacts-tab-talent" data-contacts-panel="talent" hidden>
              <div class="contacts-tab-card contacts-tab-card--full">
                <div class="contacts-form-shell contacts-form-shell--wide">
                  <div class="contacts-brief-success" id="talentFormSuccess" hidden role="alert">
                    <span class="contacts-brief-success__icon" aria-hidden="true"><i class="bi bi-check-circle-fill"></i></span>
                    <p class="contacts-brief-success__text">Grazie! Abbiamo ricevuto la tua candidatura.</p>
                  </div>

                  <form class="contacts-form contacts-form--brief" id="talentForm" novalidate>
                    <div class="contacts-brief-apierror" id="talentFormApiError" hidden role="alert">
                      <i class="bi bi-exclamation-triangle" aria-hidden="true"></i>
                      Si è verificato un errore. Riprova più tardi.
                    </div>

                    <fieldset class="contacts-brief-section">
                      <legend class="contacts-brief-section__legend">I tuoi riferimenti</legend>
                      <div class="row g-2 g-xl-3">
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentNome">Nome <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentNome" name="nome" type="text" required aria-required="true" autocomplete="given-name" />
                            <p class="contacts-field-error" id="talentNome-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentCognome">Cognome <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentCognome" name="cognome" type="text" required aria-required="true" autocomplete="family-name" />
                            <p class="contacts-field-error" id="talentCognome-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentEmail">Email <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentEmail" name="email" type="email" required aria-required="true" autocomplete="email" />
                            <p class="contacts-field-error" id="talentEmail-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentTelefono">Telefono <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentTelefono" name="telefono" type="text" required aria-required="true" autocomplete="tel" />
                            <p class="contacts-field-error" id="talentTelefono-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentPaese">Paese / Nazione <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentPaese" name="paese" type="text" required aria-required="true" autocomplete="country-name" />
                            <p class="contacts-field-error" id="talentPaese-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentCitta">Città <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentCitta" name="citta" type="text" required aria-required="true" autocomplete="address-level2" />
                            <p class="contacts-field-error" id="talentCitta-error" role="alert" hidden></p>
                          </div>
                        </div>
                      </div>
                    </fieldset>

                    <fieldset class="contacts-brief-section">
                      <legend class="contacts-brief-section__legend">Candidatura</legend>
                      <div class="row g-2 g-xl-3">
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <p class="form-label contacts-brief-group-label" id="talentRuoloLabel">Quale ruolo ti interessa? <span class="contacts-required-mark" aria-hidden="true">*</span></p>
                            <div class="contacts-checkbox-group contacts-checkbox-group--compact" role="radiogroup" aria-labelledby="talentRuoloLabel" aria-describedby="talentRuolo-error" id="talentRuoloGroup">
                              {talentRoleOptions.map((option, index) => (
                                <div class="form-check contacts-checkbox-item">
                                  <input class="form-check-input" type="radio" name="ruolo" value={option} id={`talentRuolo-${index}`} />
                                  <label class="form-check-label" for={`talentRuolo-${index}`}>{option}</label>
                                </div>
                              ))}
                            </div>
                            <p class="contacts-field-error" id="talentRuolo-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <p class="form-label contacts-brief-group-label" id="talentCosaLabel">Per cosa ti candidi? <span class="contacts-required-mark" aria-hidden="true">*</span></p>
                            <div class="contacts-checkbox-group contacts-checkbox-group--compact" role="radiogroup" aria-labelledby="talentCosaLabel" aria-describedby="talentCosa-error" id="talentCosaGroup">
                              {talentApplicationOptions.map((option, index) => (
                                <div class="form-check contacts-checkbox-item">
                                  <input class="form-check-input" type="radio" name="cosa" value={option} id={`talentCosa-${index}`} />
                                  <label class="form-check-label" for={`talentCosa-${index}`}>{option}</label>
                                </div>
                              ))}
                            </div>
                            <p class="contacts-field-error" id="talentCosa-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12" id="talentStageSection" hidden>
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentStage">Se ti candidi per uno stage: per quanto tempo, in quale periodo, con quale ente di formazione, quale corso hai frequentato e qual è il tuo percorso? <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <textarea class="form-control" id="talentStage" name="stage" rows="5" placeholder="Durata, periodo, ente di formazione, corso frequentato e percorso di studi/formazione."></textarea>
                            <p class="contacts-field-error" id="talentStage-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12" id="talentMessageSection" hidden>
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentMessaggio">Raccontaci qualcosa di te</label>
                            <textarea class="form-control" id="talentMessaggio" name="messaggio" rows="5" placeholder="Competenze, esperienze, strumenti e il tipo di progetti su cui vorresti lavorare."></textarea>
                            <p class="contacts-field-error" id="talentMessaggio-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-xl-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentLinkCv">Carica il tuo CV <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentLinkCv" name="linkCv" type="text" required aria-required="true" placeholder="Inserisci un link condivisibile" />
                            <p class="contacts-field-error" id="talentLinkCv-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-xl-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentLinkPortfolio">Carica portfolio / showreel (link) <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentLinkPortfolio" name="linkPortfolio" type="text" required aria-required="true" placeholder="https:// oppure link a cartella condivisa" />
                            <p class="contacts-field-error" id="talentLinkPortfolio-error" role="alert" hidden></p>
                          </div>
                        </div>
                      </div>
                    </fieldset>

                    <div class="contacts-brief-section contacts-brief-section--consents">
                      <div class="contacts-consent">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="talentNewsletter" name="newsletter" value="yes" />
                          <label class="form-check-label" for="talentNewsletter">Vuoi rimanere aggiornato sui nostri progetti?</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="talentPrivacy" name="privacy" value="accepted" required aria-required="true" />
                          <label class="form-check-label" for="talentPrivacy">
                            Acconsento al trattamento dei dati personali e all'iscrizione alla newsletter così come definito all'interno delle <a href={buildPath("privacyPolicy", lang)}>Privacy Policy</a>. <span class="contacts-required-mark" aria-hidden="true">*</span>
                          </label>
                        </div>
                        <p class="contacts-field-error" id="talentPrivacy-error" role="alert" hidden></p>
                      </div>
                    </div>

                    <div class="contacts-brief-actions">
                      <button class="btn btn-cta btn-cta--blue btn-pill contacts-brief-submit" type="submit" id="talentFormSubmit">
                        <span class="contacts-brief-submit__text">Invia la tua candidatura</span>
                        <span class="contacts-brief-submit__loading" hidden aria-hidden="true">
                          <span class="contacts-brief-spinner"></span>
                          Invio in corso...
                        </span>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </section>
          </div>
        </section>
      </div>
    </section>
  </main>
  <script type="module" src={contactsPageScriptUrl}></script>
</Layout>
