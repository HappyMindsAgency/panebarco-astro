          tags: ["Coinvolgere", "Commercial"],
        },
      ],
    },
  ],
  cta: {
    kicker: "Hai un progetto in mente?",
    title: "LO ANIMIAMO NOI.",
    figureSrc: "/images/lo-animiamo-noi.png",
    figureAlt: "Mascotte Panebarco",
    background: "#9f5ea3",
    button: {
      label: "Contattaci",
      href: buildPath("contacts", lang),
    },
  },
};

const commercialContent = await getServiceDetailContent({
  resource: "pagina-commercials",
  lang,
  fallback,
});

---

<Layout
  title="Commercials - Panebarco"
  useInnerStyles={true}
  lang={lang}
  entita="pagina-commercials"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="commercials-page commercials-page--commercials studio-page">
    <HeroStyStudio
      backgroundVideoSrc={commercialContent.header.backgroundVideoSrc}
      bgWord={commercialContent.header.bgWord}
      title={commercialContent.header.title}
      subtitle={commercialContent.header.subtitle}
      sideImageSrc={commercialContent.header.sideImageSrc}
      sideImageAlt={commercialContent.header.sideImageAlt}
      showSideImage={false}
    />

    <section class="page-main page-main--studio">
      <div class="w-100">
        <div class="container">
          <div class="row">
            <div class="col-12 text-lg-center text-start">
              <h2 class="page-title-uniform mb-4 text-body">{commercialContent.intro.title}</h2>
              <RitchText block={commercialContent.intro.content} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <ServiceModesSection modes={commercialContent.modes} defaultTag="Commercial" />

    <section class="section-space section-space--tight mt-4 mt-md-5 mt-lg-5 pt-2 pt-md-3 pt-lg-4">
      <div class="container">
        <ContactCtaBanner
          kicker={commercialContent.cta.kicker}
          title={commercialContent.cta.title}
          href={commercialContent.cta.button.href}
          buttonLabel={commercialContent.cta.button.label}
          figureSrc={commercialContent.cta.figureSrc}
          figureAlt={commercialContent.cta.figureAlt}
          background={commercialContent.cta.background}
        />
      </div>
    </section>
  </main>
  <script type="module" src={commercialsPageScriptUrl}></script>
</Layout>
