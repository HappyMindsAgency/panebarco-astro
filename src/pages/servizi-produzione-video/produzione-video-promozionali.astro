      bubble: "/images/coinvolgere.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/coinvolgere-01.jpg",
          imageAlt: "Coinvolgere scena 1",
          title: "Coinvolgere 01",
          summary: "Frame dal progetto coinvolgere.",
          tags: ["Coinvolgere", "Commercial"],
        },
        {
          image: "/images/coinvolgere-02.jpg",
          imageAlt: "Coinvolgere scena 2",
          title: "Coinvolgere 02",
          summary: "Frame dal progetto coinvolgere.",
          tags: ["Coinvolgere", "Commercial"],
        },
        {
          image: "/images/coinvolgere-03.jpg",
          imageAlt: "Coinvolgere scena 3",
          title: "Coinvolgere 03",
          summary: "Frame dal progetto coinvolgere.",
