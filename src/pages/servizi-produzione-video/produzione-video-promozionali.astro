      description: "",
      bubble: "/images/promuovere.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/promuovere-01.png",
          imageAlt: "Promuovere scena 1",
          title: "Promuovere 01",
          summary: "Frame dal progetto promuovere.",
          tags: ["Promuovere", "Commercial"],
        },
