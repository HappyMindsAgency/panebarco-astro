---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import ServiceModesSection from "../../components/ServiceModesSection.astro";
import RitchText from "../../components/RitchText.astro";
import commercialsPageScriptUrl from "../../scripts/pages/commercials.js?url";
import { buildPath } from "../../i18n/routing";
