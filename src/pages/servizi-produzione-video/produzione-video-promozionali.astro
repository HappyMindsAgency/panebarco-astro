      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/spiegare-01.png",
          imageAlt: "Spiegare scena 1",
          title: "Spiegare 01",
          summary: "Frame dal progetto spiegare.",
          tags: ["Spiegare", "Commercial"],
        },
