---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import ServiceModesSection from "../../components/ServiceModesSection.astro";
import RitchText from "../../components/RitchText.astro";
import { getServiceDetailContent } from "../../lib/services-content";
import { buildPath } from "../../i18n/routing";
import commercialsPageScriptUrl from "../../scripts/pages/commercials.js?url";

const lang = "it" as const;

const serviceFallback = {
  header: {
    bgWord: "SERVICE",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "/images/panebarco-studio-video.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "",
  },
  intro: {
    title: "",
    content: "",
  },
  modes: [
    {
      title: "",
      description: "",
      bubble: "/images/raccontare.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/spiegare-01.png",
          imageAlt: "Sviluppare scena 1",
          title: "Sviluppare 01",
          summary: "Frame dal progetto sviluppare.",
          tags: ["Service"],
        },
        {
          image: "/images/raccontare-02.jpg",
          imageAlt: "Sviluppare scena 2",
          title: "Sviluppare 02",
          summary: "Frame dal progetto sviluppare.",
          tags: ["Service"],
        },
        {
          image: "/images/promuovere-03.png",
          imageAlt: "Sviluppare scena 3",
          title: "Sviluppare 03",
          summary: "Frame dal progetto sviluppare.",
          tags: ["Service"],
        },
        {
          image: "/images/coinvolgere-03.jpg",
          imageAlt: "Sviluppare scena 4",
          title: "Sviluppare 04",
          summary: "Frame dal progetto sviluppare.",
          tags: ["Service"],
        },
      ],
    },
    {
      title: "",
      description: "",
      bubble: "/images/spiegare.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/promuovere-03.png",
          imageAlt: "Produrre scena 1",
          title: "Produrre 01",
          summary: "Frame dal progetto produrre.",
          tags: ["Service"],
        },
        {
          image: "/images/spiegare-02.png",
          imageAlt: "Produrre scena 2",
          title: "Produrre 02",
          summary: "Frame dal progetto produrre.",
          tags: ["Service"],
        },
        {
          image: "/images/raccontare-03.jpg",
          imageAlt: "Produrre scena 3",
          title: "Produrre 03",
          summary: "Frame dal progetto produrre.",
          tags: ["Service"],
        },
        {
          image: "/images/coinvolgere-02.jpg",
          imageAlt: "Produrre scena 4",
          title: "Produrre 04",
          summary: "Frame dal progetto produrre.",
          tags: ["Service"],
        },
      ],
    },
    {
      title: "",
      description: "",
      bubble: "/images/promuovere.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/coinvolgere-03.jpg",
          imageAlt: "Coordinare scena 1",
          title: "Coordinare 01",
          summary: "Frame dal progetto coordinare.",
          tags: ["Service"],
        },
        {
          image: "/images/raccontare-04.jpg",
          imageAlt: "Coordinare scena 2",
          title: "Coordinare 02",
          summary: "Frame dal progetto coordinare.",
          tags: ["Service"],
        },
        {
          image: "/images/spiegare-03.png",
          imageAlt: "Coordinare scena 3",
          title: "Coordinare 03",
          summary: "Frame dal progetto coordinare.",
          tags: ["Service"],
        },
        {
          image: "/images/promuovere-02.png",
          imageAlt: "Coordinare scena 4",
          title: "Coordinare 04",
          summary: "Frame dal progetto coordinare.",
          tags: ["Service"],
        },
      ],
    },
    {
      title: "",
      description: "",
      bubble: "/images/coinvolgere.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/raccontare-02.jpg",
          imageAlt: "Accompagnare scena 1",
          title: "Accompagnare 01",
          summary: "Frame dal progetto accompagnare.",
          tags: ["Service"],
        },
        {
          image: "/images/coinvolgere-01.jpg",
          imageAlt: "Accompagnare scena 2",
          title: "Accompagnare 02",
          summary: "Frame dal progetto accompagnare.",
          tags: ["Service"],
        },
        {
          image: "/images/spiegare-04.png",
          imageAlt: "Accompagnare scena 3",
          title: "Accompagnare 03",
          summary: "Frame dal progetto accompagnare.",
          tags: ["Service"],
        },
        {
          image: "/images/promuovere-01.png",
          imageAlt: "Accompagnare scena 4",
          title: "Accompagnare 04",
          summary: "Frame dal progetto accompagnare.",
          tags: ["Service"],
        },
      ],
    },
  ],
  tag: "Service",
  cta: {
    kicker: "",
    title: "",
    figureSrc: "/images/lo-animiamo-noi.png",
    figureAlt: "",
    background: "#9f5ea3",
    button: {
      label: "",
      href: buildPath("contacts", lang),
    },
  },
};

const serviceContent = await getServiceDetailContent({
  resource: "pagina-service",
  lang,
  fallback: serviceFallback,
});
---

<Layout
  title="Service - Panebarco"
  useInnerStyles={true}
  lang={lang}
  entita="pagina-service"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="commercials-page commercials-page--service studio-page">
    <HeroStyStudio
      backgroundVideoSrc={serviceContent.header.backgroundVideoSrc}
      bgWord={serviceContent.header.bgWord}
      title={serviceContent.header.title}
      subtitle={serviceContent.header.subtitle}
      sideImageSrc={serviceContent.header.sideImageSrc}
      sideImageAlt={serviceContent.header.sideImageAlt}
      showSideImage={false}
    />

    <section class="page-main page-main--studio">
      <div class="w-100">
        <div class="container">
          <div class="row">
            <div class="col-12 text-lg-center text-start">
              <h2 class="page-title-uniform mb-4 text-body">{serviceContent.intro.title}</h2>
              <RitchText block={serviceContent.intro.content} />
            </div>
          </div>
        </div>
      </div>
    </section>

    <ServiceModesSection modes={serviceContent.modes} defaultTag={serviceContent.tag || serviceFallback.tag} />

    <section class="section-space section-space--tight mt-4 mt-md-5 mt-lg-5 pt-2 pt-md-3 pt-lg-4">
      <div class="container">
        <ContactCtaBanner
          kicker={serviceContent.cta.kicker}
          title={serviceContent.cta.title}
          href={serviceContent.cta.button.href}
          buttonLabel={serviceContent.cta.button.label}
          figureSrc={serviceContent.cta.figureSrc}
          figureAlt={serviceContent.cta.figureAlt}
          background={serviceContent.cta.background}
        />
      </div>
    </section>
  </main>
  <script type="module" src={commercialsPageScriptUrl}></script>
</Layout>
