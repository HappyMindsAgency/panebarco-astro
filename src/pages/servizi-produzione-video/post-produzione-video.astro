---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import ServiceModesSection from "../../components/ServiceModesSection.astro";
import commercialsPageScriptUrl from "../../scripts/pages/commercials.js?url";
import { buildPath } from "../../i18n/routing";
import { getServiceDetailContent } from "../../lib/services-content";

const locale = "it" as const;
const lang = locale;

const fallbackContent = {
  header: {
    bgWord: "FINISHING",
    title: "POST-PRODUZIONE",
    subtitle: "Integrare, trasformare, rifinire e potenziare le immagini",
    backgroundVideoSrc: "/images/1021768637.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "Team Panebarco",
    showSideImage: false,
  },
  intro: {
    title: "Lorem ipsum dolor sit amet",
    paragraphs: [
      "Entriamo nella fase finale del progetto quando serve continuita visiva, controllo tecnico e una lavorazione capace di tenere insieme riprese, elementi digitali, compositing e finishing.",
      "Affianchiamo produzioni, studi e agenzie su interventi di 3D, VFX, integrazione live action, color grading e rifinitura finale, con un approccio pratico che lavora sul dettaglio senza perdere di vista il risultato.",
    ],
    content: "",
  },
  modes: [
    {
      title: "Integrare",
      description:
        "3D, VFX e live action lavorano insieme per far convivere livelli diversi nello stesso frame con naturalezza, ritmo e precisione.",
      bubble: "/images/raccontare.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/compositing-e-visual-effects-01.jpg",
          imageAlt: "Integrare scena 1",
          title: "Integrare 01",
          summary: "Frame dal progetto integrare.",
          tags: ["Integrare", "Post"],
        },
        {
          image: "/images/rendering-a-livelli-02.jpg",
          imageAlt: "Integrare scena 2",
          title: "Integrare 02",
          summary: "Frame dal progetto integrare.",
          tags: ["Integrare", "Post"],
        },
        {
          image: "/images/background-e-props-02.jpg",
          imageAlt: "Integrare scena 3",
          title: "Integrare 03",
          summary: "Frame dal progetto integrare.",
          tags: ["Integrare", "Post"],
        },
        {
          image: "/images/rendering-finale-02.jpg",
          imageAlt: "Integrare scena 4",
          title: "Integrare 04",
          summary: "Frame dal progetto integrare.",
          tags: ["Integrare", "Post"],
        },
      ],
    },
    {
      title: "Trasformare",
      description:
        "Interveniamo sull'immagine per cambiare percezione, intensita e impatto visivo attraverso compositing, effetti e lavorazioni dedicate.",
      bubble: "/images/spiegare.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/rendering-a-livelli-01.jpg",
          imageAlt: "Trasformare scena 1",
          title: "Trasformare 01",
          summary: "Frame dal progetto trasformare.",
          tags: ["Trasformare", "Post"],
        },
        {
          image: "/images/storyboard-e-animatic-01.jpg",
          imageAlt: "Trasformare scena 2",
          title: "Trasformare 02",
          summary: "Frame dal progetto trasformare.",
          tags: ["Trasformare", "Post"],
        },
        {
          image: "/images/compositing-e-visual-effects-01.jpg",
          imageAlt: "Trasformare scena 3",
          title: "Trasformare 03",
          summary: "Frame dal progetto trasformare.",
          tags: ["Trasformare", "Post"],
        },
        {
          image: "/images/rendering-a-livelli-02.jpg",
          imageAlt: "Trasformare scena 4",
          title: "Trasformare 04",
          summary: "Frame dal progetto trasformare.",
          tags: ["Trasformare", "Post"],
        },
      ],
    },
    {
      title: "Rifinire",
      description:
        "Color, look and feel e finishing definiscono la tenuta finale del progetto, dando coerenza a ogni passaggio della post-produzione.",
      bubble: "/images/promuovere.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/rendering-finale-01.jpg",
          imageAlt: "Rifinire scena 1",
          title: "Rifinire 01",
          summary: "Frame dal progetto rifinire.",
          tags: ["Rifinire", "Post"],
        },
        {
          image: "/images/rendering-finale-02.jpg",
          imageAlt: "Rifinire scena 2",
          title: "Rifinire 02",
          summary: "Frame dal progetto rifinire.",
          tags: ["Rifinire", "Post"],
        },
        {
          image: "/images/background-e-props-02.jpg",
          imageAlt: "Rifinire scena 3",
          title: "Rifinire 03",
          summary: "Frame dal progetto rifinire.",
          tags: ["Rifinire", "Post"],
        },
        {
          image: "/images/compositing-e-visual-effects-01.jpg",
          imageAlt: "Rifinire scena 4",
          title: "Rifinire 04",
          summary: "Frame dal progetto rifinire.",
          tags: ["Rifinire", "Post"],
        },
      ],
    },
    {
      title: "Potenziare",
      description:
        "A volte il nostro lavoro non si vede, ma si sente: interventi invisibili che sostengono narrazione, atmosfera e continuita.",
      bubble: "/images/coinvolgere.png",
      topLayout: "col-lg-8",
      bottomLayout: "col-lg-4",
      scenes: [
        {
          image: "/images/background-e-props-02.jpg",
          imageAlt: "Potenziare scena 1",
          title: "Potenziare 01",
          summary: "Frame dal progetto potenziare.",
          tags: ["Potenziare", "Post"],
        },
        {
          image: "/images/compositing-e-visual-effects-01.jpg",
          imageAlt: "Potenziare scena 2",
          title: "Potenziare 02",
          summary: "Frame dal progetto potenziare.",
          tags: ["Potenziare", "Post"],
        },
        {
          image: "/images/rendering-a-livelli-01.jpg",
          imageAlt: "Potenziare scena 3",
          title: "Potenziare 03",
          summary: "Frame dal progetto potenziare.",
          tags: ["Potenziare", "Post"],
        },
        {
          image: "/images/rendering-finale-01.jpg",
          imageAlt: "Potenziare scena 4",
          title: "Potenziare 04",
          summary: "Frame dal progetto potenziare.",
          tags: ["Potenziare", "Post"],
        },
      ],
    },
  ],
  cta: {
    kicker: "Hai gia il materiale o il progetto e in corso?",
    title: "LO RIFINIAMO NOI.",
    figureSrc: "/images/lo-animiamo-noi.png",
    figureAlt: "Mascotte Panebarco",
    background: "#9f5ea3",
    button: {
      label: "Contattaci",
      href: buildPath("contacts", lang),
    },
  },
};

const textlessFallback = {
  header: {
    ...fallbackContent.header,
    bgWord: "",
    title: "",
    subtitle: "",
  },
  intro: {
    ...fallbackContent.intro,
    title: "",
    paragraphs: [],
    content: "",
  },
  modes: fallbackContent.modes.map((mode) => ({
    ...mode,
    title: "",
    description: "",
    scenes: mode.scenes.map((scene) => ({
      ...scene,
      title: "",
      summary: "",
      tags: [],
    })),
  })),
  cta: {
    ...fallbackContent.cta,
    kicker: "",
    title: "",
    button: {
      ...fallbackContent.cta.button,
      label: "",
    },
  },
};

const pageContent = await getServiceDetailContent({
  resource: "pagina-post-produzione",
  lang: locale,
  fallback: textlessFallback,
});
const introParagraphs = pageContent.intro.paragraphs;
const hasIntro = Boolean(pageContent.intro.title || introParagraphs.length);
const hasCta = Boolean(
  pageContent.cta.kicker ||
  pageContent.cta.title ||
  pageContent.cta.button.label
);
---

<Layout
  title="Post-produzione - Panebarco"
  useInnerStyles={true}
  lang={lang}
  entita="pagina-post-produzione"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="commercials-page commercials-page--post studio-page">
    <HeroStyStudio
      backgroundVideoSrc={pageContent.header.backgroundVideoSrc}
      bgWord={pageContent.header.bgWord}
      title={pageContent.header.title}
      subtitle={pageContent.header.subtitle}
      sideImageSrc={pageContent.header.sideImageSrc}
      sideImageAlt={pageContent.header.sideImageAlt}
      showSideImage={pageContent.header.showSideImage}
    />

    {hasIntro && (
      <section class="page-main page-main--studio">
        <div class="w-100">
          <div class="container">
            <div class="row">
              <div class="col-12 text-lg-center text-start">
                {pageContent.intro.title && <h2 class="page-title-uniform mb-4 text-body">{pageContent.intro.title}</h2>}
                {introParagraphs.map((paragraph, index) => (
                  <p class:list={[index === introParagraphs.length - 1 ? "mb-0" : "mb-4"]}>{paragraph}</p>
                ))}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    <ServiceModesSection modes={pageContent.modes} defaultTag={pageContent.tag || "Post"} />

    {hasCta && (
      <section class="section-space section-space--tight mt-4 mt-md-5 mt-lg-5 pt-2 pt-md-3 pt-lg-4">
        <div class="container">
          <ContactCtaBanner
            kicker={pageContent.cta.kicker}
            title={pageContent.cta.title}
            href={pageContent.cta.button.href}
            buttonLabel={pageContent.cta.button.label}
            figureSrc={pageContent.cta.figureSrc}
            figureAlt={pageContent.cta.figureAlt}
            background={pageContent.cta.background}
          />
        </div>
      </section>
    )}
  </main>
  <script type="module" src={commercialsPageScriptUrl}></script>
</Layout>
