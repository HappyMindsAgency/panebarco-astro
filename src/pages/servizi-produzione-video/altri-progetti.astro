---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import { buildPath, joinLocalizedPath } from "../../i18n/routing";
import { getCollectionDocuments, getSingleDocument } from "../../lib/strapi-client";
import { getImageFormat, getStrapiMediaUrl } from "../../lib/utility-function";
import customLabel from "../../lib/utility-customlabel";

const lang = "it" as const;
const specialProjectsLabel = customLabel("Progetti speciali", lang);
const thoughtsLabel = customLabel("Pensieri che ci frullano in testa", lang);
const discussLabel = customLabel("Parliamone", lang);

const fallbackSpecialProjects = [
  {
    title: "Curiosita e formati laterali",
    href: buildPath("paneblog", lang),
    image: "/images/portfolio-cover-01-695x391.jpg",
    alt: "Storyboard e contenuti laterali Panebarco",
    summary: "Contenuti nati per sperimentare formati ibridi, linguaggi piu leggeri e materiali che possono vivere anche oltre il progetto principale.",
    slot: "top-left" as const,
    tags: ["Editoriale", "Format"] as const,
  },
  {
    title: "Progetti editoriali e racconto",
    href: buildPath("paneblogTravelDiary", lang),
    image: "/images/portfolio-cover-02-695x391.jpg",
    alt: "Personaggio in una scena editoriale Panebarco",
    summary: "Appunti visivi, backstage e narrazioni corte pensate per dare continuita al tono dei progetti anche fuori dal set.",
    slot: "top-right" as const,
    tags: ["Storytelling", "Backstage"] as const,
  },
  {
    title: "Esperimenti visivi",
    href: buildPath("portfolio", lang),
    image: "/images/portfolio-cover-03-695x391.jpg",
    alt: "Personaggio illustrato colorato Panebarco",
    summary: "Piccoli test, variazioni di stile e prove di immaginario che ci aiutano a far evolvere il linguaggio del laboratorio.",
    slot: "bottom-left" as const,
    tags: ["Visual", "R&D"] as const,
  },
  {
    title: "Contenuti da archivio vivo",
    href: buildPath("portfolio", lang),
    image: "/images/portfolio-cover-04-695x391.jpg",
    alt: "Ritratto character-driven Panebarco",
    summary: "Materiali modulari che restano utili nel tempo, si riattivano facilmente e alimentano una libreria di contenuti sempre pronta a muoversi.",
    slot: "bottom-right" as const,
    tags: ["Library", "Content"] as const,
  },
] as const;

const fallbackThoughtCards = [
  {
    label: "Paneblog",
    href: buildPath("paneblog", lang),
    summary:
      "Note veloci da set, studio e lavorazioni: cose raccolte al volo, ma spesso decisive per capire come evolve un progetto.",
    cta: customLabel("Scopri di piu", lang),
    stickerClass: "extras-figma-thought-card__sticker--red",
  },
  {
    label: "Diario di viaggio",
    href: buildPath("paneblogTravelDiary", lang),
    summary:
      "Note veloci da set, studio e lavorazioni: cose raccolte al volo, ma spesso decisive per capire come evolve un progetto.",
    cta: customLabel("Accedi ora", lang),
    stickerClass: "extras-figma-thought-card__sticker--blue",
  },
  {
    label: "Newsletter",
    href: buildPath("contacts", lang),
    summary:
      "Aggiornamenti essenziali su nuove uscite, materiali utili e direzioni che vale la pena seguire senza troppo rumore intorno.",
    cta: customLabel("Accedi ora", lang),
    stickerClass: "extras-figma-thought-card__sticker--violet",
  },
] as const;

const fallbackSocialLibrary = {
  eyebrow: "PSL",
  title: "Panebarco Social Library",
  body:
    "Una raccolta in movimento di contenuti, frammenti e materiali da riattivare nel tempo: una libreria viva per raccontare meglio il lavoro, costruire continuita e far circolare ogni progetto oltre il set.",
  ctaLabel: customLabel("Scopri di piu", lang),
  ctaHref: buildPath("contacts", lang),
  background: "/images/panebarco-social-library.jpg",
};

const fallbackNewsletter = {
  kicker: "Vuoi ricevere gli aggiornamenti?",
  title: "ISCRIVITI ALLA NEWSLETTER.",
  buttonLabel: "Contattaci",
  figureSrc: "/images/lo-animiamo-noi.png",
  figureAlt: "Mascotte Panebarco",
  background: "#30997b",
};

const servicePageQuery = {
  locale: lang,
  status: "published",
  populate: {
    header: {
      populate: {
        videoBackground: true,
        imgTeam: true,
      },
    },
    intro: {
      populate: {
        media: true,
      },
    },
    pensieri: {
      populate: {
        cover: true,
      },
    },
    ctaLibrary: {
      populate: {
        cover: true,
        pulsante: true,
      },
    },
    cta: {
      populate: {
        cover: true,
        pulsante: true,
      },
    },
  },
} as const;

function asArray(value) {
  return Array.isArray(value) ? value : value ? [value] : [];
}

function stripHtml(value) {
  return String(value || "")
    .replace(/<[^>]*>/g, " ")
    .replace(/&nbsp;/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

function richTextParagraphs(value) {
  const html = String(value || "");
  const paragraphs = Array.from(html.matchAll(/<p[^>]*>([\s\S]*?)<\/p>/gi), (match) => stripHtml(match[1])).filter(Boolean);

  if (paragraphs.length) return paragraphs;

  const plainText = stripHtml(html);
  if (!plainText) return [];

  return plainText.split(/\n{2,}/).map((item) => item.trim()).filter(Boolean);
}

function getMediaSrc(media, fallback = "") {
  if (!media) return fallback;
  return getImageFormat(media, "large") || getStrapiMediaUrl(media.url) || fallback;
}

function getMediaAlt(media, fallback = "") {
  return stripHtml(media?.alternativeText || media?.caption || fallback);
}

function getButtonLabel(button, fallback = "") {
  return stripHtml(button?.etichetta || button?.title || fallback) || fallback;
}

function getButtonHref(button, fallback = "") {
  return stripHtml(button?.url || fallback) || fallback;
}

const [pageResponse, specialProjectsResponse] = await Promise.all([
  getSingleDocument("pagina-tanto-altro", servicePageQuery),
  getCollectionDocuments("progetti", {
    locale: lang,
    status: "published",
    sort: ["inEvidenza:desc", "updatedAt:desc"],
    pagination: { page: 1, pageSize: 4 },
    fields: ["titolo", "slug", "intro"],
    populate: {
      cover: true,
      tipologie_progetto: {
        fields: ["titolo"],
      },
    },
  }),
]);

const page = pageResponse?.data || {};

const header = {
  backgroundVideoSrc: getMediaSrc(page.header?.videoBackground, "/images/panebarco-commercial-video.mp4"),
  bgWord: stripHtml(page.header?.titoloTana || "SERVIZI"),
  title: stripHtml(page.header?.titolo || "E TANTO ALTRO"),
  subtitle: stripHtml(page.header?.sottotitolo || "Idee al confine tra cartoon e realta"),
  sideImageSrc: getMediaSrc(page.header?.imgTeam, "/images/hero-commercials.png"),
  sideImageAlt: getMediaAlt(page.header?.imgTeam, "Hero e tanto altro"),
};

const introParagraphs = richTextParagraphs(page.intro?.contenuto);
const intro = {
  title: stripHtml(page.intro?.titolo || "Qui finiscono le etichette e iniziano le deviazioni interessanti."),
  firstParagraph:
    introParagraphs[0] ||
    "Amiamo definirci bottega multimediale: un luogo in cui ogni progetto nasce su misura, ma anche uno spazio attraversato da idee, persone, formati e curiosita che non stanno in una sola categoria.",
  secondParagraph:
    introParagraphs[1] ||
    "Questa pagina raccoglie proprio quel margine fertile: progetti speciali, contenuti editoriali, materiali da archivio e strumenti narrativi che tengono vivo il laboratorio anche fuori dai percorsi piu canonici.",
};

const specialProjectsCollection = asArray(specialProjectsResponse?.data);
const specialProjects = fallbackSpecialProjects.map((fallbackProject, index) => {
  const project = specialProjectsCollection[index] || {};
  const slug = stripHtml(project.slug || "");
  const href = slug ? joinLocalizedPath(buildPath("portfolio", lang), slug) : fallbackProject.href;
  const introSummary = stripHtml(project.intro || "");
  const projectTags = asArray(project.tipologie_progetto)
    .map((item) => stripHtml(item?.titolo || ""))
    .filter(Boolean);
  const tags = projectTags.length ? projectTags.slice(0, 2) : fallbackProject.tags;

  return {
    title: stripHtml(project.titolo || fallbackProject.title),
    href,
    image: getMediaSrc(project.cover, fallbackProject.image),
    alt: getMediaAlt(project.cover, fallbackProject.alt || fallbackProject.title),
    summary: introSummary || fallbackProject.summary,
    slot: fallbackProject.slot,
    tags,
  };
});

const thoughts = fallbackThoughtCards.map((fallbackCard, index) => {
  const item = asArray(page.pensieri)[index] || {};
  const title = stripHtml(item.titolo || "");
  const label = item.tag && stripHtml(item.tags || "") ? stripHtml(item.tags) : title || fallbackCard.label;
  const summary = stripHtml(item.contenuto || "") || fallbackCard.summary;
  const href = stripHtml(item.url || "") || fallbackCard.href;

  return {
    label,
    href,
    summary,
    cta: fallbackCard.cta,
    stickerClass: fallbackCard.stickerClass,
  };
});

const ctaLibrary = page.ctaLibrary || {};
const ctaLibraryData = {
  eyebrow: stripHtml(ctaLibrary.sottotitolo || fallbackSocialLibrary.eyebrow),
  title: stripHtml(ctaLibrary.titolo || fallbackSocialLibrary.title),
  body: stripHtml(ctaLibrary.contenuto || fallbackSocialLibrary.body),
  ctaLabel: getButtonLabel(ctaLibrary.pulsante, fallbackSocialLibrary.ctaLabel),
  ctaHref: getButtonHref(ctaLibrary.pulsante, fallbackSocialLibrary.ctaHref),
  background: getMediaSrc(ctaLibrary.cover, fallbackSocialLibrary.background),
};

const cta = page.cta || {};
const newsletterData = {
  kicker: stripHtml(cta.sottotitolo || fallbackNewsletter.kicker),
  title: stripHtml(cta.titolo || fallbackNewsletter.title),
  buttonLabel: getButtonLabel(cta.pulsante, fallbackNewsletter.buttonLabel),
  figureSrc: getMediaSrc(cta.cover, fallbackNewsletter.figureSrc),
  figureAlt: getMediaAlt(cta.cover, fallbackNewsletter.figureAlt),
  background: stripHtml(cta.bgColor || fallbackNewsletter.background),
};
---

<Layout
  title="E tanto altro - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5", darkmode: true }}
>
  <main class="studio-page extras-page">
    <HeroStyStudio
      backgroundVideoSrc={header.backgroundVideoSrc}
      bgWord={header.bgWord}
      title={header.title}
      subtitle={header.subtitle}
      sideImageSrc={header.sideImageSrc}
      sideImageAlt={header.sideImageAlt}
      showSideImage={false}
    />

    <section class="page-main page-main--studio">
      <div class="w-100">
        <div class="container">
          <div class="row">
            <div class="col-12 text-lg-center text-start">
              <h2 class="page-title-uniform mb-4 text-body">{intro.title}</h2>
              <p class="mb-4">{intro.firstParagraph}</p>
              <p class="mb-0">{intro.secondParagraph}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="extras-figma-projects" aria-labelledby="specialProjectsTitle">
      <div class="container portfolio-container extras-figma-projects__container" data-portfolio-showcase>
        <div class="extras-figma-projects__heading">
          <h2 id="specialProjectsTitle" class="page-title-uniform">{specialProjectsLabel}</h2>
          <p>
            {stripHtml(page.progettiSpeciali || "") ||
              "Formati ibridi, racconti laterali e contenuti che nascono per esplorare nuove direzioni senza perdere la mano artigianale del nostro modo di lavorare."}
          </p>
        </div>

        <div class="portfolio-grid">
          {specialProjects.map((item) => (
            <a
              class:list={["portfolio-item", item.slot, "text-decoration-none"]}
              href={item.href}
              aria-label={`Apri il progetto speciale ${item.title}`}
              data-portfolio-showcase-card
            >
              <img src={item.image} alt={item.alt} loading="lazy" decoding="async" />
              <div class="portfolio-tags">
                {item.tags.map((tag) => (
                  <span class="portfolio-tag">{tag}</span>
                ))}
              </div>
              <div class="portfolio-overlay">
                <h3>{item.title}</h3>
                <p>{item.summary}</p>
              </div>
            </a>
          ))}
        </div>

        <div class="extras-figma-projects__cta">
          <a class="btn btn-cta btn-cta--blue btn-pill" href={buildPath("contacts", lang)}>{discussLabel}</a>
        </div>
      </div>
    </section>

    <section class="extras-figma-thoughts" aria-labelledby="extrasThoughtsTitle">
      <div class="container">
        <h2 id="extrasThoughtsTitle" class="extras-figma-thoughts__title">{thoughtsLabel}</h2>

        <div class="extras-figma-thoughts__grid">
          {thoughts.map((item) => (
            <article class="extras-figma-thought-card">
              <a class:list={["extras-figma-thought-card__sticker", item.stickerClass]} href={item.href}>
                {item.label}
              </a>
              <p class="extras-figma-thought-card__summary">{item.summary}</p>
              <a class="btn btn-cta btn-cta--orange btn-pill extras-figma-thought-card__cta" href={item.href}>
                {item.cta}
              </a>
            </article>
          ))}
        </div>
      </div>
    </section>

    <section class="extras-figma-library" style={`--extras-library-image: url('${ctaLibraryData.background}');`}>
      <div class="container">
        <div class="extras-figma-library__content">
          <p class="extras-figma-library__eyebrow">{ctaLibraryData.eyebrow}</p>
          <h2 class="extras-figma-library__title">{ctaLibraryData.title}</h2>
          <p class="extras-figma-library__body">{ctaLibraryData.body}</p>
          <a class="btn btn-cta btn-cta--blue btn-pill extras-figma-library__cta" href={ctaLibraryData.ctaHref}>
            {ctaLibraryData.ctaLabel}
          </a>
        </div>
      </div>
    </section>

    <div class="container pt-md-5 mt-5 mb-5">
      <section class="extras-newsletter-card" style={`background: ${newsletterData.background};`}>
        <div class="extras-newsletter-card__copy">
          <p class="extras-newsletter-card__kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">{newsletterData.kicker}</p>
          <h2 class="extras-newsletter-card__title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">
            {newsletterData.title}
          </h2>
          <a class="btn btn-cta btn-cta--orange btn-pill" href={buildPath("contacts", lang)}>{newsletterData.buttonLabel}</a>
        </div>
        <img
          class="extras-newsletter-card__figure"
          src={newsletterData.figureSrc}
          alt={newsletterData.figureAlt}
          loading="lazy"
          decoding="async"
        />
      </section>
    </div>
  </main>

  <script is:inline>
    (function () {
      function initPortfolioShowcases() {
        document.querySelectorAll("[data-portfolio-showcase]").forEach(function (root) {
          if (root.dataset.bound === "true") return;
          root.dataset.bound = "true";

          var title = root.querySelector("[data-portfolio-showcase-title]");
          var cards = root.querySelectorAll("[data-portfolio-showcase-card]");

          if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            if (title) title.classList.add("is-in-view");
            cards.forEach(function (card) {
              card.classList.add("is-in-view");
            });
            return;
          }

          if (title) {
            var lastScrollY = window.scrollY;
            var titleObserver = new IntersectionObserver(
              function (entries) {
                var currentScrollY = window.scrollY;
                var isScrollingUp = currentScrollY < lastScrollY;
                lastScrollY = currentScrollY;

                entries.forEach(function (entry) {
                  if (entry.isIntersecting) {
                    entry.target.classList.add("is-in-view");
                    return;
                  }

                  if (isScrollingUp) {
                    entry.target.classList.remove("is-in-view");
                  }
                });
              },
              {
                threshold: 0.01,
                rootMargin: "-35% 0px -35% 0px",
              }
            );

            titleObserver.observe(title);
          }

          cards.forEach(function (card, index) {
            card.style.transitionDelay = String(index * 0.08) + "s";
          });

          var cardObserver = new IntersectionObserver(
            function (entries) {
              entries.forEach(function (entry) {
                if (!entry.isIntersecting) return;

                entry.target.classList.add("is-in-view");
                cardObserver.unobserve(entry.target);
              });
            },
            {
              threshold: 0.15,
              rootMargin: "0px 0px -50% 0px",
            }
          );

          cards.forEach(function (card) {
            cardObserver.observe(card);
          });
        });
      }

      if (!window.__panebarcoPortfolioShowcaseBound) {
        document.addEventListener("astro:page-load", initPortfolioShowcases);
        window.__panebarcoPortfolioShowcaseBound = true;
      }

      initPortfolioShowcases();
    })();
  </script>
</Layout>
