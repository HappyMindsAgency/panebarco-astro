---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import RitchText from "../../components/RitchText.astro";
import mainScriptUrl from "../../scripts/main.js?url";
import { buildPath, joinLocalizedPath } from "../../i18n/routing";
import { getLabel, getServicesOriginalSlides, getServicesPageContent } from "../../lib/services-content";

const lang = "it" as const;
const clientsLabel = getLabel("I nostri clienti", lang);
const originalsCtaLabel = getLabel("Guarda tutti gli originals", lang);
const servicesFallback = {
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "/images/1021768637.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "",
  },
  intro: {
    title: "",
    content: "",
    mediaSrc: "/images/lo-studio-panebarco-teams.png",
    mediaAlt: "",
    hasMedia: false,
  },
  serviceCards: [
    {
      title: "",
      href: buildPath("servicesCommercials", lang),
      image: "/images/portfolio-cover-03-695x391.jpg",
      imageAlt: "",
      summary: "",
      bullets: ["Commercials", "Story-driven", "Expainer", "Adv & social"],
      buttonLabel: getLabel("Scopri di piu", lang),
    },
    {
      title: "",
      href: buildPath("servicesPost", lang),
      image: "/images/rendering-a-livelli-02.jpg",
      imageAlt: "",
      summary: "",
      bullets: ["Color & finish", "3D e VFX", "Compositing", "Motion graphics"],
      buttonLabel: getLabel("Scopri di piu", lang),
    },
    {
      title: "",
      href: buildPath("servicesService", lang),
      image: "/images/portfolio-cover-04-695x391.jpg",
      imageAlt: "",
      summary: "",
      bullets: ["Produzione", "Supporto set", "Pipeline", "Supervisione"],
      buttonLabel: getLabel("Scopri di piu", lang),
    },
    {
      title: "",
      href: buildPath("servicesMore", lang),
      image: "/images/hero-commercials.png",
      imageAlt: "",
      summary: "",
      bullets: ["Progetti speciali", "Contenuti editoriali", "Social library", "Newsletter & format"],
      buttonLabel: getLabel("Scopri di piu", lang),
    },
  ],
  clientNames: [],
  originalsIntro: "",
  oscarCta: {
    title: "",
    subtitle: "",
    content: "",
    image: "/images/lo-studio-oscar.png",
    imageAlt: "",
    button: {
      label: "",
      href: buildPath("studioOscars", lang),
    },
  },
};

const servicesPage = await getServicesPageContent({
  lang,
  fallback: servicesFallback,
});

const servicesOriginalSlides = await getServicesOriginalSlides({
  lang,
  fallback: [
    {
      title: "",
      subtitle: "",
      image: "/images/originals-cover-01-700x395.jpg",
      slug: "caramelle",
    },
    {
      title: "",
      subtitle: "",
      image: "/images/originals-cover-02-270x395.jpg",
      slug: "marta-e-la-morte",
    },
    {
      title: "",
      subtitle: "",
      image: "/images/originals-cover-03-270x395.jpg",
      slug: "nostoppingnora",
    },
  ],
});

const originalSlidesFallback = [
  {
    title: "",
    subtitle: "",
    image: "/images/originals-cover-01-700x395.jpg",
    slug: "caramelle",
  },
  {
    title: "",
    subtitle: "",
    image: "/images/originals-cover-02-270x395.jpg",
    slug: "marta-e-la-morte",
  },
  {
    title: "",
    subtitle: "",
    image: "/images/originals-cover-03-270x395.jpg",
    slug: "nostoppingnora",
  },
];

const repeatedClientNames = Array.from({ length: 3 }, (_, groupIndex) =>
  servicesPage.clientNames.map((name) => ({
    name,
    isDuplicate: groupIndex > 0,
  }))
).flat();

const portfolioOriginalSlides = originalSlidesFallback.map((fallbackSlide, index) => {
  const slide = servicesOriginalSlides[index] || fallbackSlide;

  return {
    title: slide.title,
    subtitle: slide.subtitle,
    image: slide.image,
    href: joinLocalizedPath(buildPath("originals", lang), slide.slug || fallbackSlide.slug),
  };
});
---

<Layout
  title="Servizi - Panebarco"
  useInnerStyles={true}
  lang={lang}
  entita="pagina-servizi"
  headerProps={{ containerClass: "hero-fluid" }}
>
    <main class="studio-page services-page">
      <HeroStyStudio
        backgroundVideoSrc={servicesPage.header.backgroundVideoSrc}
        bgWord={servicesPage.header.bgWord}
        title={servicesPage.header.title}
        subtitle={servicesPage.header.subtitle}
        sideImageSrc={servicesPage.header.sideImageSrc}
        sideImageAlt={servicesPage.header.sideImageAlt}
        className="hero-sty-studio page-hero page-hero--studio"
        showSideImage={false}
      />

      <section class="page-main page-main--studio services-hub-intro">
        <div class="w-100">
          <div class="container">
            <div class="row">
              <div class="col-12 text-lg-center text-start services-intro-copy">
                <RitchText block={servicesPage.intro.content} />
              </div>
            </div>
          </div>
        </div>
      </section>

      <section id="servizi" class="section-space section-space--soft pt-0 services-home-cards services-figma-list">
        <div class="container">
          <div class="services-figma-list__rows">
            {servicesPage.serviceCards.map((service, index) => (
              <article class="services-figma-row">
                <div class:list={["services-figma-row__media", index % 2 === 1 && "order-lg-2"]}>
                  <img src={service.image} alt={service.imageAlt} loading="lazy" decoding="async" />
                </div>

                <div class:list={["services-figma-row__copy", index % 2 === 1 && "order-lg-1"]}>
                  <h2>{service.title}</h2>
                  <p class="services-figma-row__summary">{service.summary}</p>

                  <ul class="service-editorial-list list-unstyled services-figma-row__list">
                    {service.bullets.map((item) => (
                      <li>{item}</li>
                    ))}
                  </ul>

                  <a class="btn btn-cta btn-cta--orange btn-pill" href={service.href}>
                    {service.buttonLabel}
                  </a>
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section class="services-clients section-space section-space--soft" aria-labelledby="servicesClientsTitle" hidden>
        <div class="container">
          <div class="text-center services-clients-head">
            <h2 id="servicesClientsTitle" class="page-title-uniform">{clientsLabel}</h2>
          </div>
        </div>

        <div class="services-logos-marquee">
          <div class="services-logos-track">
            {repeatedClientNames.map((client) => (
              <div class="services-logo-item" aria-hidden={client.isDuplicate ? "true" : undefined}>
                <span>{client.name}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="servizi-originals" class="section-space section-space--soft services-originals-band">
        <div class="container">
          <div class="services-originals-band__brand">
            <img class="originals-title-logo" src="/images/panebarco originals logo.png" alt="Panebarco Originals" />
          </div>

          <div class="services-originals-band__intro">
            <p>{servicesPage.originalsIntro}</p>
          </div>

          <div class="portfolio-originals-slider__shell position-relative" data-portfolio-slider data-portfolio-start="0">
            <button
              class="portfolio-originals-slider__arrow portfolio-originals-slider__arrow--prev btn btn-light rounded-circle"
              type="button"
              aria-label="Slide precedente"
              data-portfolio-prev
            >
              <i class="bi bi-arrow-left"></i>
            </button>

            <div class="portfolio-originals-slider__frame">
              <div class="portfolio-originals-slider__track" data-portfolio-track>
                {portfolioOriginalSlides.map((slide) => (
                  <a
                    class="portfolio-originals-slider__slide text-decoration-none"
                    href={slide.href}
                    data-portfolio-slide
                    aria-label={`Apri ${slide.title}`}
                  >
                    <img src={slide.image} alt={slide.title} loading="lazy" decoding="async" />
                    <div class="portfolio-originals-slider__overlay">
                      <h3>{slide.title}</h3>
                      <p>{slide.subtitle}</p>
                    </div>
                  </a>
                ))}
              </div>
            </div>

            <button
              class="portfolio-originals-slider__arrow portfolio-originals-slider__arrow--next btn btn-light rounded-circle"
              type="button"
              aria-label="Slide successiva"
              data-portfolio-next
            >
              <i class="bi bi-arrow-right"></i>
            </button>
          </div>

          <div class="services-originals-band__cta">
            <a class="btn btn-cta btn-cta--blue btn-pill" href={buildPath("originals", lang)}>{originalsCtaLabel}</a>
          </div>
        </div>
      </section>

      <section class="studio-oscar-section section-space section-space--soft">
        <div class="container">
          <div class="row g-4 g-lg-5 align-items-start align-items-lg-center studio-oscar-grid">
            <div class="col-12 col-lg-5 studio-oscar-art">
              <img class="img-fluid d-block mx-auto mx-lg-0" src={servicesPage.oscarCta.image} alt={servicesPage.oscarCta.imageAlt}>
            </div>
            <div class="col-12 col-lg-7 studio-oscar-copy text-start">
              <h2 class="page-title-uniform">
                {servicesPage.oscarCta.subtitle}
                <span>{servicesPage.oscarCta.title}</span>
              </h2>
              <p>{servicesPage.oscarCta.content}</p>
              <a class="btn btn-cta btn-cta--blue btn-pill" href={servicesPage.oscarCta.button.href}>{servicesPage.oscarCta.button.label}</a>
            </div>
          </div>
        </div>
      </section>
    </main>
    <script is:inline>
      (function () {
        function initServicesOriginalsSlider() {
          document.querySelectorAll("[data-portfolio-slider]").forEach(function (root) {
            if (root.dataset.bound === "true") return;
            root.dataset.bound = "true";

            var prev = root.querySelector("[data-portfolio-prev]");
            var next = root.querySelector("[data-portfolio-next]");
            var slides = root.querySelectorAll("[data-portfolio-slide]");

            if (!prev || !next || !slides.length) return;

            var activeIndex = Number(root.getAttribute("data-portfolio-start") || 0);

            function mod(index, length) {
              return ((index % length) + length) % length;
            }

            function syncSlides() {
              var prevIndex = mod(activeIndex - 1, slides.length);
              var nextIndex = mod(activeIndex + 1, slides.length);

              slides.forEach(function (slide, index) {
                slide.classList.toggle("is-active", index === activeIndex);
                slide.classList.toggle("is-prev", index === prevIndex);
                slide.classList.toggle("is-next", index === nextIndex);
                slide.classList.toggle("is-hidden", index !== activeIndex && index !== prevIndex && index !== nextIndex);
              });
            }

            prev.addEventListener("click", function () {
              activeIndex = mod(activeIndex - 1, slides.length);
              syncSlides();
            });

            next.addEventListener("click", function () {
              activeIndex = mod(activeIndex + 1, slides.length);
              syncSlides();
            });

            slides.forEach(function (slide, index) {
              slide.addEventListener("click", function (event) {
                if (index === activeIndex) return;

                event.preventDefault();
                activeIndex = index;
                syncSlides();
              });
            });

            window.requestAnimationFrame(function () {
              activeIndex = mod(activeIndex, slides.length);
              syncSlides();
            });
          });
        }

        if (!window.__panebarcoServicesPageBound) {
          document.addEventListener("astro:page-load", initServicesOriginalsSlider);
          window.__panebarcoServicesPageBound = true;
        }

        initServicesOriginalsSlider();
      })();
    </script>
    <script type="module" src={mainScriptUrl}></script>
</Layout>
