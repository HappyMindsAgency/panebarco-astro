---
import Layout from "../../layouts/Layout.astro";
import HeroStyHome from "../../components/HeroStyHome.astro";
import { buildPath } from "../../i18n/routing";
import { getPortfolioDetailContent } from "../../lib/site-content";

const lang = "it" as const;
const slugPort = Astro.params.slugPort ?? "";
const project = slugPort ? await getPortfolioDetailContent({ lang, slug: slugPort }) : null;

if (!project) {
  return Astro.redirect(buildPath("portfolio", lang));
}
---

<Layout
  title={project.seo.title}
  description={project.seo.description}
  useInnerStyles={false}
  lang={lang}
  entita="progetti"
  documentId={project.documentId}
  headerProps={{ darkmode: false }}
>
  <main class="portfolio-detail-page">
    <HeroStyHome
      id="portfolio-hero"
      className="hero-wrap"
      videoSrc={false}
      imageSrc={project.cover || "/images/hero-dettaglio-fallback.jpg"}
      showSlider={false}
      showTitle={false}
      showSubtitle={false}
      showCta={false}
    />

    <section class="portfolio-detail-content pb-5">
      <div class="container">
        <div class="row">
          <div class="col-12">
            <p class="text-uppercase fw-bold text-body-secondary small mb-2">{project.category}</p>
            <h1 class="heading-detail mb-2">{project.titolo}</h1>
            <p class="text-uppercase fw-bold text-body-secondary small mb-3">{project.meta}</p>

            <div class="d-flex flex-wrap gap-2 align-items-center mb-4">
              {project.tags.map((tag, index) => (
                <span
                  class:list={[
                    "badge fw-bold rounded-1 px-2 py-1",
                    index === 0
                      ? "text-bg-primary text-uppercase"
                      : "bg-secondary-subtle text-dark-emphasis",
                  ]}
                >
                  {tag}
                </span>
              ))}
            </div>

            {project.introParagraphs[0] && (
              <p class="portfolio-detail-body mt-3 mt-md-5 pt-5 mb-3">{project.introParagraphs[0]}</p>
            )}
            {project.introParagraphs[1] && (
              <p class="portfolio-detail-body mb-4">{project.introParagraphs[1]}</p>
            )}
            {project.introParagraphs[2] && (
              <p class="portfolio-detail-body mb-4">{project.introParagraphs[2]}</p>
            )}

            {project.importedContentHtml && (
              <div class="portfolio-detail-imported-content mb-4">
                <Fragment set:html={project.importedContentHtml} />
              </div>
            )}

            {project.videos[0] && (
              <div class="ratio ratio-16x9 overflow-hidden mb-4">
                <iframe
                  src={project.videos[0].src}
                  title={project.videos[0].title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            )}

            {project.introParagraphs[2] && (
              <p class="portfolio-detail-body mt-5 mb-5">{project.introParagraphs[2]}</p>
            )}

            {project.videos[1] && (
              <div class="ratio ratio-16x9 overflow-hidden">
                <iframe
                  src={project.videos[1].src}
                  title={project.videos[1].title}
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  referrerpolicy="strict-origin-when-cross-origin"
                  allowfullscreen
                ></iframe>
              </div>
            )}

            {project.creditsHtml && (
              <section class="pt-5 mt-5">
                <div class="row justify-content-center">
                  <div class="col-12 col-lg-10">
                    <hr class="border-dark opacity-100 mb-5" />
                  </div>
                  <div class="col-12 col-lg-10">
                    <h2 class="h1 text-uppercase fw-bold mb-4">Credits</h2>
                    <Fragment set:html={project.creditsHtml} />
                  </div>
                </div>
              </section>
            )}
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  @media (max-width: 991.98px) {
    :global(.hero-wrap .hero-card) {
      min-height: unset !important;
      aspect-ratio: 16 / 9;
    }
  }

  .portfolio-detail-page p {
    max-width: 100%;
  }

  .portfolio-detail-page .portfolio-detail-body {
    font-family: var(--bs-body-font-family);
    font-size: var(--type-body);
    line-height: 1.5;
    font-weight: 400;
    color: var(--ink);
  }

  .portfolio-detail-page .portfolio-detail-imported-content {
    color: var(--ink);
  }

  .portfolio-detail-page .portfolio-detail-imported-content :global(p) {
    font-family: var(--bs-body-font-family);
    font-size: var(--type-body);
    line-height: 1.5;
    font-weight: 400;
    color: var(--ink);
    margin-bottom: 1.5rem;
  }

  .portfolio-detail-page .portfolio-detail-imported-content :global(iframe) {
    display: block;
    width: 100%;
    max-width: 100%;
    aspect-ratio: 16 / 9;
    height: auto;
    border: none;
  }
</style>
