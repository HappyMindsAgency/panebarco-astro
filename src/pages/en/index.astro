                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentEmail">Email <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentEmail" name="email" type="email" required aria-required="true" autocomplete="email" />
                            <p class="contacts-field-error" id="talentEmail-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentTelefono">Phone <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentTelefono" name="telefono" type="text" required aria-required="true" autocomplete="tel" />
                            <p class="contacts-field-error" id="talentTelefono-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentPaese">Country <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentPaese" name="paese" type="text" required aria-required="true" autocomplete="country-name" />
                            <p class="contacts-field-error" id="talentPaese-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-sm-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentCitta">City <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentCitta" name="citta" type="text" required aria-required="true" autocomplete="address-level2" />
                            <p class="contacts-field-error" id="talentCitta-error" role="alert" hidden></p>
                          </div>
                        </div>
                      </div>
                    </fieldset>

                    <fieldset class="contacts-brief-section">
                      <legend class="contacts-brief-section__legend">Application</legend>
                      <div class="row g-2 g-xl-3">
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <p class="form-label contacts-brief-group-label" id="talentRuoloLabel">Which role interests you? <span class="contacts-required-mark" aria-hidden="true">*</span></p>
                            <div class="contacts-checkbox-group contacts-checkbox-group--compact" role="radiogroup" aria-labelledby="talentRuoloLabel" aria-describedby="talentRuolo-error" id="talentRuoloGroup">
                              {talentRoleOptions.map((option, index) => (
                                <div class="form-check contacts-checkbox-item">
                                  <input class="form-check-input" type="radio" name="ruolo" value={option} id={`talentRuolo-${index}`} />
                                  <label class="form-check-label" for={`talentRuolo-${index}`}>{option}</label>
                                </div>
                              ))}
                            </div>
                            <p class="contacts-field-error" id="talentRuolo-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12">
                          <div class="contacts-brief-field">
                            <p class="form-label contacts-brief-group-label" id="talentCosaLabel">What are you applying for? <span class="contacts-required-mark" aria-hidden="true">*</span></p>
                            <div class="contacts-checkbox-group contacts-checkbox-group--compact" role="radiogroup" aria-labelledby="talentCosaLabel" aria-describedby="talentCosa-error" id="talentCosaGroup">
                              {talentApplicationOptions.map((option, index) => (
                                <div class="form-check contacts-checkbox-item">
                                  <input class="form-check-input" type="radio" name="cosa" value={option} id={`talentCosa-${index}`} />
                                  <label class="form-check-label" for={`talentCosa-${index}`}>{option}</label>
                                </div>
                              ))}
                            </div>
                            <p class="contacts-field-error" id="talentCosa-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12" id="talentStageSection" hidden>
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentStage">If you are applying for an internship: for how long, in which period, with which training institution, which course did you attend, and what is your background? <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <textarea class="form-control" id="talentStage" name="stage" rows="5" placeholder="Duration, period, training institution, attended course and educational background."></textarea>
                            <p class="contacts-field-error" id="talentStage-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12" id="talentMessageSection" hidden>
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentMessaggio">Tell us something about yourself</label>
                            <textarea class="form-control" id="talentMessaggio" name="messaggio" rows="5" placeholder="Skills, experience, tools and the kind of projects you would like to work on."></textarea>
                            <p class="contacts-field-error" id="talentMessaggio-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-xl-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentLinkCv">Upload your CV <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentLinkCv" name="linkCv" type="text" required aria-required="true" placeholder="Paste a shareable link" />
                            <p class="contacts-field-error" id="talentLinkCv-error" role="alert" hidden></p>
                          </div>
                        </div>
                        <div class="col-12 col-xl-6">
                          <div class="contacts-brief-field">
                            <label class="form-label" for="talentLinkPortfolio">Upload portfolio / showreel (link) <span class="contacts-required-mark" aria-hidden="true">*</span></label>
                            <input class="form-control" id="talentLinkPortfolio" name="linkPortfolio" type="text" required aria-required="true" placeholder="https:// or link to a shared folder" />
                            <p class="contacts-field-error" id="talentLinkPortfolio-error" role="alert" hidden></p>
                          </div>
                        </div>
                      </div>
                    </fieldset>

                    <div class="contacts-brief-section contacts-brief-section--consents">
                      <div class="contacts-consent">
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="talentNewsletter" name="newsletter" value="yes" />
                          <label class="form-check-label" for="talentNewsletter">Would you like to stay updated on our projects?</label>
                        </div>
                        <div class="form-check">
                          <input class="form-check-input" type="checkbox" id="talentPrivacy" name="privacy" value="accepted" required aria-required="true" />
                          <label class="form-check-label" for="talentPrivacy">
                            I consent to the processing of personal data and newsletter subscription as defined in the <a href={buildPath("privacyPolicy", lang)}>{customLabel("footer.privacy", lang)}</a>. <span class="contacts-required-mark" aria-hidden="true">*</span>
                          </label>
                        </div>
                        <p class="contacts-field-error" id="talentPrivacy-error" role="alert" hidden></p>
                      </div>
                    </div>

                    <div class="contacts-brief-actions">
                      <button class="btn btn-cta btn-cta--blue btn-pill contacts-brief-submit" type="submit" id="talentFormSubmit">
                        <span class="contacts-brief-submit__text">Send your application</span>
                        <span class="contacts-brief-submit__loading" hidden aria-hidden="true">
                          <span class="contacts-brief-spinner"></span>
                          Sending...
                        </span>
                      </button>
                    </div>
                  </form>
                </div>
              </div>
            </section>
          </div>
        </section>
      </div>
    </section>
  </main>

  <script type="module" src={mainScriptUrl}></script>
  <script is:inline>
    (function () {
      var cleanupHomeContact = window.__cleanupHomeContact || function () {};

      function collectFormData(form) {
        var data = {};
        var fd = new FormData(form);

        fd.forEach(function (value, key) {
          if (Object.prototype.hasOwnProperty.call(data, key)) {
            if (!Array.isArray(data[key])) data[key] = [data[key]];
            data[key].push(value);
          } else {
            data[key] = value;
          }
        });

        return data;
      }

      function setupContactsTabs(cleanups) {
        var roots = Array.from(document.querySelectorAll("[data-contacts-tabs]"));
        if (roots.length === 0) return;

        roots.forEach(function (root) {
          var buttons = Array.from(root.querySelectorAll("[data-contacts-tab]"));
          var panels = Array.from(root.querySelectorAll("[data-contacts-panel]"));
          if (buttons.length === 0 || panels.length === 0) return;

          var controller = new AbortController();
          var signal = controller.signal;

          function activateTab(targetKey) {
            buttons.forEach(function (button) {
              var isActive = button.getAttribute("data-contacts-tab") === targetKey;
              button.classList.toggle("is-active", isActive);
              button.setAttribute("aria-selected", String(isActive));
              button.tabIndex = isActive ? 0 : -1;
            });

            panels.forEach(function (panel) {
              var isActive = panel.getAttribute("data-contacts-panel") === targetKey;
              panel.classList.toggle("is-active", isActive);
              panel.hidden = !isActive;
            });
          }

          buttons.forEach(function (button, index) {
            button.addEventListener("click", function () {
              activateTab(button.getAttribute("data-contacts-tab"));
            }, { signal: signal });

            button.addEventListener("keydown", function (event) {
              if (event.key !== "ArrowRight" && event.key !== "ArrowLeft" && event.key !== "Home" && event.key !== "End") {
                return;
              }

              event.preventDefault();

              var nextIndex = index;
              if (event.key === "ArrowRight") nextIndex = (index + 1) % buttons.length;
              if (event.key === "ArrowLeft") nextIndex = (index - 1 + buttons.length) % buttons.length;
              if (event.key === "Home") nextIndex = 0;
              if (event.key === "End") nextIndex = buttons.length - 1;

              var nextButton = buttons[nextIndex];
              if (!nextButton) return;
              activateTab(nextButton.getAttribute("data-contacts-tab"));
              nextButton.focus();
            }, { signal: signal });
          });

          var activeButton = buttons.find(function (button) {
            return button.classList.contains("is-active");
          }) || buttons[0];

          if (activeButton) {
            activateTab(activeButton.getAttribute("data-contacts-tab"));
          }

          cleanups.push(function () {
            controller.abort();
          });
        });
      }

      function setupBriefContactForm(cleanups) {
        var form = document.getElementById("contactBriefForm");
        if (!form) return;

        var controller = new AbortController();
        var signal = controller.signal;
        var requiredFieldIds = [
          "briefNome",
          "briefCognome",
          "briefEmail",
          "briefTelefono",
          "briefAzienda",
          "briefRuolo",
          "briefPaese",
          "briefCitta",
          "briefMessaggio",
        ];

        function getFieldError(field) {
          var value = field.value.trim();
          if (field.tagName === "SELECT") {
            return value ? "" : "Select an option";
          }
          if (field.type === "email") {
            if (!value) return "This field is required";
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value) ? "" : "Enter a valid email address";
          }
          return value ? "" : "This field is required";
        }

        function setFieldError(fieldId, message) {
          var field = document.getElementById(fieldId);
          var errorEl = document.getElementById(fieldId + "-error");
          if (field) field.classList.toggle("is-brief-invalid", !!message);
          if (errorEl) {
            errorEl.hidden = !message;
            errorEl.textContent = message || "";
          }
        }

        function validateAll() {
          var firstInvalidEl = null;

          requiredFieldIds.forEach(function (id) {
            var field = document.getElementById(id);
            if (!field) return;
            var err = getFieldError(field);
            setFieldError(id, err);
            if (err && !firstInvalidEl) firstInvalidEl = field;
          });

          var needsChecked = form.querySelectorAll('input[name="motivo"]:checked').length > 0;
          var needsErrorEl = document.getElementById("briefMotivo-error");
          var needsGroup = document.getElementById("briefMotivoGroup");
          if (!needsChecked) {
            if (needsErrorEl) {
              needsErrorEl.hidden = false;
              needsErrorEl.textContent = "Select at least one option";
            }
            if (needsGroup) needsGroup.classList.add("is-brief-invalid");
            if (!firstInvalidEl) firstInvalidEl = needsGroup;
          } else {
            if (needsErrorEl) {
              needsErrorEl.hidden = true;
              needsErrorEl.textContent = "";
            }
            if (needsGroup) needsGroup.classList.remove("is-brief-invalid");
          }

          var privacyField = document.getElementById("briefPrivacy");
          if (privacyField && !privacyField.checked) {
            setFieldError("briefPrivacy", "You need to accept the Privacy Policy to continue");
            if (!firstInvalidEl) firstInvalidEl = privacyField;
          } else {
            setFieldError("briefPrivacy", "");
          }

          return firstInvalidEl;
        }

        function setSubmitLoading(loading) {
          var btn = document.getElementById("briefFormSubmit");
          if (!btn) return;
          btn.disabled = loading;
          var textEl = btn.querySelector(".contacts-brief-submit__text");
          var loadingEl = btn.querySelector(".contacts-brief-submit__loading");
          if (textEl) textEl.hidden = loading;
          if (loadingEl) loadingEl.hidden = !loading;
        }

        form.addEventListener("submit", function (event) {
          event.preventDefault();

          var firstInvalidEl = validateAll();
          if (firstInvalidEl) {
            firstInvalidEl.scrollIntoView({ behavior: "smooth", block: "center" });
            if (typeof firstInvalidEl.focus === "function") {
              setTimeout(function () { firstInvalidEl.focus(); }, 350);
            }
            return;
          }

          setSubmitLoading(true);

          var apiErrorEl = document.getElementById("briefFormApiError");
          if (apiErrorEl) apiErrorEl.hidden = true;

          var data = collectFormData(form);
          console.log("[EnHomeBriefForm] Sending:", data);
          var mockRequest = new Promise(function (resolve) { setTimeout(resolve, 1200); });

          mockRequest.then(function () {
            var successEl = document.getElementById("briefFormSuccess");
            if (successEl) successEl.hidden = false;
            form.hidden = true;
          }).catch(function (error) {
            console.error("[EnHomeBriefForm] Error:", error);
            if (apiErrorEl) apiErrorEl.hidden = false;
            setSubmitLoading(false);
          });
        }, { signal: signal });

        cleanups.push(function () {
          controller.abort();
        });
      }

      function setupTalentForm(cleanups) {
        var form = document.getElementById("talentForm");
        if (!form) return;

        var controller = new AbortController();
        var signal = controller.signal;
        var requiredFieldIds = [
          "talentNome",
          "talentCognome",
          "talentEmail",
          "talentTelefono",
          "talentPaese",
          "talentCitta",
          "talentLinkCv",
          "talentLinkPortfolio",
        ];

        function getFieldError(field) {
          var value = field.value.trim();
          if (field.tagName === "SELECT") {
            return value ? "" : "Select an option";
          }
          if (field.type === "email") {
            if (!value) return "This field is required";
            return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value) ? "" : "Enter a valid email address";
          }
          return value ? "" : "This field is required";
        }

        function setFieldError(fieldId, message) {
          var field = document.getElementById(fieldId);
          var errorEl = document.getElementById(fieldId + "-error");
          if (field) field.classList.toggle("is-brief-invalid", !!message);
          if (errorEl) {
            errorEl.hidden = !message;
            errorEl.textContent = message || "";
          }
        }

        function setGroupError(errorId, groupId, message) {
          var errorEl = document.getElementById(errorId);
          var groupEl = document.getElementById(groupId);
          if (errorEl) {
            errorEl.hidden = !message;
            errorEl.textContent = message || "";
          }
          if (groupEl) {
            groupEl.classList.toggle("is-brief-invalid", !!message);
          }
        }

        function getSelectedRadioValue(name) {
          var checked = form.querySelector('input[name="' + name + '"]:checked');
          return checked ? checked.value : "";
        }

        function syncConditionalFields() {
          var applicationType = getSelectedRadioValue("cosa");
          var stageSection = document.getElementById("talentStageSection");
          var messageSection = document.getElementById("talentMessageSection");
          var stageVisible = applicationType === "Internship";
          var messageVisible = applicationType === "Collaboration";

          if (stageSection) stageSection.hidden = !stageVisible;
          if (messageSection) messageSection.hidden = !messageVisible;

          if (!stageVisible) setFieldError("talentStage", "");
          if (!messageVisible) setFieldError("talentMessaggio", "");
        }

        function validateAll() {
          var firstInvalidEl = null;

          requiredFieldIds.forEach(function (id) {
            var field = document.getElementById(id);
            if (!field) return;
            var err = getFieldError(field);
            setFieldError(id, err);
            if (err && !firstInvalidEl) firstInvalidEl = field;
          });

          var roleValue = getSelectedRadioValue("ruolo");
          if (!roleValue) {
            setGroupError("talentRuolo-error", "talentRuoloGroup", "Select a role");
            if (!firstInvalidEl) firstInvalidEl = document.getElementById("talentRuoloGroup");
          } else {
            setGroupError("talentRuolo-error", "talentRuoloGroup", "");
          }

          var applicationType = getSelectedRadioValue("cosa");
          if (!applicationType) {
            setGroupError("talentCosa-error", "talentCosaGroup", "Select an option");
            if (!firstInvalidEl) firstInvalidEl = document.getElementById("talentCosaGroup");
          } else {
            setGroupError("talentCosa-error", "talentCosaGroup", "");
          }

          if (applicationType === "Internship") {
            var stageField = document.getElementById("talentStage");
            var stageError = stageField ? getFieldError(stageField) : "";
            setFieldError("talentStage", stageError);
            if (stageError && !firstInvalidEl) firstInvalidEl = stageField;
          } else {
            setFieldError("talentStage", "");
          }

          var privacyField = document.getElementById("talentPrivacy");
          if (privacyField && !privacyField.checked) {
            setFieldError("talentPrivacy", "You need to accept the Privacy Policy to continue");
            if (!firstInvalidEl) firstInvalidEl = privacyField;
          } else {
            setFieldError("talentPrivacy", "");
          }

          return firstInvalidEl;
        }

        function setSubmitLoading(loading) {
          var btn = document.getElementById("talentFormSubmit");
          if (!btn) return;
          btn.disabled = loading;
          var textEl = btn.querySelector(".contacts-brief-submit__text");
          var loadingEl = btn.querySelector(".contacts-brief-submit__loading");
          if (textEl) textEl.hidden = loading;
          if (loadingEl) loadingEl.hidden = !loading;
        }

        form.querySelectorAll('input[name="cosa"]').forEach(function (input) {
          input.addEventListener("change", syncConditionalFields, { signal: signal });
        });

        syncConditionalFields();

        form.addEventListener("submit", function (event) {
          event.preventDefault();

          var firstInvalidEl = validateAll();
          if (firstInvalidEl) {
            firstInvalidEl.scrollIntoView({ behavior: "smooth", block: "center" });
            if (typeof firstInvalidEl.focus === "function") {
              setTimeout(function () { firstInvalidEl.focus(); }, 350);
            }
            return;
          }

          setSubmitLoading(true);

          var apiErrorEl = document.getElementById("talentFormApiError");
          if (apiErrorEl) apiErrorEl.hidden = true;

          var data = collectFormData(form);
          console.log("[EnHomeTalentForm] Sending:", data);
          var mockRequest = new Promise(function (resolve) { setTimeout(resolve, 1200); });

          mockRequest.then(function () {
            var successEl = document.getElementById("talentFormSuccess");
            if (successEl) successEl.hidden = false;
            form.hidden = true;
          }).catch(function (error) {
            console.error("[EnHomeTalentForm] Error:", error);
            if (apiErrorEl) apiErrorEl.hidden = false;
            setSubmitLoading(false);
          });
        }, { signal: signal });

        cleanups.push(function () {
          controller.abort();
        });
      }

      function initHomeContactForm() {
        cleanupHomeContact();

        var cleanups = [];
        setupContactsTabs(cleanups);
        setupBriefContactForm(cleanups);
        setupTalentForm(cleanups);

        cleanupHomeContact = function () {
          cleanups.forEach(function (dispose) {
            dispose();
          });
        };

        window.__cleanupHomeContact = cleanupHomeContact;
      }

      if (!window.__panebarcoEnHomeContactBound) {
        document.addEventListener("astro:before-swap", function () {
          cleanupHomeContact();
        });

        document.addEventListener("astro:page-load", initHomeContactForm);
        window.__panebarcoEnHomeContactBound = true;
      }

      initHomeContactForm();
    })();
  </script>

