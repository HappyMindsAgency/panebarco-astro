---
import Layout from "../../layouts/Layout.astro";
import ChatPopSlider from "../../components/ChatPopSlider.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import { buildPath, joinLocalizedPath } from "../../i18n/routing";

const lang = "it" as const;
const caramelleArticleHref = joinLocalizedPath(buildPath("paneblog", lang), "dietro-le-quinte-di-caramelle");

const diarySlides = [
  {
    date: "21 FEB 2026",
    title: "Diario di viaggio",
    headline: "Dentro Caramelle: appunti di sviluppo, passaggi chiave e intuizioni raccolte lungo il percorso.",
    summary:
      "Un diario aperto sul processo: dalle prime ipotesi visive alla costruzione del tono, fino ai materiali che aiutano un progetto a prendere forma.",
    image: "/images/paneblog-cover-01-356x217.png",
    href: buildPath("paneblogTravelDiary", lang),
    cta: "Apri il diario",
  },
  {
    date: "15 FEB 2026",
    title: "Taccuino di produzione",
