---
import Layout from "../../layouts/Layout.astro";
import ChatPopSlider from "../../components/ChatPopSlider.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import { buildPath, getLangFromPath } from "../../i18n/routing";
import { getFlashNewsContent, getPaneblogPageContent } from "../../lib/paneblog-content";

const lang = getLangFromPath(Astro.url.pathname);
const pageContent = await getPaneblogPageContent({
  lang,
  fallback: {
    cta: {
      background: "#9f5ea3",
      buttonLabel: "Contattaci",
      figureAlt: "Mascotte Panebarco",
      figureSrc: "/images/lo-animiamo-noi.png",
      href: buildPath("contacts", lang),
      kicker: "Vuoi ricevere gli aggiornamenti?",
      title: "ISCRIVITI ALLA NEWSLETTER.",
    },
    header: {
      bgWord: "PRODUZIONI INDIPENDENTI",
      subtitle: "Format originali sviluppati dentro la nostra casa creativa",
      title: "PANEBLOG",
    },
    intro: {
      body: "Un luogo piu editoriale del sito: flash news, dietro le quinte, note di produzione e storie raccolte lungo il viaggio",
      title: "Diario di viaggio",
    },
  },
});

const flashNewsItems = await getFlashNewsContent({ lang, limit: 3 });

const diaryChatMessages = flashNewsItems.length
  ? flashNewsItems
  : [
      {
        date: "18/03/2026",
        character: "Maya",
        avatar: "/images/teams-avatar-che-fate-01.png",
        title: "Flash dal diario",
        text: "Oggi abbiamo salvato tre appunti utili da una reference trovata quasi per caso.",
      },
      {
        date: "16/03/2026",
        character: "Luca",
        avatar: "/images/teams-avatar-che-fate-02.png",
        title: "Nota di produzione",
        text: "Abbiamo rimesso in fila timing, tono e materiali per capire cosa tenere vivo nel racconto.",
      },
      {
        date: "12/03/2026",
        character: "Nora",
        avatar: "/images/teams-avatar-che-fate-03.png",
        title: "Dietro le quinte",
        text: "Una piccola deviazione di processo ci ha aperto una strada piu interessante per il progetto.",
      },
    ];
---

<Layout
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-paneblog"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="studio-page originals-page paneblog-page">
    <HeroStyStudio
      backgroundVideoSrc={pageContent.header.backgroundVideoSrc}
      bgWord={pageContent.header.bgWord}
      title={pageContent.header.title}
      subtitle={pageContent.header.subtitle}
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
      className="hero-sty-studio page-hero page-hero--studio"
      showSideImage={false}
    />


   

    <section class="section-space paneblog-articles p-0" data-paneblog-root>
      <div class="container">
        <div class="row justify-content-center text-center mb-4 mb-lg-5" hidden>
          <div class="col-12">
            <h2 id="paneblogMindTitle" class="section-title section-title-reveal paneblog-mind-title" data-paneblog-mind-title>
              <span class="section-title-text">{pageContent.intro.title}</span>
              <span class="paneblog-mind-title__balloons" aria-hidden="true">
                <span class="paneblog-mind-bubble paneblog-mind-bubble--green">Pensieri</span>
                <span class="paneblog-mind-bubble paneblog-mind-bubble--red">Che ci frullano in testa</span>
              </span>
            </h2>
            <p class="paneblog-mind-subtitle mt-4">
              {pageContent.intro.body}
            </p>
          </div>
        </div>

        <div class="row justify-content-center mb-4 mb-lg-5">
          <div class="col-12">
            <ChatPopSlider
              variant="wide"
              className="paneblog-chat-pop"
              ariaLabel="Flash dal diario"
              messages={diaryChatMessages}
            />
          </div>
        </div>

        <div class="row justify-content-center text-center mb-3 mb-lg-4 mt-5">
          <div class="col-12 col-xl-8 mt-md-5">
            <h2 class="page-title-uniform mt-5">Lista articoli</h2>
          </div>
        </div>

        <div class="paneblog-filters mb-4 mb-lg-5">
          <div class="d-flex flex-wrap justify-content-center gap-2">
            {pageContent.articleFilters.map((filter, index) => (
              <button
                class:list={["paneblog-filter-chip", index === 0 && "is-active"]}
                type="button"
                data-filter-value={filter}
              >
                {filter}
              </button>
            ))}
          </div>
        </div>

        <div class="row g-4" data-paneblog-grid>
          {pageContent.articles.map((article) => (
            <div class="col-12 col-md-6 col-xl-4" data-article-card data-category={article.category}>
              <article class="card blog-card h-100">
                <img src={article.image} alt={article.imageAlt} loading="lazy" decoding="async" />
                <div class="card-body">
                  <p class="blog-date">{article.date}</p>
                  <p class="paneblog-article-category">{article.category}</p>
                  <h3 class="blog-title">{article.title}</h3>
                  <p class="blog-abstract">{article.summary}</p>
                  <a class="blog-link stretched-link" href={article.href}>
                    Leggi di piu <i class="bi bi-arrow-right"></i>
                  </a>
                </div>
              </article>
            </div>
          ))}
        </div>

        <div class="paneblog-empty-state d-none text-center mt-4" data-paneblog-empty>
          <p class="mb-0">Nessun articolo corrisponde al filtro selezionato.</p>
        </div>

        <div class="text-center mt-4 d-none" data-paneblog-load-more-wrap>
          <button class="paneblog-load-more-link" type="button" data-paneblog-load-more>
            Carica altro <i class="bi bi-arrow-right" aria-hidden="true"></i>
          </button>
        </div>
      </div>
    </section>

    <div class="container mt-5 pt-4 mb-5 paneblog-cta-shell">
        <ContactCtaBanner
          kicker={pageContent.cta.kicker}
          title={pageContent.cta.title}
          href={pageContent.cta.href}
          buttonLabel={pageContent.cta.buttonLabel}
          figureSrc={pageContent.cta.figureSrc}
          figureAlt={pageContent.cta.figureAlt}
          background={pageContent.cta.background}
        />
      </div>
  </main>

  <style>
    .paneblog-load-more-link {
      appearance: none;
      -webkit-appearance: none;
      -moz-appearance: none;
      background: none;
      border: 0;
      outline: none;
      box-shadow: none;
      padding: 0;
      margin: 0;
      color: #009fe3;
      font-size: 1.75rem;
      font-weight: 800;
      line-height: 1;
      display: inline-flex;
      align-items: center;
      gap: 0.45rem;
      cursor: pointer;
    }

    .paneblog-load-more-link:hover,
    .paneblog-load-more-link:focus-visible {
      color: #009fe3;
      text-decoration: none;
      opacity: 0.88;
    }

    .paneblog-load-more-link i {
      font-size: 1.2rem;
      line-height: 1;
    }

    .paneblog-cta-shell :global(.contact-cta-card) {
      overflow: visible;
      min-height: clamp(15rem, 23vw, 18.5rem);
      padding-left: calc(clamp(1.2rem, 4.2vw, 4.8rem) + clamp(16rem, 30vw, 24rem) + clamp(1.2rem, 2.2vw, 2rem));
    }

    .paneblog-cta-shell :global(.contact-cta-figure) {
      left: clamp(1.2rem, 4.2vw, 4.8rem);
      bottom: 0;
      top: auto;
      width: clamp(16rem, 30vw, 24rem);
      height: auto;
      transform: none;
      z-index: 2;
    }

    @media (max-width: 991.98px) {
      .paneblog-cta-shell :global(.contact-cta-card) {
        min-height: clamp(12rem, 28vw, 15.5rem);
        padding-left: calc(clamp(0.9rem, 2.6vw, 2.4rem) + clamp(11rem, 27vw, 15rem) + clamp(1rem, 2vw, 1.6rem));
      }

      .paneblog-cta-shell :global(.contact-cta-figure) {
        left: clamp(0.9rem, 2.6vw, 2.4rem);
        width: clamp(11rem, 27vw, 15rem);
        bottom: 0;
        top: auto;
        transform: none;
      }
    }

    @media (max-width: 767.98px) {
      .paneblog-cta-shell :global(.contact-cta-card) {
        min-height: clamp(8rem, 24vw, 10rem);
        padding-left: calc(clamp(0.35rem, 1.5vw, 0.9rem) + clamp(6.8rem, 21vw, 8.6rem) + 1rem);
      }

      .paneblog-cta-shell :global(.contact-cta-figure) {
        left: clamp(0.35rem, 1.5vw, 0.9rem);
        width: clamp(6.8rem, 21vw, 8.6rem);
        bottom: 0;
        top: auto;
        transform: none;
      }
    }
  </style>

  <script is:inline>
    (function () {
      function initPaneblogPage() {
        (function setupMindTitleReveal() {
          var revealTitles = document.querySelectorAll("[data-paneblog-mind-title]");
          if (!revealTitles.length) return;

          if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
            revealTitles.forEach(function (title) {
              title.classList.add("is-in-view");
            });
            return;
          }

          var lastScrollY = window.scrollY;
          var observer = new IntersectionObserver(
            function (entries) {
              var currentScrollY = window.scrollY;
              var isScrollingUp = currentScrollY < lastScrollY;
              lastScrollY = currentScrollY;

              entries.forEach(function (entry) {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-in-view");
                  return;
                }

                if (isScrollingUp) {
                  entry.target.classList.remove("is-in-view");
                }
              });
            },
            {
              threshold: 0.01,
              rootMargin: "-35% 0px -35% 0px",
            }
          );

          revealTitles.forEach(function (title) {
            if (title.dataset.revealBound === "true") return;
            title.dataset.revealBound = "true";
            observer.observe(title);
          });
        })();

        (function setupNewsletterTyping() {
          var typingText = document.getElementById("newsletter-typing-text");
          if (!typingText || typingText.dataset.bound === "true") return;
          typingText.dataset.bound = "true";

          var words = (typingText.getAttribute("data-words") || "")
            .split("|")
            .map(function (word) {
              return word.trim();
            })
            .filter(Boolean);

          if (!words.length) return;

          var wordIndex = 0;
          var charIndex = 0;
          var isDeleting = false;
          var currentColor = "#009FE3";
          var timeoutId = null;
          var palette = ["#009FE3", "#B03D4F", "#995791", "#3394B2", "#30997B"];
          var typingSpeed = 90;
          var deletingSpeed = 55;
          var wordPause = 1200;
          var restartPause = 350;

          function queue(nextStep, delay) {
            timeoutId = window.setTimeout(nextStep, delay);
          }

          function animateTyping() {
            var currentWord = words[wordIndex];

            if (!isDeleting) {
              if (charIndex === 0) {
                currentColor = palette[Math.floor(Math.random() * palette.length)];
                typingText.style.color = currentColor;
              }

              charIndex += 1;
              typingText.textContent = currentWord.slice(0, charIndex).toUpperCase();

              if (charIndex === currentWord.length) {
                isDeleting = true;
                queue(animateTyping, wordPause);
                return;
              }

              queue(animateTyping, typingSpeed);
              return;
            }

            charIndex -= 1;
            typingText.textContent = currentWord.slice(0, Math.max(0, charIndex)).toUpperCase();

            if (charIndex === 0) {
              isDeleting = false;
              wordIndex = (wordIndex + 1) % words.length;
              queue(animateTyping, restartPause);
              return;
            }

            queue(animateTyping, deletingSpeed);
          }

          typingText.textContent = "";

          window.addEventListener(
            "beforeunload",
            function () {
              if (timeoutId !== null) {
                window.clearTimeout(timeoutId);
              }
            },
            { once: true }
          );

          queue(animateTyping, 500);
        })();

        document.querySelectorAll("[data-paneblog-slider]").forEach(function (root) {
          if (root.dataset.bound === "true") return;
          root.dataset.bound = "true";

          var image = root.querySelector("[data-paneblog-slide-image]");
          var date = root.querySelector("[data-paneblog-slide-date]");
          var kicker = root.querySelector("[data-paneblog-slide-kicker]");
          var title = root.querySelector("[data-paneblog-slide-title]");
          var summary = root.querySelector("[data-paneblog-slide-summary]");
          var link = root.querySelector("[data-paneblog-slide-link]");
          var prev = root.querySelector("[data-paneblog-prev]");
          var next = root.querySelector("[data-paneblog-next]");
          var dots = root.querySelectorAll("[data-paneblog-dot]");

          if (!image || !date || !kicker || !title || !summary || !link || !prev || !next || !dots.length) return;

          var activeIndex = 0;
          var autoplayId = null;

          function mod(index, length) {
            return ((index % length) + length) % length;
          }

          function render(index) {
            activeIndex = mod(index, diarySlides.length);
            var item = diarySlides[activeIndex];

            image.setAttribute("src", item.image);
            image.setAttribute("alt", item.headline);
            date.textContent = item.date;
            kicker.textContent = item.title;
            title.textContent = item.headline;
            summary.textContent = item.summary;
            link.setAttribute("href", item.href);
            link.textContent = item.cta;

            dots.forEach(function (dot, dotIndex) {
              dot.classList.toggle("is-active", dotIndex === activeIndex);
            });
          }

          function stopAutoplay() {
            if (autoplayId !== null) {
              window.clearInterval(autoplayId);
              autoplayId = null;
            }
          }

          function startAutoplay() {
            stopAutoplay();
            autoplayId = window.setInterval(function () {
              render(activeIndex + 1);
            }, 4200);
          }

          prev.addEventListener("click", function () {
            render(activeIndex - 1);
            startAutoplay();
          });

          next.addEventListener("click", function () {
            render(activeIndex + 1);
            startAutoplay();
          });

          dots.forEach(function (dot) {
            dot.addEventListener("click", function () {
              render(Number(dot.getAttribute("data-paneblog-dot") || 0));
              startAutoplay();
            });
          });

          root.addEventListener("pointerenter", stopAutoplay);
          root.addEventListener("pointerleave", startAutoplay);
          root.addEventListener("focusin", stopAutoplay);
          root.addEventListener("focusout", function () {
            window.requestAnimationFrame(function () {
              if (!root.contains(document.activeElement)) {
                startAutoplay();
              }
            });
          });

          render(0);
          startAutoplay();
        });

        document.querySelectorAll("[data-paneblog-root]").forEach(function (root) {
          if (root.dataset.bound === "true") return;
          root.dataset.bound = "true";

          var activeFilter = "Tutti";
          var initialVisibleCount = 6;
          var visibleLimit = initialVisibleCount;
          var buttons = root.querySelectorAll("[data-filter-value]");
          var cards = root.querySelectorAll("[data-article-card]");
          var emptyState = root.querySelector("[data-paneblog-empty]");
          var loadMoreWrap = root.querySelector("[data-paneblog-load-more-wrap]");
          var loadMoreButton = root.querySelector("[data-paneblog-load-more]");

          function updateCards() {
            var matchingCards = [];

            cards.forEach(function (card) {
              var category = card.getAttribute("data-category");
              var matchesFilter = activeFilter === "Tutti" || activeFilter === category;

              if (matchesFilter) {
                matchingCards.push(card);
              }
            });

            cards.forEach(function (card) {
              card.classList.add("d-none");
            });

            matchingCards.slice(0, visibleLimit).forEach(function (card) {
              card.classList.remove("d-none");
            });

            if (emptyState) {
              emptyState.classList.toggle("d-none", matchingCards.length > 0);
            }

            if (loadMoreWrap) {
              loadMoreWrap.classList.toggle("d-none", matchingCards.length <= visibleLimit || matchingCards.length === 0);
            }
          }

          buttons.forEach(function (button) {
            button.addEventListener("click", function () {
              var value = button.getAttribute("data-filter-value");
              if (!value) return;

              activeFilter = value;

              buttons.forEach(function (btn) {
                btn.classList.toggle("is-active", btn === button);
              });

              visibleLimit = initialVisibleCount;
              updateCards();
            });
          });

          if (loadMoreButton) {
            loadMoreButton.addEventListener("click", function () {
              visibleLimit += initialVisibleCount;
              updateCards();
            });
          }

          updateCards();
        });
      }

      if (!window.__paneblogPageBound) {
        document.addEventListener("astro:page-load", initPaneblogPage);
        window.__paneblogPageBound = true;
      }

      initPaneblogPage();
    })();
  </script>
</Layout>
