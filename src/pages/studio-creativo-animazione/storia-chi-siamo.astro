---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import RitchText from "../../components/RitchText.astro";
import studioPageScriptUrl from "../../scripts/pages/studio.js?url";
import { getLangFromPath } from "../../i18n/routing";
import { getStoryMutantPageContent } from "../../lib/site-content";
import type { ContactBannerContent, StoryMutantPageContent } from "../../lib/site-content.types";

const lang = getLangFromPath(Astro.url.pathname);
const storyFallback = {
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "/images/panebarco-studio-video.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "",
  },
  intro: {
    mediaSrc: "/images/lo-studio-img-intro.png",
    mediaAlt: "",
  },
  timeline: {
    title: "",
    imageSrc: "/images/lo-studi-storia-panebarco.png",
    imageAlt: "",
  },
  cta: {
    imageSrc: "/images/cta-ci-vediamo-agli-oscar.png",
    imageAlt: "",
  },
  seo: {
    title: "",
    description: "",
  },
};
function hasStoryCta(
  cta: StoryMutantPageContent["cta"]
): cta is ContactBannerContent & { button: { label: string; href: string } } {
  return Boolean(cta?.button?.label && cta?.button?.href && (cta.kicker || cta.title));
}

const storyContent: StoryMutantPageContent = await getStoryMutantPageContent({ lang, fallback: storyFallback });
const hasIntro = Boolean(
  storyContent.intro.title ||
  storyContent.intro.content ||
  storyContent.intro.mediaSrc
);
const hasTimeline = Boolean(
  storyContent.timeline.title ||
  storyContent.timeline.content ||
  storyContent.timeline.cards.length
);
const hasMediaGallery = Boolean(
  storyContent.mediaGallery.title ||
  storyContent.mediaGallery.content ||
  storyContent.mediaGallery.videos.length
);
const storyCta = hasStoryCta(storyContent.cta) ? storyContent.cta : null;
---

<Layout
  title={storyContent.seo.title}
  description={storyContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-storia-azienda-mutante"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="studio-page story-mutant-page">
    <HeroStyStudio
      backgroundVideoSrc={storyContent.header.backgroundVideoSrc}
      bgWord={storyContent.header.bgWord}
      title={storyContent.header.title}
      subtitle={storyContent.header.subtitle}
      showSideImage={false}
      sideImageSrc={storyContent.header.sideImageSrc}
      sideImageAlt={storyContent.header.sideImageAlt}
    />

    {hasIntro && (
      <section class="page-main page-main--studio">
        <div class="container">
          <div class="row g-4 g-xl-5 align-items-end studio-story">
            <div class="col-12 col-lg-7 studio-story-copy">
              {storyContent.intro.title && <h2 class="page-title-uniform">{storyContent.intro.title}</h2>}
              {storyContent.intro.content && <RitchText block={storyContent.intro.content} className="story-mutant-intro-richtext" />}
            </div>
            <div class="col-12 col-lg-5 studio-story-art text-lg-end">
              {storyContent.intro.mediaSrc && (
                <img
                  class="studio-story-intro-img img-fluid d-block ms-lg-auto"
                  src={storyContent.intro.mediaSrc}
                  alt={storyContent.intro.mediaAlt}
                />
              )}
            </div>
          </div>
        </div>
      </section>
    )}

    {hasTimeline && (
      <section class="studio-timeline section-space">
        <div class="container">
          <h2 class="studio-timeline-title page-title-uniform" id="studioTimelineTitle">
            Scorri la nostra timeline in 6 Atti
          </h2>

          {storyContent.timeline.cards.length > 0 && (
            <>
              <div class="studio-timeline-track" data-studio-timeline>
                <button
                  class="studio-timeline-arrow studio-timeline-arrow--prev"
                  type="button"
                  aria-label="Anno precedente"
                  data-timeline-prev
                >
                  <img src="/images/freccia-sinistra.png" alt="" aria-hidden="true" />
                </button>

                <div class="studio-timeline-viewport" id="studioTimelineViewport" aria-labelledby="studioTimelineTitle">
                  <div class="studio-timeline-slides">
                    {storyContent.timeline.cards.map((card, index) => (
                      <article class:list={["studio-timeline-card", index === 0 && "is-active"]}>
                        <div class="row g-3 g-lg-4 align-items-center">
                          <div class="col-12 col-md-6 studio-timeline-year">
                            {card.imageSrc && (
                              <img class="img-fluid d-block" src={card.imageSrc} alt={card.imageAlt} />
                            )}
                          </div>
                          <div class="col-12 col-md-6 studio-timeline-copy">
                            {card.title && <h3>{card.title}</h3>}
                            {card.content && <RitchText block={card.content} className="story-mutant-card-richtext" />}
                          </div>
                        </div>
                      </article>
                    ))}
                  </div>
                </div>

                <button
                  class="studio-timeline-arrow studio-timeline-arrow--next"
                  type="button"
                  aria-label="Anno successivo"
                  data-timeline-next
                >
                  <img src="/images/freccia-destra.png" alt="" aria-hidden="true" />
                </button>
              </div>

              <div class="studio-timeline-dots" role="tablist" aria-label="Seleziona una fase della storia">
                {storyContent.timeline.cards.map((card, index) => (
                  <button
                    class:list={["studio-timeline-dot", index === 0 && "is-active"]}
                    type="button"
                    aria-label={`Vai a ${card.title || `fase ${index + 1}`}`}
                    data-timeline-dot={index}
                  ></button>
                ))}
              </div>
            </>
          )}
        </div>
      </section>
    )}

    {hasMediaGallery && (
      <section class="section-space section-space--soft story-mutant-media">
        <div class="container">
          <div class="story-mutant-media__intro text-lg-center text-start">
            {storyContent.mediaGallery.title && <h2 class="page-title-uniform">{storyContent.mediaGallery.title}</h2>}
            {storyContent.mediaGallery.content && <RitchText block={storyContent.mediaGallery.content} className="story-mutant-media-richtext" />}
          </div>

          {storyContent.mediaGallery.videos.length > 0 && (
            <div class="story-mutant-media__content">
              {storyContent.mediaGallery.videos.length === 1 ? (
                <div class="story-mutant-media__video story-mutant-media__video--single">
                  <div class="ratio ratio-16x9 overflow-hidden rounded-4">
                    {storyContent.mediaGallery.videos[0].videoSrc ? (
                      <video controls playsinline preload="metadata" title={storyContent.mediaGallery.videos[0].title}>
                        <source
                          src={storyContent.mediaGallery.videos[0].videoSrc}
                          type={storyContent.mediaGallery.videos[0].mimeType || "video/mp4"}
                        />
                      </video>
                    ) : (
                      <iframe
                        src={storyContent.mediaGallery.videos[0].embedSrc}
                        title={storyContent.mediaGallery.videos[0].title}
                        loading="lazy"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                        allowfullscreen
                        referrerpolicy="strict-origin-when-cross-origin"
                      ></iframe>
                    )}
                  </div>
                </div>
              ) : (
                <div class="row g-4">
                  {storyContent.mediaGallery.videos.map((video) => (
                    <div class="col-12 col-lg-6">
                      <div class="story-mutant-media__video">
                        <div class="ratio ratio-16x9 overflow-hidden rounded-4">
                          {video.videoSrc ? (
                            <video controls playsinline preload="metadata" title={video.title}>
                              <source src={video.videoSrc} type={video.mimeType || "video/mp4"} />
                            </video>
                          ) : (
                            <iframe
                              src={video.embedSrc}
                              title={video.title}
                              loading="lazy"
                              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                              allowfullscreen
                              referrerpolicy="strict-origin-when-cross-origin"
                            ></iframe>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>
              )}
            </div>
          )}
        </div>
      </section>
    )}

    {storyCta && (
      <div class="container pt-md-5 mt-5 mb-5">
        <section class="extras-newsletter-card" style={storyCta.background ? `background:${storyCta.background};` : undefined}>
          <div class="extras-newsletter-card__copy">
            {storyCta.kicker && (
              <p class="extras-newsletter-card__kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">{storyCta.kicker}</p>
            )}
            {storyCta.title && (
              <h2 class="extras-newsletter-card__title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">
                {storyCta.title}
              </h2>
            )}
            {storyCta.button.href && storyCta.button.label && (
              <a class="btn btn-cta btn-cta--blue btn-pill" href={storyCta.button.href}>{storyCta.button.label}</a>
            )}
          </div>
          {storyCta.imageSrc && (
            <img
              class="extras-newsletter-card__figure"
              src={storyCta.imageSrc}
              alt={storyCta.imageAlt}
              loading="lazy"
              decoding="async"
            />
          )}
        </section>
      </div>
    )}
  </main>

  <script type="module" src={studioPageScriptUrl}></script>
</Layout>
