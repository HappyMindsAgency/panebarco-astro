---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import OscarCtaSection from "../../components/OscarCtaSection.astro";
import RitchText from "../../components/RitchText.astro";
import studioPageScriptUrl from "../../scripts/pages/studio.js?url";
import { buildPath, getLangFromPath } from "../../i18n/routing";
import { getStudioPageContent } from "../../lib/site-content";

const lang = getLangFromPath(Astro.url.pathname);
const studioFallback = {
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "/images/panebarco-studio-video.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "",
  },
  intro: {
    title: "",
    paragraphs: [],
    mediaSrc: "/images/lo-studio-img-intro.png",
    mediaAlt: "",
    button: {
      label: "",
      href: buildPath("studioStory", lang),
    },
  },
  protagonists: {
    title: "",
    paragraphs: [],
    imageAlt: "",
    images: [
      { src: "/images/lo-studio-panebarcos-01.jpg", alt: "" },
      { src: "/images/lo-studio-panebarcos-02.jpg", alt: "" },
      { src: "/images/lo-studio-panebarcos-03.jpg", alt: "" },
      { src: "/images/lo-studio-panebarcos-04.jpg", alt: "" },
    ],
  },
  cta: {
    kicker: "",
    title: "",
    body: "",
    imageSrc: "/images/lo-studio-oscar.png",
    imageAlt: "",
    button: {
      label: "",
      href: buildPath("studioOscars", lang),
    },
  },
  seo: {
    title: "",
    description: "",
  },
};
const studioContent = await getStudioPageContent({ lang, fallback: studioFallback });
const protagonistImages = studioContent.protagonists.images;
const protagonistFirstImage = protagonistImages[0] || studioFallback.protagonists.images[0];
---

<Layout
  title={studioContent.seo.title}
  description={studioContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-studio"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
    <main class="studio-page">
      <!-- Hero dello Studio (componentizzata) -->
      <HeroStyStudio
        backgroundVideoSrc={studioContent.header.backgroundVideoSrc}
        bgWord={studioContent.header.bgWord}
        title={studioContent.header.title}
        showSideImage={studioContent.header.showSideImage}
        subtitle={studioContent.header.subtitle}
        sideImageSrc={studioContent.header.sideImageSrc}
        sideImageAlt={studioContent.header.sideImageAlt}
      />
  
      <!-- Blocco storia introduttivo -->
      <section class="page-main page-main--studio">
        <div class="container">
          <div class="row g-4 g-xl-5 align-items-end studio-story">
            <div class="col-12 col-lg-7 studio-story-copy">
              <h2 class="page-title-uniform">{studioContent.intro.title}</h2>
              <RitchText block={studioContent.intro.content} className="studio-intro-richtext" />
              <a class="btn btn-cta btn-cta--blue btn-pill mt-3" href={studioContent.intro.button.href}>
                {studioContent.intro.button.label}
              </a>
            </div>
            <div class="col-12 col-lg-5 studio-story-art text-lg-end">
              <img class="studio-story-intro-img img-fluid d-block ms-lg-auto" src={studioContent.intro.mediaSrc} alt={studioContent.intro.mediaAlt}>
            </div>
          </div>
        </div>
      </section>

      <!-- Timeline/slider storia azienda -->
      <section class="studio-timeline section-space" hidden>
        <div class="container">
          <h2 class="studio-timeline-title page-title-uniform" id="studioTimelineTitle">Questa è la storia di un’azienda mutante</h2>
          <div class="studio-timeline-track" data-studio-timeline>
            <button
              class="studio-timeline-arrow studio-timeline-arrow--prev"
              type="button"
              aria-label="Anno precedente"
              data-timeline-prev
            >
              <img src="/images/freccia-sinistra.png" alt="" aria-hidden="true">
            </button>

            <div class="studio-timeline-viewport" id="studioTimelineViewport" aria-labelledby="studioTimelineTitle">
              <div class="studio-timeline-slides">
                <article class="studio-timeline-card is-active">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 1976">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Gli inizi</h3>
                    </div>
                  </div>
                </article>

                <article class="studio-timeline-card">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 1989">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Crescita creativa</h3>
                    </div>
                  </div>
                </article>

                <article class="studio-timeline-card">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 2003">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Nuove produzioni</h3>
                    </div>
                  </div>
                </article>

                <article class="studio-timeline-card">
                  <div class="row g-3 g-lg-4 align-items-center">
                    <div class="col-12 col-md-6 studio-timeline-year">
                      <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 2024">
                    </div>
                    <div class="col-12 col-md-6 studio-timeline-copy">
                      <h3>Nuove mutazioni</h3>
                    </div>
                  </div>
                </article>
              </div>
            </div>

            <button
              class="studio-timeline-arrow studio-timeline-arrow--next"
              type="button"
              aria-label="Anno successivo"
              data-timeline-next
            >
              <img src="/images/freccia-destra.png" alt="" aria-hidden="true">
            </button>
          </div>

          <div class="studio-timeline-dots" role="tablist" aria-label="Seleziona una fase della storia">
            <button class="studio-timeline-dot is-active" type="button" aria-label="Vai al 1976" data-timeline-dot="0"></button>
            <button class="studio-timeline-dot" type="button" aria-label="Vai al 1989" data-timeline-dot="1"></button>
            <button class="studio-timeline-dot" type="button" aria-label="Vai al 2003" data-timeline-dot="2"></button>
            <button class="studio-timeline-dot" type="button" aria-label="Vai al 2024" data-timeline-dot="3"></button>
          </div>
        </div>
      </section>

      <section class="studio-panebarcos-intro section-space section-space--soft">
        <div class="container">
          <div class="row justify-content-center">
            <div class="col-12 col-xl-10 studio-panebarcos-intro-inner text-start text-md-center">
              <h2 class="page-title-uniform" hidden>{studioContent.protagonists.title}</h2>
              <RitchText block={studioContent.protagonists.content} className="studio-panebarcos-richtext" />
            </div>
          </div>
        </div>
      </section>

      <section class="studio-panebarcos-photo py-0" aria-label="Il team Panebarcos" hidden>
        <div class="container-fluid px-0 position-relative">
          <img
            id="studioPanebarcosImage"
            class="img-fluid d-block w-100"
            src={protagonistFirstImage.src}
            alt={protagonistFirstImage.alt}
            data-studio-panebarcos-image
            data-studio-panebarcos-images={JSON.stringify(protagonistImages)}
          >
          <button
            class="studio-panebarcos-trigger position-absolute d-block m-2 m-md-4"
            type="button"
            aria-label="Mostra la foto successiva dei Panebarcos"
            aria-controls="studioPanebarcosImage"
            data-studio-panebarcos-trigger
            style="top:0; right:0; width:clamp(7rem, 22vw, 20rem); z-index:2;"
          >
            <img
              class="img-fluid d-block w-100"
              src="/images/studio-make-magic-happen.png"
              alt=""
              aria-hidden="true"
            >
          </button>
        </div>
      </section>

      <OscarCtaSection
        heading={studioContent.cta.kicker}
        highlight={studioContent.cta.title}
        body={studioContent.cta.body}
        href={studioContent.cta.button.href}
        buttonLabel={studioContent.cta.button.label}
        imageSrc={studioContent.cta.imageSrc}
        imageAlt={studioContent.cta.imageAlt}
      />
    </main>
    <script type="module" src={studioPageScriptUrl}></script>
</Layout>

<style>
  :global(.studio-intro-richtext) {
    color: inherit;
  }

  :global(.studio-intro-richtext h1),
  :global(.studio-intro-richtext h2),
  :global(.studio-intro-richtext h3),
  :global(.studio-intro-richtext h4),
  :global(.studio-intro-richtext h5),
  :global(.studio-intro-richtext h6) {
    color: inherit;
  }

  :global(.studio-panebarcos-richtext) {
    color: inherit;
  }

  :global(.studio-panebarcos-richtext h1),
  :global(.studio-panebarcos-richtext h2),
  :global(.studio-panebarcos-richtext h3),
  :global(.studio-panebarcos-richtext h4),
  :global(.studio-panebarcos-richtext h5),
  :global(.studio-panebarcos-richtext h6) {
    color: inherit;
  }
</style>
