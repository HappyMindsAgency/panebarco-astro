---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import OscarCtaSection from "../../components/OscarCtaSection.astro";
import RitchText from "../../components/RitchText.astro";
import studioPageScriptUrl from "../../scripts/pages/studio.js?url";
import { getLangFromPath } from "../../i18n/routing";
import { getPanebarcosPageContent } from "../../lib/site-content";
import type { ContactBannerContent, PanebarcosPageContent } from "../../lib/site-content.types";

const lang = getLangFromPath(Astro.url.pathname);
const panebarcosFallback = {
  header: {
    backgroundVideoSrc: "/images/1021768637.mp4",
  },
  intro: {
    mediaSrc: "/images/lo-studio-panebarco-teams.png",
    mediaAlt: "I Panebarcos",
  },
  team: {},
  cta: {
    imageSrc: "/images/lo-studio-oscar.png",
    imageAlt: "Personaggi con Oscar",
  },
  seo: {
    title: "I Panebarcos - Panebarco",
    description: "I Panebarcos - Panebarco",
  },
};

function hasPanebarcosCta(
  cta: PanebarcosPageContent["cta"]
): cta is ContactBannerContent & { button: { label: string; href: string } } {
  return Boolean(cta?.button?.label && cta?.button?.href && (cta.kicker || cta.title));
}

const panebarcosContent: PanebarcosPageContent = await getPanebarcosPageContent({ lang, fallback: panebarcosFallback });
const hasIntro = Boolean(
  panebarcosContent.intro.title ||
  panebarcosContent.intro.content ||
  panebarcosContent.intro.mediaSrc
);
const hasSections = panebarcosContent.sections.length > 0;
const panebarcosCta = hasPanebarcosCta(panebarcosContent.cta) ? panebarcosContent.cta : null;
---

<Layout
  title={panebarcosContent.seo.title}
  description={panebarcosContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-panebarcos"
  headerProps={{ containerClass: "hero-fluid" }}
>
  <main class="studio-page studio-team-page">
    <HeroStyStudio
      backgroundVideoSrc={panebarcosContent.header.backgroundVideoSrc}
      bgWord={panebarcosContent.header.bgWord}
      title={panebarcosContent.header.title}
      subtitle={panebarcosContent.header.subtitle}
      showSideImage={false}
      sideImageSrc={panebarcosContent.header.sideImageSrc}
      sideImageAlt={panebarcosContent.header.sideImageAlt}
      className="hero-sty-studio page-hero page-hero--studio"
    />

    {hasIntro && (
      <section class="page-main page-main--studio panebarcos-page-intro">
        <div class="container">
          <div class="row g-4 g-xl-5 align-items-center">
            <div class="col-12 col-xl-7">
              <div class="panebarcos-page-intro__copy studio-story-copy">
                {panebarcosContent.intro.title && <h2 class="page-title-uniform">{panebarcosContent.intro.title}</h2>}
                {panebarcosContent.intro.content && <RitchText block={panebarcosContent.intro.content} className="panebarcos-intro-richtext" />}
              </div>
            </div>
            <div class="col-12 col-xl-5">
              <div class="panebarcos-page-intro__art">
                {panebarcosContent.intro.mediaSrc && (
                  <img class="img-fluid d-block mx-auto" src={panebarcosContent.intro.mediaSrc} alt={panebarcosContent.intro.mediaAlt} />
                )}
              </div>
            </div>
          </div>
        </div>
      </section>
    )}

    {hasSections && (
      <section id="team" class="section-space section-space--soft panebarcos-groups" aria-label="Team Panebarco">
        <div class="container">
          {panebarcosContent.sections.map((section, sectionIndex) => (
            <section class:list={["panebarcos-family-block", sectionIndex > 0 && "mt-5 mt-xl-6"]}>
              <div class="panebarcos-family-block__head">
                {section.title && <h2 class="panebarcos-family-block__title page-title-uniform text-body">{section.title}</h2>}
                {section.subtitle && <p>{section.subtitle}</p>}
              </div>

              {section.content && (
                <div class="panebarcos-network-listing__intro">
                  <RitchText block={section.content} className="panebarcos-group-richtext" />
                </div>
              )}

              {section.members.length > 0 && (
                <div class="row g-4 panebarcos-family-grid">
                  {section.members.map((member, memberIndex) => (
                    <div class="col-12 col-sm-6 col-xl-3">
                      <article
                        class="panebarcos-family-card h-100"
                        data-panebarcos-reveal
                        style={`--panebarcos-reveal-delay:${(sectionIndex * 4 + memberIndex) * 110}ms;`}
                      >
                        {member.imageSrc && (
                          <div class="panebarcos-family-card__media">
                            <img class="img-fluid d-block" src={member.imageSrc} alt={member.imageAlt} />
                          </div>
                        )}
                          <div class="panebarcos-family-card__body">
                            <div class="panebarcos-family-card__head">
                              {member.name && <h3>{member.name}</h3>}
                              {member.linkedin && (
                                <a
                                  class="panebarcos-family-card__linkedin"
                                  href={member.linkedin}
                                  target="_blank"
                                  rel="noopener noreferrer"
                                  aria-label={`LinkedIn di ${member.name || "team member"}`}
                                >
                                  <i class="bi bi-linkedin" aria-hidden="true"></i>
                                </a>
                              )}
                            </div>
                            {member.role && <p class="panebarcos-family-card__role">{member.role}</p>}
                            {member.roleTana && <RitchText block={member.roleTana} className="panebarcos-family-card__role-tana" />}
                            {member.intro && <RitchText block={member.intro} className="panebarcos-family-card__micro" />}
                          </div>
                        </article>
                      </div>
                  ))}
                </div>
              )}
            </section>
          ))}
        </div>
      </section>
    )}

    {panebarcosCta && (
      <OscarCtaSection
        heading={panebarcosCta.kicker}
        highlight={panebarcosCta.title}
        body=""
        href={panebarcosCta.button.href}
        buttonLabel={panebarcosCta.button.label}
        imageSrc={panebarcosCta.imageSrc}
        imageAlt={panebarcosCta.imageAlt}
      />
    )}
  </main>
  <script type="module" src={studioPageScriptUrl}></script>
</Layout>
