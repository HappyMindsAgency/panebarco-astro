---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import RitchText from "../../components/RitchText.astro";
import { getLangFromPath } from "../../i18n/routing";
import { getOscarsPageContent } from "../../lib/site-content";
import type { ContactBannerContent, OscarsPageContent } from "../../lib/site-content.types";

const lang = getLangFromPath(Astro.url.pathname);
const oscarsBeliefsImage = {
  src: "/images/home-team-panebarco.png",
  alt: "Team Panebarco",
};
const oscarsFallback = {
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "/images/1021768637.mp4",
    sideImageSrc: "/images/lo-studio-panebarco-teams.png",
    sideImageAlt: "",
  },
  beliefs: {
    title: "",
    imageSrc: oscarsBeliefsImage.src,
    imageAlt: oscarsBeliefsImage.alt,
    items: [
      { title: "", subtitle: "", theme: "blue", bgColor: "#3394B2" },
      { title: "", subtitle: "", theme: "violet", bgColor: "#995791" },
      { title: "", subtitle: "", theme: "red", bgColor: "#B03D4F" },
      { title: "", subtitle: "", theme: "green", bgColor: "#30997B" },
      { title: "", subtitle: "", theme: "cyan", bgColor: "#3394B2" },
    ],
  },
  dream: {
    imageSrc: "/images/teams-valori.png",
    imageAlt: "",
  },
  workflow: {
    title: "Come ci piace lavorare",
    subtitle: "il tocco Panebarco",
    items: [],
  },
  cta: {
    imageSrc: "/images/cta-ci-vediamo-agli-oscar.png",
    imageAlt: "",
  },
  seo: {
    title: "",
    description: "",
  },
};
function hasOscarsCta(
  cta: OscarsPageContent["cta"]
): cta is ContactBannerContent & { button: { label: string; href: string } } {
  return Boolean(cta?.button?.label && cta?.button?.href && (cta.kicker || cta.title));
}

const oscarsContent: OscarsPageContent = await getOscarsPageContent({ lang, fallback: oscarsFallback });
const hasDreamContent = Boolean(oscarsContent.dream.title || oscarsContent.dream.content);
const hasWorkflow = Array.isArray(oscarsContent.workflow.items) && oscarsContent.workflow.items.length > 0;
const oscarsCta = hasOscarsCta(oscarsContent.cta) ? oscarsContent.cta : null;
const normalizeOscarsStickerText = (value = "") =>
  String(value)
    .trim()
    .toLowerCase()
    .normalize("NFD")
    .replace(/[\u0300-\u036f]/g, "");
const oscarsBeliefItems = oscarsContent.beliefs.items.map((item) => {
  const isBeautyResponsibilitySticker =
    normalizeOscarsStickerText(item.title) === "bellezza" &&
    normalizeOscarsStickerText(item.subtitle) === "come responsabilita";

  return {
    ...item,
    bgColor: isBeautyResponsibilitySticker ? "#009fe3" : item.bgColor,
  };
});
---

<Layout
  title={oscarsContent.seo.title}
  description={oscarsContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-vediamo-oscar"
  headerProps={{ containerClass: "hero-fluid" }}
>
  <main class="studio-page oscars-page">
    <HeroStyStudio
      backgroundVideoSrc={oscarsContent.header.backgroundVideoSrc}
      bgWord={oscarsContent.header.bgWord}
      title={oscarsContent.header.title}
      subtitle={oscarsContent.header.subtitle}
      showSideImage={false}
      sideImageSrc={oscarsContent.header.sideImageSrc}
      sideImageAlt={oscarsContent.header.sideImageAlt}
      className="hero-sty-studio page-hero page-hero--studio"
    />

    <section class="page-main page-main--studio oscars-beliefs" aria-labelledby="oscarsValuesTitle">
      <div class="container" data-oscars-block-reveal style="--oscars-reveal-delay:80ms;">
        <div class="oscars-section-head text-center">
          <h2 id="oscarsValuesTitle" class="page-title-uniform">{oscarsContent.beliefs.title}</h2>
        </div>

        <div class="oscars-beliefs__layout">
          <div class="oscars-beliefs__art">
            <img
              class="img-fluid d-block mx-auto"
              src={oscarsBeliefsImage.src}
              alt={oscarsBeliefsImage.alt}
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="oscars-beliefs__stickers" aria-label={oscarsContent.beliefs.title}>
            {oscarsBeliefItems.map((item) => (
              <div class:list={["oscars-belief-sticker", `oscars-belief-sticker--${item.theme}`]} style={item.bgColor ? `background:${item.bgColor};` : undefined}>
                <span class="oscars-belief-sticker__title">{item.title}</span>
                <span class="oscars-belief-sticker__subtitle">{item.subtitle}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    {hasDreamContent && (
      <section class="section-space oscars-dream" aria-labelledby="oscarsDreamTitle">
        <div class="container">
          <div class="oscars-dream-card" data-oscars-block-reveal style="--oscars-reveal-delay:120ms;">
            <h2 id="oscarsDreamTitle" class="page-title-uniform oscars-dream-card__title">{oscarsContent.dream.title}</h2>
            <div class="oscars-dream-card__body">
              <RitchText block={oscarsContent.dream.content} className="oscars-dream-richtext" />
            </div>
            <div class="oscars-dream-card__art">
              <img
                class="img-fluid d-block w-100"
                src={oscarsContent.dream.imageSrc}
                alt={oscarsContent.dream.imageAlt}
                loading="lazy"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </section>
    )}

    {hasWorkflow && (
      <section class="section-space section-space--soft oscars-work" aria-labelledby="oscarsWorkTitle">
        <div class="container" data-oscars-block-reveal style="--oscars-reveal-delay:140ms;">
          <div class="oscars-section-head text-center">
            <h2 id="oscarsWorkTitle" class="page-title-uniform">{oscarsContent.workflow.title}</h2>
            <p class="oscars-work__subtitle">{oscarsContent.workflow.subtitle}</p>
          </div>
          <div class="oscars-work__stack">
            {oscarsContent.workflow.items.map((area) => (
              <article class="oscars-work-card">
                <span class="oscars-work-card__badge" aria-hidden="true">{area.kicker}</span>
                <div class="oscars-work-card__body py-4 py-lg-4">
                  <span class="oscars-work-card__kicker">{area.kicker}</span>
                  <h3>{area.title}</h3>
                  <RitchText block={area.content} className="oscars-work-richtext" />
                </div>
              </article>
            ))}
          </div>
        </div>
      </section>
    )}

    {oscarsCta && (
      <div class="container pt-md-5 mt-5 mb-5">
        <section class="extras-newsletter-card" style={oscarsCta.background ? `background:${oscarsCta.background};` : undefined}>
          <div class="extras-newsletter-card__copy">
            <p class="extras-newsletter-card__kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">{oscarsCta.kicker}</p>
            <h2 class="extras-newsletter-card__title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">
              {oscarsCta.title}
            </h2>
            {oscarsCta.button.href && oscarsCta.button.label && (
              <a class="btn btn-cta btn-cta--orange btn-pill" href={oscarsCta.button.href}>{oscarsCta.button.label}</a>
            )}
          </div>
          {oscarsCta.imageSrc && (
            <img
              class="extras-newsletter-card__figure"
              src={oscarsCta.imageSrc}
              alt={oscarsCta.imageAlt}
              loading="lazy"
              decoding="async"
            />
          )}
        </section>
      </div>
    )}
  </main>

  <script is:inline>
    (function () {
      var cleanupOscarsPage = window.__cleanupOscarsPage || function () {};

      function setupOscarsTyping(cleanups) {
        var typingText = document.getElementById("oscars-belief-typing");
        if (!typingText) return;

        var words = (typingText.getAttribute("data-words") || "")
          .split("|")
          .map(function (word) {
            return word.trim();
          })
          .filter(Boolean);

        if (!words.length) return;

        var wordIndex = 0;
        var charIndex = 0;
        var isDeleting = false;
        var currentColor = "#009FE3";
        var timeoutId = null;
        var disposed = false;
        var palette = ["#009FE3", "#B03D4F", "#995791", "#3394B2", "#30997B"];
        var typingSpeed = 90;
        var deletingSpeed = 55;
        var wordPause = 1200;
        var restartPause = 350;

        function queue(nextStep, delay) {
          timeoutId = window.setTimeout(nextStep, delay);
        }

        function animateTyping() {
          if (disposed) return;

          var currentWord = words[wordIndex];

          if (!isDeleting) {
            if (charIndex === 0) {
              currentColor = palette[Math.floor(Math.random() * palette.length)];
              typingText.style.color = currentColor;
            }

            charIndex += 1;
            typingText.textContent = currentWord.slice(0, charIndex).toUpperCase();

            if (charIndex === currentWord.length) {
              isDeleting = true;
              queue(animateTyping, wordPause);
              return;
            }

            queue(animateTyping, typingSpeed);
            return;
          }

          charIndex -= 1;
          typingText.textContent = currentWord.slice(0, Math.max(0, charIndex)).toUpperCase();

          if (charIndex === 0) {
            isDeleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            queue(animateTyping, restartPause);
            return;
          }

          queue(animateTyping, deletingSpeed);
        }

        typingText.textContent = "";
        queue(animateTyping, 500);

        cleanups.push(function () {
          disposed = true;
          if (timeoutId !== null) {
            window.clearTimeout(timeoutId);
          }
        });
      }

      function setupOscarsBlockReveal(cleanups) {
        var blocks = document.querySelectorAll("[data-oscars-block-reveal]");
        if (!blocks.length) return;

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          blocks.forEach(function (block) {
            block.classList.add("is-in-view");
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              entry.target.classList.toggle("is-in-view", entry.isIntersecting);
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -10% 0px",
          }
        );

        blocks.forEach(function (block) {
          observer.observe(block);
        });

        cleanups.push(function () {
          observer.disconnect();
        });
      }

      function initOscarsPage() {
        cleanupOscarsPage();

        var cleanups = [];
        setupOscarsTyping(cleanups);
        setupOscarsBlockReveal(cleanups);

        cleanupOscarsPage = function () {
          cleanups.forEach(function (dispose) {
            dispose();
          });
        };

        window.__cleanupOscarsPage = cleanupOscarsPage;
      }

      if (!window.__oscarsPageBound) {
        document.addEventListener("astro:before-swap", function () {
          cleanupOscarsPage();
        });

        document.addEventListener("astro:page-load", initOscarsPage);
        window.__oscarsPageBound = true;
      }

      initOscarsPage();
    })();
  </script>
</Layout>

<style>
  :global(.oscars-dream-richtext),
  :global(.oscars-work-richtext) {
    color: inherit;
  }

  :global(.oscars-dream-richtext > :first-child),
  :global(.oscars-work-richtext > :first-child) {
    margin-top: 0;
  }

  :global(.oscars-dream-richtext p),
  :global(.oscars-work-richtext p) {
    margin-bottom: 1rem;
  }
</style>
