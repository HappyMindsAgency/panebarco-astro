---
import Layout from "../layouts/Layout.astro";
import { buildPath } from "../i18n/routing";

const lang = "it" as const;
const homeHref = buildPath("home", lang);
const contactsHref = buildPath("contacts", lang);
---

<Layout
  title="404 - Pagina non trovata | Panebarco"
  description="La pagina che stai cercando non esiste o si è spostata."
  lang={lang}
  useInnerStyles={true}
  headerProps={{ darkmode: false, containerClass: "hero-fluid" }}
>
  <main class="error-404-page">
    <section class="error-404-section section-space" aria-labelledby="error404Title">
      <div class="container">
        <div class="error-404-card row g-0 align-items-center">
          <div class="col-12 col-lg-6 order-2 order-lg-1">
            <figure class="error-404-visual mb-0">
              <img
                src="/images/pigeon-1-pagina-404.png"
                alt="Piccione Panebarco"
                loading="eager"
                decoding="async"
              />
            </figure>
          </div>

          <div class="col-12 col-lg-6 order-1 order-lg-2">
            <div class="error-404-copy text-center text-lg-start">
              <p class="error-404-kicker">Errore di rotta</p>
              <h1 id="error404Title">Oops! 404</h1>
              <p class="error-404-lead">
                La pagina che stai cercando non &egrave; stata trovata. Potrebbe essere stata spostata
                oppure il link non essere pi&ugrave; valido.
              </p>

              <div class="error-404-actions justify-content-center justify-content-lg-start">
                <a href={homeHref} class="btn btn-cta btn-cta--blue btn-pill">Torna alla home</a>
                <a href={contactsHref} class="btn btn-cta btn-cta--orange btn-pill">Contattaci</a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .error-404-page {
    min-height: 100svh;
    display: flex;
  }

  .error-404-section {
    flex: 1;
    display: grid;
    align-items: center;
    padding-top: clamp(6.5rem, 10vw, 8rem);
    padding-bottom: clamp(3rem, 7vw, 5rem);
  }

  .error-404-card {
    background: rgba(255, 255, 255, 0.94);
    border-radius: clamp(1.75rem, 3vw, 2.5rem);
    box-shadow:
      0 1rem 2.5rem rgba(15, 23, 42, 0.08),
      inset 0 0 0 1px rgba(15, 23, 42, 0.05);
    overflow: hidden;
  }

  .error-404-visual {
    min-height: clamp(20rem, 34vw, 34rem);
    display: flex;
    align-items: end;
    justify-content: center;
    padding:
      clamp(1.5rem, 3vw, 2.75rem)
      clamp(1rem, 2.5vw, 2rem)
      0;
  }

  .error-404-visual img {
    display: block;
    width: min(100%, clamp(18rem, 35vw, 34rem));
    height: auto;
    object-fit: contain;
  }

  .error-404-copy {
    position: relative;
    z-index: 1;
    padding:
      clamp(2rem, 4vw, 4rem)
      clamp(1.5rem, 4vw, 4rem)
      clamp(2rem, 4vw, 4rem);
  }

  .error-404-kicker {
    margin: 0 0 0.9rem;
    color: rgba(var(--bs-primary-rgb), 0.92);
    font-size: 0.82rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .error-404-lead {
    margin: 1.4rem 0 0;
    font-size: clamp(1rem, 0.94rem + 0.45vw, 1.25rem);
    line-height: 1.65;
  }

  .error-404-actions {
    position: relative;
    z-index: 2;
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    margin-top: 2rem;
  }

  @media (max-width: 991.98px) {
    .error-404-card {
      max-width: 46rem;
      margin-inline: auto;
    }

    .error-404-visual {
      min-height: auto;
      padding-bottom: 0;
    }

    .error-404-visual img {
      width: min(100%, 28rem);
    }

    .error-404-lead {
      margin-inline: auto;
    }
  }

  @media (max-width: 575.98px) {
    .error-404-section {
      padding-top: 5.8rem;
    }

    .error-404-actions {
      display: grid;
      grid-template-columns: minmax(0, 1fr);
    }

    .error-404-actions .btn {
      width: 100%;
    }
  }
</style>
