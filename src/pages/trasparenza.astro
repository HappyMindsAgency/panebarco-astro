        <script>
          (function () {
            const table = document.getElementById('trasparenza-table') as HTMLTableElement | null;
            if (!table) return;

            const headers = table.querySelectorAll<HTMLElement>('th.sortable');
            let currentCol: number | null = null;
            let ascending = true;

            function parseValue(td: HTMLElement, type: string): number | string {
              const text = (td.textContent ?? '').trim();
              if (type === 'date') {
                const [d, m, y] = text.split('/');
                return new Date(+y, +m - 1, +d).getTime();
              }
              if (type === 'euro') {
                return parseFloat(text.replace(/[€\s.]/g, '').replace(',', '.')) || 0;
              }
              return text.toLowerCase();
            }

            headers.forEach(th => {
              th.style.cursor = 'pointer';
              th.addEventListener('click', () => {
                const col = +(th as HTMLElement).dataset.col!;
                const type = (th as HTMLElement).dataset.type!;
                if (currentCol === col) {
                  ascending = !ascending;
                } else {
                  currentCol = col;
                  ascending = true;
                }

                headers.forEach(h => {
                  const icon = h.querySelector('.sort-icon');
                  if (icon) icon.textContent = '↕';
                  h.classList.remove('sort-asc', 'sort-desc');
                });
                const thIcon = th.querySelector('.sort-icon');
                if (thIcon) thIcon.textContent = ascending ? '↑' : '↓';
                th.classList.add(ascending ? 'sort-asc' : 'sort-desc');

                const tbody = table.querySelector('tbody');
                if (!tbody) return;
                const rows = Array.from(tbody.querySelectorAll<HTMLTableRowElement>('tr'));
                rows.sort((a, b) => {
                  const aVal = parseValue(a.querySelectorAll('td')[col] as HTMLElement, type);
                  const bVal = parseValue(b.querySelectorAll('td')[col] as HTMLElement, type);
                  if (aVal < bVal) return ascending ? -1 : 1;
                  if (aVal > bVal) return ascending ? 1 : -1;
                  return 0;
                });
                rows.forEach(r => tbody.appendChild(r));
              });
            });
          })();
        </script>
      </section>
