</Layout>

<style>
  .legal-page-title {
    margin-top: 0;
    color: #21262e;
    font-family: "Sofia Sans", sans-serif;
    font-size: clamp(3.4rem, 8vw, 6.2rem);
    font-weight: 900;
    line-height: 0.92;
    letter-spacing: -0.04em;
  }

  @media (max-width: 767.98px) {
    .legal-page-title {
      font-size: clamp(2.8rem, 12vw, 4.2rem);
    }
  }

  .legal-page-content :global(h2) {
    font-size: clamp(1.5rem, 2.6vw, 2rem);
    line-height: 1.08;
    margin: 2rem 0 1rem;
  }

  .legal-page-content :global(h3) {
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    line-height: 1.15;
    margin: 1.6rem 0 0.85rem;
  }

  /* Table */
  .table-responsive-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
  }

  .trasparenza-table-wrap {
    margin: 0;
    padding: 0;
  }

  .trasparenza-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.78rem;
    line-height: 1.4;
    color: #21262e;
    background: #fff;
  }

  .trasparenza-table thead tr {
    background: #21262e;
    color: #fff;
  }

  .trasparenza-table thead th {
    padding: 0.75rem 0.9rem;
    text-align: left;
    font-weight: 700;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    white-space: nowrap;
    border: none;
  }

  .trasparenza-table tbody tr:nth-child(odd) {
    background: #f6f7f8;
  }

  .trasparenza-table tbody tr:nth-child(even) {
    background: #fff;
  }

  .trasparenza-table tbody tr:hover {
    background: #eaf0f8;
  }

  .trasparenza-table tbody td {
    padding: 0.6rem 0.9rem;
    border-bottom: 1px solid #e2e6ea;
    vertical-align: top;
    min-width: 90px;
  }

  .trasparenza-table tbody td:last-child {
    font-weight: 700;
    white-space: nowrap;
  }

  .trasparenza-table tbody td:first-child {
    white-space: nowrap;
    font-weight: 600;
    color: #555;
  }

  /* Last column (Elemento Aiuto) align right */
  .trasparenza-table thead th:last-child,
  .trasparenza-table tbody td:last-child {
    text-align: right;
  }

  .legal-page-content :global(h4),
  .legal-page-content :global(h5),
  .legal-page-content :global(h6) {
    font-size: 1.05rem;
    line-height: 1.2;
    margin: 1.35rem 0 0.75rem;
  }
</style>
