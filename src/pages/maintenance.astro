---
import Layout from "../layouts/Layout.astro";

const lang = "it" as const;
---

<Layout
  title="Sito in manutenzione | Panebarco"
  description="Stiamo effettuando un aggiornamento del sito Panebarco. Torna a trovarci a breve."
  lang={lang}
  showHeader={false}
  showFooter={false}
>
  <main class="maintenance-page">
    <section class="maintenance-hero">
      <div class="maintenance-hero__noise" aria-hidden="true"></div>
      <div class="container maintenance-shell">
        <div class="maintenance-copy">
          <img
            class="maintenance-logo"
            src="/images/panebarco-logo-dark.png"
            alt="Panebarco"
            loading="eager"
            decoding="async"
          />
          <p class="maintenance-kicker">stiamo sistemando il set</p>
          <h1 class="maintenance-title">
            <span class="maintenance-title__overline">Modalita</span>
            <span class="maintenance-title__main">Manutenzione</span>
          </h1>
          <p class="maintenance-lead">
            Il sito e momentaneamente offline per alcuni aggiornamenti tecnici.
            Torniamo online il prima possibile, senza lasciare cavi in mezzo al palco.
          </p>
          <p class="maintenance-note">
            Se devi accedere durante i lavori, usa il link di bypass previsto dal middleware.
          </p>
        </div>

        <div class="maintenance-visual" aria-hidden="true">
          <div class="maintenance-orb maintenance-orb--blue"></div>
          <div class="maintenance-orb maintenance-orb--yellow"></div>
          <div class="maintenance-card">
            <div class="maintenance-card__top">
              <span></span>
              <span></span>
              <span></span>
            </div>
            <div class="maintenance-card__body">
              <div class="maintenance-card__line maintenance-card__line--lg"></div>
              <div class="maintenance-card__line maintenance-card__line--md"></div>
              <div class="maintenance-card__line maintenance-card__line--sm"></div>
            </div>
          </div>
          <div class="maintenance-sticker">back soon</div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .maintenance-page {
    min-height: 100vh;
    background:
      radial-gradient(circle at 15% 20%, rgba(0, 159, 227, 0.26), transparent 24%),
      radial-gradient(circle at 82% 18%, rgba(243, 171, 40, 0.2), transparent 18%),
      linear-gradient(145deg, #f6f1e8 0%, #fbf7ef 38%, #efe6d7 100%);
    color: #111;
  }

  .maintenance-hero {
    position: relative;
    overflow: clip;
    min-height: 100vh;
    display: grid;
    align-items: center;
    padding: clamp(3rem, 7vw, 5rem) 0;
  }

  .maintenance-hero__noise {
    position: absolute;
    inset: 0;
    opacity: 0.28;
    background-image:
      linear-gradient(rgba(17, 17, 17, 0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(17, 17, 17, 0.025) 1px, transparent 1px);
    background-size: 22px 22px;
    pointer-events: none;
  }

  .maintenance-shell {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: minmax(0, 1.05fr) minmax(18rem, 0.95fr);
    gap: clamp(2rem, 5vw, 5rem);
    align-items: center;
  }

  .maintenance-copy {
    max-width: 42rem;
  }

  .maintenance-logo {
    display: block;
    width: clamp(9rem, 18vw, 13rem);
    height: auto;
    margin: 0 0 1.5rem;
  }

  .maintenance-kicker {
    display: inline-block;
    margin: 0 0 1rem;
    padding: 0.55rem 0.95rem 0.65rem;
    border: 2px solid #111;
    border-radius: 999px;
    background: #f3ab28;
    font-family: "Margarine", "Sofia Sans", sans-serif;
    font-size: 1rem;
    line-height: 1;
    transform: rotate(-3deg);
  }

  .maintenance-title {
    display: grid;
    gap: 0.15rem;
    margin: 0;
    text-transform: uppercase;
  }

  .maintenance-title__overline {
    font-family: "Nunito", sans-serif;
    font-size: clamp(3.6rem, 10vw, 7rem);
    line-height: 0.86;
    color: rgba(17, 17, 17, 0.18);
  }

  .maintenance-title__main {
    font-family: "Sofia Sans Semi Condensed", "Sofia Sans", sans-serif;
    font-size: clamp(3rem, 7vw, 6rem);
    line-height: 0.9;
    font-weight: 900;
    max-width: 8ch;
  }

  .maintenance-lead,
  .maintenance-note {
    font-family: "Plus Jakarta Sans", sans-serif;
    line-height: 1.65;
  }

  .maintenance-lead {
    margin: 1.5rem 0 0;
    font-size: clamp(1.05rem, 1rem + 0.55vw, 1.35rem);
    max-width: 34rem;
  }

  .maintenance-note {
    margin: 1rem 0 0;
    font-size: 0.98rem;
    max-width: 32rem;
    color: rgba(17, 17, 17, 0.72);
  }

  .maintenance-visual {
    position: relative;
    min-height: clamp(20rem, 42vw, 32rem);
  }

  .maintenance-orb {
    position: absolute;
    border-radius: 999px;
    filter: blur(1px);
  }

  .maintenance-orb--blue {
    width: clamp(9rem, 24vw, 15rem);
    aspect-ratio: 1;
    top: 0.5rem;
    right: 0;
    background: rgba(0, 159, 227, 0.22);
  }

  .maintenance-orb--yellow {
    width: clamp(7rem, 18vw, 11rem);
    aspect-ratio: 1;
    left: 0.5rem;
    bottom: 1.4rem;
    background: rgba(243, 171, 40, 0.28);
  }

  .maintenance-card {
    position: absolute;
    inset: auto 1.2rem 1.2rem 2.6rem;
    overflow: hidden;
    border: 2px solid rgba(17, 17, 17, 0.1);
    border-radius: 2rem;
    background: rgba(255, 255, 255, 0.72);
    backdrop-filter: blur(18px);
    box-shadow: 0 1.5rem 3rem rgba(17, 17, 17, 0.14);
    transform: rotate(-5deg);
  }

  .maintenance-card__top {
    display: flex;
    gap: 0.5rem;
    padding: 1rem 1.2rem 0;
  }

  .maintenance-card__top span {
    width: 0.8rem;
    height: 0.8rem;
    border-radius: 999px;
    background: rgba(17, 17, 17, 0.2);
  }

  .maintenance-card__body {
    display: grid;
    gap: 1rem;
    padding: 1.4rem 1.2rem 1.6rem;
  }

  .maintenance-card__line {
    height: 1rem;
    border-radius: 999px;
    background: linear-gradient(90deg, rgba(17, 17, 17, 0.14), rgba(17, 17, 17, 0.06));
  }

  .maintenance-card__line--lg {
    width: 82%;
  }

  .maintenance-card__line--md {
    width: 68%;
  }

  .maintenance-card__line--sm {
    width: 44%;
  }

  .maintenance-sticker {
    position: absolute;
    top: 1.5rem;
    left: 0;
    padding: 0.8rem 1rem 0.9rem;
    border-radius: 999px;
    background: #111;
    color: #f6f1e8;
    font-family: "Margarine", "Sofia Sans", sans-serif;
    font-size: clamp(1rem, 1.2vw + 0.8rem, 1.4rem);
    line-height: 1;
    transform: rotate(-10deg);
    box-shadow: 0 1rem 1.8rem rgba(17, 17, 17, 0.16);
  }

  @media (max-width: 991.98px) {
    .maintenance-shell {
      grid-template-columns: 1fr;
    }

    .maintenance-visual {
      width: 100%;
      max-width: 34rem;
      margin-inline: auto;
    }
  }

  @media (max-width: 639.98px) {
    .maintenance-title__main {
      max-width: 7ch;
    }

    .maintenance-visual {
      min-height: 17rem;
    }

    .maintenance-card {
      inset: auto 0.5rem 0.8rem 1.4rem;
      border-radius: 1.5rem;
    }

    .maintenance-sticker {
      top: 0.35rem;
      left: 0.4rem;
    }
  }
</style>
