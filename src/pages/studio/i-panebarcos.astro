const content = pageContent[lang];
const duplicatedFamilyMembers = [...content.familyMembers, ...content.familyMembers];
---

<Layout
  title="I Panebarcos - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "hero-fluid" }}
>
  <main class="studio-page studio-team-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/1021768637.mp4"
      bgWord="LA FAMIGLIA"
      title="I PANEBARCOS"
      subtitle={content.heroSubtitle}
      showSideImage={false}
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
      className="hero-sty-studio page-hero page-hero--studio"
    />

    <section class="page-main page-main--studio panebarcos-page-intro">
      <div class="container">
        <div class="row g-4 g-xl-5 align-items-center">
          <div class="col-12 col-xl-7">
            <div class="panebarcos-page-intro__copy studio-story-copy">
              <h2 class="page-title-uniform">{content.introTitle}</h2>
              {content.introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
          <div class="col-12 col-xl-5">
            <div class="panebarcos-page-intro__art">
              <img class="img-fluid d-block mx-auto" src="/images/lo-studio-panebarco-teams.png" alt="I Panebarcos" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft panebarcos-groups" aria-label="Team e network Panebarco">
      <div class="container">
        <div class="panebarcos-family-block">
          <h2 class="panebarcos-family-block__title page-title-uniform text-body">Il team</h2>

          <div class="row g-4 panebarcos-family-grid">
            {duplicatedFamilyMembers.map((member, index) => (
              <div class="col-12 col-sm-6 col-xl-3">
                <article
                  class="panebarcos-family-card h-100"
                  data-panebarcos-reveal
                  style={`--panebarcos-reveal-delay:${index * 110}ms;`}
                >
                  <div class="panebarcos-family-card__media">
                    <img class="img-fluid d-block" src={member.photo} alt="" aria-hidden="true" />
                  </div>
                  <div class="panebarcos-family-card__body">
                    <span class="panebarcos-family-card__avatar" aria-hidden="true">
                      <img src={member.avatar} alt="" />
                    </span>
                    <h3>{member.name}</h3>
                    <p>{member.role}</p>
                  </div>
                </article>
              </div>
            ))}
          </div>
        </div>

        <section class="panebarcos-network-listing mt-5 mt-xl-6" aria-labelledby="panebarcosNetworkListingTitle">
          <div class="panebarcos-network-listing__intro">
            <h2 id="panebarcosNetworkListingTitle" class="page-title-uniform text-body">{content.networkListTitle}</h2>
            <p class="text-body">{content.networkListIntro}</p>
          </div>

          <div class="row g-4 g-xl-4 mt-4 mt-xl-5 panebarcos-network-grid">
            {content.networkMembers.map((member, index) => (
              <div class="col-12 col-sm-6 col-lg-4 col-xl-2">
                <article
                  class="panebarcos-network-person h-100"
                  data-panebarcos-reveal
                  style={`--panebarcos-reveal-delay:${(index + 4) * 85}ms;`}
                >
                  <div class="panebarcos-network-person__media">
                    <img class="img-fluid d-block" src={member.photo} alt="" aria-hidden="true" />
                  </div>
                  <div class="panebarcos-network-person__overlay">
                    <h3>{member.name}</h3>
                    <p>{member.role}</p>
                    <span class="panebarcos-network-person__badge" aria-hidden="true">
                      <i class="bi bi-linkedin"></i>
                    </span>
                  </div>
                </article>
              </div>
            ))}
          </div>
        </section>
      </div>
    </section>

    <OscarCtaSection
      heading="Spoiler sul finale?"
      highlight="CI VEDIAMO AGLI OSCAR"
      body={content.oscarBody}
      href={buildPath("studioOscars", lang)}
      buttonLabel="Ci vediamo agli Oscar"
    />
  </main>

  <script is:inline>
    (function () {
      var cleanupPanebarcosTeam = window.__cleanupPanebarcosTeam || function () {};

      function setupPanebarcosReveal(cleanups) {
        var revealItems = document.querySelectorAll("[data-panebarcos-reveal]");
        if (!revealItems.length) return;

        if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          revealItems.forEach(function (item) {
            item.classList.add("is-in-view");
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              entry.target.classList.toggle("is-in-view", entry.isIntersecting);
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -10% 0px",
          }
        );

        revealItems.forEach(function (item) {
          observer.observe(item);
        });

        cleanups.push(function () {
          observer.disconnect();
        });
      }

      function initPanebarcosTeam() {
        cleanupPanebarcosTeam();

        var cleanups = [];
        setupPanebarcosReveal(cleanups);

        cleanupPanebarcosTeam = function () {
          cleanups.forEach(function (dispose) {
            dispose();
          });
        };

        window.__cleanupPanebarcosTeam = cleanupPanebarcosTeam;
      }

      if (!window.__panebarcosTeamBound) {
        document.addEventListener("astro:before-swap", function () {
          cleanupPanebarcosTeam();
        });

        document.addEventListener("astro:page-load", initPanebarcosTeam);
        window.__panebarcosTeamBound = true;
      }

      initPanebarcosTeam();
    })();
  </script>
</Layout>
