---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import OscarCtaSection from "../../components/OscarCtaSection.astro";
import { buildPath } from "../../i18n/routing";

const lang = "it" as const;

const pageContent = {
  it: {
    heroSubtitle: "Famiglia, bottega e lavoro condiviso",
    introTitle: "Una famiglia creativa, una bottega che lavora insieme",
    introParagraphs: [
      "Panebarco nasce come una storia di famiglia, ma cresce come una bottega aperta: un nucleo stabile che condivide metodo, immaginario e responsabilita, capace di restare compatto anche quando i progetti cambiano forma.",
      "Dentro questo spazio convivono visione autoriale, organizzazione produttiva e un modo molto concreto di lavorare insieme. E intorno alla famiglia si muove una rete di collaboratori, partner e professionisti che nel tempo sono diventati, a loro volta, Panebarcos.",
    ],
    familyTitle: "La famiglia",
    familyBody:
      "Un nucleo creativo che tiene insieme visione, organizzazione e continuita del lavoro. Qui la bottega prende forma ogni giorno, tra affetto, mestiere e responsabilita condivise.",
    familyMembers: [
      {
        name: "Daniele",
        role: "Visione, disegno e immaginari che aprono il gioco.",
        avatar: "/images/avatar-che-fate-00.png",
        sticker: "origine",
      },
      {
        name: "Marianna",
        role: "Produzione, regia e continuita del racconto di famiglia.",
        avatar: "/images/teams-avatar-che-fate-01.png",
        sticker: "ritmo",
      },
      {
        name: "Matteo",
        role: "Sviluppo, coordinamento e sguardo sui formati che cambiano.",
        avatar: "/images/teams-avatar-che-fate-02.png",
        sticker: "energia",
      },
      {
        name: "Camilla",
        role: "Organizzazione, cura e connessioni tra persone e progetti.",
        avatar: "/images/teams-avatar-che-fate-03.png",
        sticker: "cura",
      },
    ],
    networkCard: {
      eyebrow: "NETWORK",
      sticker: "bottega allargata",
      title: "...e tanti altri Panebarcos",
      body:
        "Illustratori, animatori, filmmaker, autori, producer e partner tecnici che entrano nei progetti quando servono competenze precise, energia nuova e sguardi complementari.",
      imageSrc: "/images/panebarcos_skecth-team_light.png",
      imageAlt: "Sketch del network Panebarco",
      items: ["Animazione", "Regia", "Design", "Produzione", "Post", "Storytelling"],
      avatars: ["/images/teams-avatar-che-fate-03.png", "/images/teams-avatar-che-fate-01.png", "/images/teams-avatar-che-fate-02.png"],
    },
    oscarBody:
      "Dietro i progetti ci sono persone, legami e un modo di lavorare che continua a evolversi senza perdere il lato artigianale.",
  },
  en: {
    heroSubtitle: "Family, workshop and shared work",
    introTitle: "A creative family, a workshop built on working together",
    introParagraphs: [
      "Panebarco starts as a family story and grows as an open workshop: a stable core sharing methods, imagination and responsibility, able to stay cohesive even when projects change shape.",
      "Inside this space, authorial vision, production organization and a very practical way of working together coexist. Around the family, a wider network of collaborators and partners has become part of the Panebarcos too.",
    ],
    familyTitle: "The family",
    familyBody:
      "A creative core holding together vision, organization and continuity of the work. This is where the workshop takes shape every day, through affection, craft and shared responsibility.",
    familyMembers: [
      {
        name: "Daniele",
        role: "Vision, drawing and worlds that open the game.",
        avatar: "/images/avatar-che-fate-00.png",
        sticker: "origin",
      },
      {
        name: "Marianna",
        role: "Production, direction and continuity in the family story.",
        avatar: "/images/teams-avatar-che-fate-01.png",
        sticker: "rhythm",
      },
      {
        name: "Matteo",
        role: "Development, coordination and an eye on changing formats.",
        avatar: "/images/teams-avatar-che-fate-02.png",
        sticker: "energy",
      },
      {
        name: "Camilla",
        role: "Organization, care and connections between people and projects.",
        avatar: "/images/teams-avatar-che-fate-03.png",
        sticker: "care",
      },
    ],
    networkCard: {
      eyebrow: "NETWORK",
      sticker: "extended workshop",
      title: "...and many other Panebarcos",
      body:
        "Illustrators, animators, filmmakers, writers, producers and technical partners joining projects whenever specific skills, fresh energy and complementary points of view are needed.",
      imageSrc: "/images/panebarcos_skecth-team_light.png",
      imageAlt: "Panebarco network sketch",
      items: ["Animation", "Direction", "Design", "Production", "Post", "Storytelling"],
      avatars: ["/images/teams-avatar-che-fate-03.png", "/images/teams-avatar-che-fate-01.png", "/images/teams-avatar-che-fate-02.png"],
    },
    oscarBody:
      "Behind the projects there are people, relationships and a way of working that keeps evolving without losing its handmade character.",
  },
} as const;

const content = pageContent[lang];
---

<Layout
  title="I Panebarcos - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "hero-fluid" }}
>
  <main class="studio-page studio-team-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/1021768637.mp4"
      bgWord="LA FAMIGLIA"
      title="I PANEBARCOS"
      subtitle={content.heroSubtitle}
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
      className="hero-sty-studio page-hero page-hero--studio"
    />

    <section class="page-main page-main--studio panebarcos-page-intro">
      <div class="container">
        <div class="row g-4 g-xl-5 align-items-center">
          <div class="col-12 col-xl-7">
            <div class="panebarcos-page-intro__copy studio-story-copy">
              <h2 class="page-title-uniform">{content.introTitle}</h2>
              {content.introParagraphs.map((paragraph) => <p>{paragraph}</p>)}
            </div>
          </div>
          <div class="col-12 col-xl-5">
            <div class="panebarcos-page-intro__art">
              <img class="img-fluid d-block mx-auto" src="/images/lo-studio-panebarco-teams.png" alt="I Panebarcos" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft panebarcos-groups" aria-label="Team e network Panebarco">
      <div class="container">
        <div class="panebarcos-family-block">
          <h2 class="panebarcos-family-block__title" aria-label="Team">
            <span
              id="panebarcos-team-typing"
              class="typing-text"
              data-words="team"
              aria-live="polite"
            ></span>
          </h2>

          <div class="row g-4">
            {content.familyMembers.map((member, index) => (
              <div class="col-12 col-xl-6">
                <article
                  class:list={["panebarcos-member-card", "h-100", index % 2 === 1 && "panebarcos-member-card--alt"]}
                  data-panebarcos-reveal
                  style={`--panebarcos-reveal-delay:${index * 110}ms;`}
                >
                  <span class="panebarcos-member-card__sticker">{member.sticker}</span>
                  <div class="panebarcos-member-card__stage">
                    <img class="img-fluid d-block mx-auto" src={member.avatar} alt="" aria-hidden="true" />
                  </div>
                  <div class="panebarcos-member-card__body">
                    <h3>{member.name}</h3>
                    <p>{member.role}</p>
                  </div>
                </article>
              </div>
            ))}
          </div>
        </div>

        <article
          class="panebarcos-group-card panebarcos-group-card--network panebarcos-network-card mt-4 mt-xl-5"
          data-panebarcos-reveal
          style="--panebarcos-reveal-delay:420ms;"
        >
          <div class="row g-4 g-xl-5 align-items-center">
            <div class="col-12 col-lg-7">
              <div class="panebarcos-group-card__body panebarcos-network-card__body">
                <div class="panebarcos-group-card__header">
                  <p class="panebarcos-group-card__eyebrow">{content.networkCard.eyebrow}</p>
                  <span class="panebarcos-group-card__sticker">{content.networkCard.sticker}</span>
                </div>
                <h3>{content.networkCard.title}</h3>
                <p>{content.networkCard.body}</p>
                <ul class="panebarcos-group-card__tags" aria-label={content.networkCard.eyebrow}>
                  {content.networkCard.items.map((item) => (
                    <li>{item}</li>
                  ))}
                </ul>
              </div>
            </div>
            <div class="col-12 col-lg-5">
              <div class="panebarcos-group-card__stage panebarcos-network-card__stage">
                <div class="panebarcos-group-card__avatars" aria-hidden="true">
                  {content.networkCard.avatars.map((avatar) => (
                    <span class="panebarcos-group-card__avatar">
                      <img src={avatar} alt="" />
                    </span>
                  ))}
                </div>
                <img class="img-fluid d-block mx-auto" src={content.networkCard.imageSrc} alt={content.networkCard.imageAlt} />
              </div>
            </div>
          </div>
        </article>
      </div>
    </section>

    <OscarCtaSection
      heading="Spoiler sul finale?"
      highlight="CI VEDIAMO AGLI OSCAR"
      body={content.oscarBody}
      href={buildPath("studioOscars", lang)}
      buttonLabel="Ci vediamo agli Oscar"
    />
  </main>

  <script is:inline>
    (function () {
      var cleanupPanebarcosTeam = window.__cleanupPanebarcosTeam || function () {};

      function setupPanebarcosTeamTyping(cleanups) {
        var typingText = document.getElementById("panebarcos-team-typing");
        if (!typingText) return;

        var words = (typingText.getAttribute("data-words") || "")
          .split("|")
          .map(function (word) {
            return word.trim();
          })
          .filter(Boolean);

        if (!words.length) return;

        var wordIndex = 0;
        var charIndex = 0;
        var isDeleting = false;
        var currentColor = "#009FE3";
        var timeoutId = null;
        var disposed = false;
        var palette = ["#009FE3", "#B03D4F", "#995791", "#3394B2", "#30997B"];
        var typingSpeed = 90;
        var deletingSpeed = 55;
        var wordPause = 1200;
        var restartPause = 350;

        function queue(nextStep, delay) {
          timeoutId = window.setTimeout(nextStep, delay);
        }

        function animateTyping() {
          if (disposed) return;

          var currentWord = words[wordIndex];

          if (!isDeleting) {
            if (charIndex === 0) {
              currentColor = palette[Math.floor(Math.random() * palette.length)];
              typingText.style.color = currentColor;
            }

            charIndex += 1;
            typingText.textContent = currentWord.slice(0, charIndex).toUpperCase();

            if (charIndex === currentWord.length) {
              isDeleting = true;
              queue(animateTyping, wordPause);
              return;
            }

            queue(animateTyping, typingSpeed);
            return;
          }

          charIndex -= 1;
          typingText.textContent = currentWord.slice(0, Math.max(0, charIndex)).toUpperCase();

          if (charIndex === 0) {
            isDeleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            queue(animateTyping, restartPause);
            return;
          }

          queue(animateTyping, deletingSpeed);
        }

        typingText.textContent = "";
        queue(animateTyping, 500);

        cleanups.push(function () {
          disposed = true;
          if (timeoutId !== null) {
            window.clearTimeout(timeoutId);
          }
        });
      }

      function setupPanebarcosReveal(cleanups) {
        var revealItems = document.querySelectorAll("[data-panebarcos-reveal]");
        if (!revealItems.length) return;

        if (window.matchMedia && window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          revealItems.forEach(function (item) {
            item.classList.add("is-in-view");
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-in-view");
                observer.unobserve(entry.target);
              }
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -10% 0px",
          }
        );

        revealItems.forEach(function (item) {
          observer.observe(item);
        });

        cleanups.push(function () {
          observer.disconnect();
        });
      }

      function initPanebarcosTeam() {
        cleanupPanebarcosTeam();

        var cleanups = [];
        setupPanebarcosTeamTyping(cleanups);
        setupPanebarcosReveal(cleanups);

        cleanupPanebarcosTeam = function () {
          cleanups.forEach(function (dispose) {
            dispose();
          });
        };

        window.__cleanupPanebarcosTeam = cleanupPanebarcosTeam;
      }

      if (!window.__panebarcosTeamBound) {
        document.addEventListener("astro:before-swap", function () {
          cleanupPanebarcosTeam();
        });

        document.addEventListener("astro:page-load", initPanebarcosTeam);
        window.__panebarcosTeamBound = true;
      }

      initPanebarcosTeam();
    })();
  </script>
</Layout>
