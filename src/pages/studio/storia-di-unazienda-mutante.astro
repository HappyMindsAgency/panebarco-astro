---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import ContactCtaBanner from "../../components/ContactCtaBanner.astro";
import studioPageScriptUrl from "../../scripts/pages/studio.js?url";
import { buildPath } from "../../i18n/routing";

const lang = "it" as const;

const mediaGallery = {
  title: "Contenuti multimediali",
  videos: [
    {
      title: "Approfondimento studio 01",
      embedSrc: "https://www.youtube-nocookie.com/embed/W_smIq9Xscw",
    },
    {
      title: "Approfondimento studio 02",
      embedSrc: "https://www.youtube-nocookie.com/embed/f0Zrn__I2Fc",
    },
    {
      title: "Approfondimento studio 03",
      embedSrc: "https://www.youtube-nocookie.com/embed/W_smIq9Xscw?start=18",
    },
  ],
} as const;
---

<Layout
  title="Storia di un'azienda mutante - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="studio-page story-mutant-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/panebarco-studio-video.mp4"
      bgWord="LA TANA"
      title="STORIA DI UN'AZIENDA MUTANTE"
      subtitle="Supporto creativo, produttivo e operativo lungo tutto il processo"
      showSideImage={false}
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
    />

    <section class="page-main page-main--studio story-mutant-intro">
      <div class="container">
        <div class="row g-4 g-xl-5 align-items-center studio-story">
          <div class="col-12 col-xl-7">
            <div class="story-mutant-intro-copy studio-story-copy">
              <h2 class="page-title-uniform">Una bottega multimediale nata per mutare</h2>
              <p>
                Tutto parte dal fumetto, dall'illustrazione e da un modo molto artigianale di costruire storie. Nel 1995
                Daniele Panebarco decide di spostare quel mestiere dentro un territorio nuovo e fonda una bottega che
                trasforma la carta in avventure interattive, animazione e produzioni multimediali.
              </p>
              <p>
                Da allora la struttura si e allargata senza perdere il suo carattere familiare: nuove competenze, nuovi
                formati, nuovi passaggi di testimone. Il risultato e un laboratorio che cambia pelle restando fedele alla
                propria origine narrativa.
              </p>
            </div>
          </div>
          <div class="col-12 col-xl-5">
            <div class="story-mutant-intro-art">
              <img class="img-fluid d-block mx-auto" src="/images/studio-la-nostra-tana.png" alt="Illustrazione della bottega Panebarco" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <section class="studio-timeline section-space">
      <div class="container">
        <h2 class="studio-timeline-title page-title-uniform" id="studioTimelineTitle">Questa e la storia di un'azienda mutante</h2>
        <div class="studio-timeline-track" data-studio-timeline>
          <button
            class="studio-timeline-arrow studio-timeline-arrow--prev"
            type="button"
            aria-label="Anno precedente"
            data-timeline-prev
          >
            <img src="/images/freccia-sinistra.png" alt="" aria-hidden="true" />
          </button>

          <div class="studio-timeline-viewport" id="studioTimelineViewport" aria-labelledby="studioTimelineTitle">
            <div class="studio-timeline-slides">
              <article class="studio-timeline-card is-active">
                <div class="row g-3 g-lg-4 align-items-center">
                  <div class="col-12 col-md-6 studio-timeline-year">
                    <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 1976" />
                  </div>
                  <div class="col-12 col-md-6 studio-timeline-copy">
                    <h3>Gli inizi</h3>
                    <p>
                      Nell'aprile 1976 Daniele pubblica il suo primo fumetto sulla rivista Il Mago, mentre in famiglia
                      comincia anche un'altra storia: quella di Marianna. Sono anni in cui il segno su carta e il
                      racconto disegnato definiscono il primo nucleo del mestiere.
                    </p>
                    <p>
                      Per quasi vent'anni il lavoro cresce dentro il fumetto e l'illustrazione, costruendo una base
                      narrativa forte che restera anche nelle trasformazioni successive.
                    </p>
                  </div>
                </div>
              </article>

              <article class="studio-timeline-card">
                <div class="row g-3 g-lg-4 align-items-center">
                  <div class="col-12 col-md-6 studio-timeline-year">
                    <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 1995" />
                  </div>
                  <div class="col-12 col-md-6 studio-timeline-copy">
                    <h3>La svolta del 1995</h3>
                    <p>
                      Nel 1995 nasce Panebarco &amp; C.: l'idea non e solo produrre immagini, ma portare le storie fuori
                      dalla pagina e trasformarle in esperienze interattive e multimediali.
                    </p>
                    <p>
                      E qui che la bottega cambia scala: il disegno resta il cuore, ma i linguaggi si allargano e il
                      lavoro prende una direzione piu ibrida.
                    </p>
                  </div>
                </div>
              </article>

              <article class="studio-timeline-card">
                <div class="row g-3 g-lg-4 align-items-center">
                  <div class="col-12 col-md-6 studio-timeline-year">
                    <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione 2005" />
                  </div>
                  <div class="col-12 col-md-6 studio-timeline-copy">
                    <h3>Una storia di famiglia</h3>
                    <p>
                      Nel 2005 Marianna, Matteo e Camilla entrano in azienda. L'impresa si rinnova dall'interno e
                      diventa sempre di piu una casa creativa familiare, capace di tenere insieme continuita e mutazione.
                    </p>
                    <p>
                      Nuovi ruoli, nuove sensibilita e una gestione condivisa portano Panebarco verso produzioni sempre
                      piu articolate tra 2D, 3D, video e sviluppo originale.
                    </p>
                  </div>
                </div>
              </article>

              <article class="studio-timeline-card">
                <div class="row g-3 g-lg-4 align-items-center">
                  <div class="col-12 col-md-6 studio-timeline-year">
                    <img class="img-fluid d-block" src="/images/lo-studi-storia-panebarco.png" alt="Illustrazione oggi" />
                  </div>
                  <div class="col-12 col-md-6 studio-timeline-copy">
                    <h3>Le mutazioni di oggi</h3>
                    <p>
                      Oggi Panebarco sviluppa animazione, contenuti branded, service, post-produzione e progetti
                      originali, mantenendo un'identita che resta bottega anche quando i formati cambiano.
                    </p>
                    <p>
                      E mentre la nuova generazione guida l'impresa, Daniele continua a tornare al fumetto: segno che le
                      trasformazioni migliori non cancellano l'origine, la rilanciano.
                    </p>
                  </div>
                </div>
              </article>
            </div>
          </div>

          <button
            class="studio-timeline-arrow studio-timeline-arrow--next"
            type="button"
            aria-label="Anno successivo"
            data-timeline-next
          >
            <img src="/images/freccia-destra.png" alt="" aria-hidden="true" />
          </button>
        </div>

        <div class="studio-timeline-dots" role="tablist" aria-label="Seleziona una fase della storia">
          <button class="studio-timeline-dot is-active" type="button" aria-label="Vai agli inizi" data-timeline-dot="0"></button>
          <button class="studio-timeline-dot" type="button" aria-label="Vai al 1995" data-timeline-dot="1"></button>
          <button class="studio-timeline-dot" type="button" aria-label="Vai al 2005" data-timeline-dot="2"></button>
          <button class="studio-timeline-dot" type="button" aria-label="Vai a oggi" data-timeline-dot="3"></button>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft story-mutant-media">
      <div class="container">
        <div class="story-mutant-media__intro text-center">
          <h2 class="page-title-uniform">{mediaGallery.title}</h2>
        </div>
        <div class="story-mutant-media__grid">
          <div class="story-mutant-media__video story-mutant-media__video--primary">
            <div class="ratio ratio-16x9 overflow-hidden rounded-4">
              <iframe
                src={mediaGallery.videos[0].embedSrc}
                title={mediaGallery.videos[0].title}
                loading="lazy"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                referrerpolicy="strict-origin-when-cross-origin"
              ></iframe>
            </div>
          </div>

          <div class="story-mutant-media__stack">
            {mediaGallery.videos.slice(1).map((video) => (
              <div class="story-mutant-media__video story-mutant-media__video--secondary">
                <div class="ratio ratio-16x9 overflow-hidden rounded-4">
                  <iframe
                    src={video.embedSrc}
                    title={video.title}
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen
                    referrerpolicy="strict-origin-when-cross-origin"
                  ></iframe>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

  <section class="section-space section-space--tight mt-4 mt-md-5 mt-lg-5 pt-2 pt-md-3 pt-lg-4">
      <div class="container">
        <ContactCtaBanner
          kicker="Hai un progetto in mente?"
          title="LO ANIMIAMO NOI."
        />
      </div>
    </section>

  <script type="module" src={studioPageScriptUrl}></script>
</Layout>
