---
import Layout from "../../layouts/Layout.astro";
import HeroStyStudio from "../../components/HeroStyStudio.astro";
import { buildPath } from "../../i18n/routing";

const lang = "it" as const;
const newsletterFigure = "/images/lo-studio-panebarco-teams.png";
const beliefStickers = [
  { title: "Bellezza", subtitle: "come responsabilita", theme: "blue" },
  { title: "Complessita", subtitle: "come valore", theme: "violet" },
  { title: "Cura", subtitle: "come metodo", theme: "red" },
  { title: "Indipendenza", subtitle: "creativa", theme: "green" },
  { title: "Inclusivita", subtitle: "come scelta narrativa", theme: "cyan" },
] as const;

const pageContent = {
  it: {
    valuesTitle: "In cosa crediamo",
    dreamTitle: "Cosa sogniamo",
    dreamLead: "Per noi \"Ci vediamo agli Oscar\" è una battuta, un augurio e un orientamento insieme.",
    dreamBody:
      "Vuol dire puntare in alto senza perdere il lato artigianale del lavoro. Continuare a coltivare idee che maturano nel tempo, trovare i partner giusti e costruire progetti che possano stare accanto ai migliori, senza smettere di essere profondamente nostri.",
    workTitle: "Come lavoriamo",
    workSubtitle: "Il nostro metodo",
    workAreas: [
      {
        kicker: "A",
        title: "Tempo e maturazione delle idee",
        body: "Ci interessa dare spazio ai progetti perché trovino la loro forma: ascoltare, correggere, far sedimentare e poi rilanciare.",
      },
      {
        kicker: "B",
        title: "Dialogo e collaborazione",
        body: "Lavoriamo bene quando il confronto è reale: con chi scrive, con chi produce, con chi entra nel progetto portando un punto di vista utile.",
      },
      {
        kicker: "C",
        title: "Artigianalità e metodo",
        body: "Non crediamo nelle scorciatoie spettacolari. Ci piace un processo chiaro, concreto, capace di unire intuizione e struttura.",
      },
    ],
  },
  en: {
    valuesTitle: "What we believe in",
    dreamTitle: "What we dream of",
    dreamLead: "For us \"See you at the Oscars\" is a joke, a wish and a compass all at once.",
    dreamBody:
      "It means aiming high without losing the handmade side of the work. It means nurturing ideas over time, finding the right partners and building projects that can stand next to the best while remaining unmistakably ours.",
    workTitle: "How we work",
    workSubtitle: "Our method",
    workAreas: [
      {
        kicker: "A",
        title: "Time and maturation of ideas",
        body: "We value giving projects enough room to find their shape: listening, revising, letting things settle and then pushing forward again.",
      },
      {
        kicker: "B",
        title: "Dialogue and collaboration",
        body: "We work best when the conversation is real: with writers, producers and everyone who brings a useful point of view into the project.",
      },
      {
        kicker: "C",
        title: "Craft and method",
        body: "We do not believe in flashy shortcuts. We prefer a clear, practical process able to combine intuition and structure.",
      },
    ],
  },
} as const;

const content = pageContent[lang];
---

<Layout
  title="Ci vediamo agli Oscar - Panebarco"
  useInnerStyles={true}
  lang={lang}
  headerProps={{ containerClass: "hero-fluid" }}
>
  <main class="studio-page oscars-page">
    <HeroStyStudio
      backgroundVideoSrc="/images/1021768637.mp4"
      bgWord="ROAD TO OSCAR"
      title="CI VEDIAMO AGLI OSCAR"
      subtitle=""
      showSideImage={false}
      sideImageSrc="/images/lo-studio-panebarco-teams.png"
      sideImageAlt="Team Panebarco"
      className="hero-sty-studio page-hero page-hero--studio"
    />

    <section class="page-main page-main--studio oscars-beliefs" aria-labelledby="oscarsValuesTitle">
      <div class="container" data-oscars-block-reveal style="--oscars-reveal-delay:80ms;">
        <div class="oscars-section-head text-center">
          <h2 id="oscarsValuesTitle" class="page-title-uniform">{content.valuesTitle}</h2>
        </div>

        <div class="oscars-beliefs__layout">
          <div class="oscars-beliefs__art">
            <img
              class="img-fluid d-block mx-auto"
              src="/images/lo-studio-panebarco-teams.png"
              alt="Team Panebarco"
              loading="lazy"
              decoding="async"
            />
          </div>

          <div class="oscars-beliefs__stickers" aria-label={content.valuesTitle}>
            {beliefStickers.map((item) => (
              <div class:list={["oscars-belief-sticker", `oscars-belief-sticker--${item.theme}`]}>
                <span class="oscars-belief-sticker__title">{item.title}</span>
                <span class="oscars-belief-sticker__subtitle">{item.subtitle}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <section class="section-space oscars-dream" aria-labelledby="oscarsDreamTitle">
      <div class="container">
        <div class="oscars-dream-card" data-oscars-block-reveal style="--oscars-reveal-delay:120ms;">
          <h2 id="oscarsDreamTitle" class="page-title-uniform oscars-dream-card__title">{content.dreamTitle}</h2>
          <p class="oscars-dream-card__lead">{content.dreamLead}</p>
          <p class="oscars-dream-card__body">{content.dreamBody}</p>
          <div class="oscars-dream-card__art">
            <img
              class="img-fluid d-block w-100"
              src="/images/teams-valori.png"
              alt="Team Panebarco insieme"
              loading="lazy"
              decoding="async"
            />
          </div>
        </div>
      </div>
    </section>

    <section class="section-space section-space--soft oscars-work" aria-labelledby="oscarsWorkTitle">
      <div class="container" data-oscars-block-reveal style="--oscars-reveal-delay:140ms;">
        <div class="oscars-section-head text-center">
          <h2 id="oscarsWorkTitle" class="page-title-uniform">{content.workTitle}</h2>
          <p class="oscars-work__subtitle">{content.workSubtitle}</p>
        </div>
        <div class="oscars-work__stack">
          {content.workAreas.map((area) => (
            <article class="oscars-work-card">
              <span class="oscars-work-card__badge" aria-hidden="true">{area.kicker}</span>
              <div class="oscars-work-card__body py-4 py-lg-4">
                <span class="oscars-work-card__kicker">{area.kicker}</span>
                <h3>{area.title}</h3>
                <p>{area.body}</p>
              </div>
            </article>
          ))}
        </div>
      </div>
    </section>

    <div class="container pt-md-5 mt-5 mb-5" data-oscars-block-reveal style="--oscars-reveal-delay:160ms;">
      <section class="extras-newsletter-card">
        <div class="extras-newsletter-card__copy">
          <p class="extras-newsletter-card__kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">Vuoi ricevere gli aggiornamenti?</p>
          <h2 class="extras-newsletter-card__title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">
            ISCRIVITI ALLA NEWSLETTER.
          </h2>
          <a class="btn btn-cta btn-cta--blue btn-pill" href={buildPath("contacts", lang)}>Contattaci</a>
        </div>
        <img
          class="extras-newsletter-card__figure"
          src={newsletterFigure}
          alt="Mascotte Panebarco"
          loading="lazy"
          decoding="async"
        />
      </section>
    </div>
  </main>

  <script is:inline>
    (function () {
      var cleanupOscarsPage = window.__cleanupOscarsPage || function () {};

      function setupOscarsTyping(cleanups) {
        var typingText = document.getElementById("oscars-belief-typing");
        if (!typingText) return;

        var words = (typingText.getAttribute("data-words") || "")
          .split("|")
          .map(function (word) {
            return word.trim();
          })
          .filter(Boolean);

        if (!words.length) return;

        var wordIndex = 0;
        var charIndex = 0;
        var isDeleting = false;
        var currentColor = "#009FE3";
        var timeoutId = null;
        var disposed = false;
        var palette = ["#009FE3", "#B03D4F", "#995791", "#3394B2", "#30997B"];
        var typingSpeed = 90;
        var deletingSpeed = 55;
        var wordPause = 1200;
        var restartPause = 350;

        function queue(nextStep, delay) {
          timeoutId = window.setTimeout(nextStep, delay);
        }

        function animateTyping() {
          if (disposed) return;

          var currentWord = words[wordIndex];

          if (!isDeleting) {
            if (charIndex === 0) {
              currentColor = palette[Math.floor(Math.random() * palette.length)];
              typingText.style.color = currentColor;
            }

            charIndex += 1;
            typingText.textContent = currentWord.slice(0, charIndex).toUpperCase();

            if (charIndex === currentWord.length) {
              isDeleting = true;
              queue(animateTyping, wordPause);
              return;
            }

            queue(animateTyping, typingSpeed);
            return;
          }

          charIndex -= 1;
          typingText.textContent = currentWord.slice(0, Math.max(0, charIndex)).toUpperCase();

          if (charIndex === 0) {
            isDeleting = false;
            wordIndex = (wordIndex + 1) % words.length;
            queue(animateTyping, restartPause);
            return;
          }

          queue(animateTyping, deletingSpeed);
        }

        typingText.textContent = "";
        queue(animateTyping, 500);

        cleanups.push(function () {
          disposed = true;
          if (timeoutId !== null) {
            window.clearTimeout(timeoutId);
          }
        });
      }

      function setupOscarsBlockReveal(cleanups) {
        var blocks = document.querySelectorAll("[data-oscars-block-reveal]");
        if (!blocks.length) return;

        if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) {
          blocks.forEach(function (block) {
            block.classList.add("is-in-view");
          });
          return;
        }

        var observer = new IntersectionObserver(
          function (entries) {
            entries.forEach(function (entry) {
              entry.target.classList.toggle("is-in-view", entry.isIntersecting);
            });
          },
          {
            threshold: 0.18,
            rootMargin: "0px 0px -10% 0px",
          }
        );

        blocks.forEach(function (block) {
          observer.observe(block);
        });

        cleanups.push(function () {
          observer.disconnect();
        });
      }

      function initOscarsPage() {
        cleanupOscarsPage();

        var cleanups = [];
        setupOscarsTyping(cleanups);
        setupOscarsBlockReveal(cleanups);

        cleanupOscarsPage = function () {
          cleanups.forEach(function (dispose) {
            dispose();
          });
        };

        window.__cleanupOscarsPage = cleanupOscarsPage;
      }

      if (!window.__oscarsPageBound) {
        document.addEventListener("astro:before-swap", function () {
          cleanupOscarsPage();
        });

        document.addEventListener("astro:page-load", initOscarsPage);
        window.__oscarsPageBound = true;
      }

      initOscarsPage();
    })();
  </script>
</Layout>
