---
import CmsContentRenderer from "../components/cms/CmsContentRenderer.astro";
import HeroStyStudio from "../components/HeroStyStudio.astro";
import SocialLibraryForm from "../components/SocialLibraryForm.astro";
import { getLangFromPath } from "../i18n/routing";
import { getSocialLibraryPageContent } from "../lib/site-content";
import Layout from "../layouts/Layout.astro";

const lang = getLangFromPath(Astro.url.pathname);

const socialLibraryFallback = {
  name: "",
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "",
    sideImageSrc: "",
    sideImageAlt: "",
    showSideImage: false,
  },
  content: "",
  seo: {
    title: "",
    description: "",
  },
};

const pageContent = await getSocialLibraryPageContent({
  lang,
  fallback: socialLibraryFallback,
});

const heroTitle = pageContent.header.title || pageContent.name;
const hasEditorialContent = Boolean(pageContent.name || pageContent.content);
---

<Layout
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-panebarco-social-library"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="social-library-page studio-page">
    <HeroStyStudio
      backgroundVideoSrc={pageContent.header.backgroundVideoSrc}
      bgWord={pageContent.header.bgWord}
      title={heroTitle}
      subtitle={pageContent.header.subtitle}
      sideImageSrc={pageContent.header.sideImageSrc}
      sideImageAlt={pageContent.header.sideImageAlt}
      showSideImage={pageContent.header.showSideImage}
      className="hero-sty-studio page-hero page-hero--studio"
    />

    <section class="social-library-main">
      <div class="container">
        <div class="row justify-content-center">
          <div class="col-12 col-xl-10">
            {hasEditorialContent && (
              <section class="social-library-editorial" aria-labelledby="socialLibraryEditorialTitle">
                {pageContent.name && (
                  <h2 id="socialLibraryEditorialTitle" class="page-title-uniform">
                    {pageContent.name}
                  </h2>
                )}
                {pageContent.content && (
                  <CmsContentRenderer
                    kind="richText"
                    markdown={pageContent.content}
                    className="social-library-editorial__content"
                  />
                )}
              </section>
            )}
          </div>
        </div>

        <div class="row justify-content-center social-library-form-row">
          <div class="col-12 col-xl-10">
            <div class="social-library-form-wrap">
              <SocialLibraryForm lang={lang} />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  .social-library-main {
    padding: clamp(3.5rem, 7vw, 6rem) 0 clamp(4rem, 7vw, 6.5rem);
  }

  .social-library-editorial,
  .social-library-form-section {
    height: 100%;
  }

  .social-library-editorial {
    padding: clamp(1.5rem, 2vw, 2rem) 0;
  }

  .social-library-editorial__content {
    margin-top: 1.4rem;
    color: rgba(33, 38, 46, 0.88);
  }

  .social-library-editorial__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .social-library-editorial__content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
    border-radius: 1.5rem;
  }

  .social-library-editorial__content :global(a) {
    color: inherit;
    text-decoration-thickness: 0.08em;
  }

  .social-library-editorial__content :global(h2),
  .social-library-editorial__content :global(h3),
  .social-library-editorial__content :global(h4) {
    margin-top: 1.5rem;
  }

  .social-library-form-row {
    margin-top: clamp(2.25rem, 5vw, 3.5rem);
  }

  @media (max-width: 1199.98px) {
    .social-library-editorial {
      padding-bottom: 0;
    }
  }
</style>
