---
import CmsContentRenderer from "../components/cms/CmsContentRenderer.astro";
import HeroStyStudio from "../components/HeroStyStudio.astro";
import SocialLibraryForm from "../components/SocialLibraryForm.astro";
import { getLangFromPath } from "../i18n/routing";
import { getSocialLibraryPageContent } from "../lib/site-content";
import Layout from "../layouts/Layout.astro";

const lang = getLangFromPath(Astro.url.pathname);

const socialLibraryFallback = {
  name: "",
  header: {
    bgWord: "",
    title: "",
    subtitle: "",
    backgroundVideoSrc: "",
    sideImageSrc: "",
    sideImageAlt: "",
    showSideImage: false,
  },
  content: "",
  seo: {
    title: "",
    description: "",
  },
};

const pageContent = await getSocialLibraryPageContent({
  lang,
  fallback: socialLibraryFallback,
});

const heroTitle = pageContent.header.title || pageContent.name;
const hasEditorialContent = Boolean(pageContent.name || pageContent.content);
---

<Layout
  title={pageContent.seo.title}
  description={pageContent.seo.description}
  useInnerStyles={true}
  lang={lang}
  entita="pagina-panebarco-social-library"
  headerProps={{ containerClass: "container-fluid hero-fluid px-3 px-md-4 px-lg-5" }}
>
  <main class="social-library-page studio-page">
    <HeroStyStudio
      backgroundVideoSrc={pageContent.header.backgroundVideoSrc}
      bgWord={pageContent.header.bgWord}
      title={heroTitle}
      subtitle={pageContent.header.subtitle}
      sideImageSrc={pageContent.header.sideImageSrc}
      sideImageAlt={pageContent.header.sideImageAlt}
      showSideImage={pageContent.header.showSideImage}
      className="hero-sty-studio page-hero page-hero--studio"
    />

    <section class="social-library-main">
      <div class="container">
        <div class="row g-4 g-xl-5 align-items-start social-library-layout" data-social-library-layout>
          <div class="col-12 col-xl-6">
            {hasEditorialContent && (
              <section class="social-library-editorial" aria-labelledby="socialLibraryEditorialTitle">
                <p class="social-library-section-kicker">Contenuto editoriale</p>
                {pageContent.name && (
                  <h2 id="socialLibraryEditorialTitle" class="page-title-uniform">
                    {pageContent.name}
                  </h2>
                )}
                {pageContent.content && (
                  <CmsContentRenderer
                    kind="richText"
                    markdown={pageContent.content}
                    className="social-library-editorial__content"
                  />
                )}
              </section>
            )}
          </div>

          <div class="col-12 col-xl-6 social-library-form-column" data-social-library-form-column>
            <div class="social-library-form-sticky" data-social-library-form-sticky>
              <SocialLibraryForm lang={lang} />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<script>
  const desktopMq = window.matchMedia("(min-width: 1200px)");
  const stickyGap = 16;
  const header = document.querySelector(".top-header");
  const layout = document.querySelector("[data-social-library-layout]");
  const formColumn = document.querySelector("[data-social-library-form-column]");
  const formSticky = document.querySelector("[data-social-library-form-sticky]");

  if (
    header instanceof HTMLElement &&
    layout instanceof HTMLElement &&
    formColumn instanceof HTMLElement &&
    formSticky instanceof HTMLElement
  ) {
    let ticking = false;

    const clearStickyState = () => {
      layout.style.position = "";
      formColumn.style.minHeight = "";
      formSticky.style.position = "";
      formSticky.style.top = "";
      formSticky.style.left = "";
      formSticky.style.width = "";
    };

    const syncStickyState = () => {
      ticking = false;

      if (!desktopMq.matches) {
        clearStickyState();
        return;
      }

      const headerHeight = header.getBoundingClientRect().height;
      const topOffset = headerHeight + stickyGap;
      const stickyHeight = formSticky.offsetHeight;
      const layoutRect = layout.getBoundingClientRect();
      const columnRect = formColumn.getBoundingClientRect();
      const layoutTop = layoutRect.top + window.scrollY;
      const layoutBottom = layoutTop + layout.offsetHeight;
      const startSticky = layoutTop - topOffset;
      const stopSticky = layoutBottom - topOffset - stickyHeight;

      layout.style.position = "relative";

      if (window.scrollY <= startSticky) {
        clearStickyState();
        return;
      }

      formColumn.style.minHeight = `${stickyHeight}px`;

      if (window.scrollY >= stopSticky) {
        formSticky.style.position = "absolute";
        formSticky.style.top = `${Math.max(layout.offsetHeight - stickyHeight, 0)}px`;
        formSticky.style.left = `${formColumn.offsetLeft}px`;
        formSticky.style.width = `${formColumn.offsetWidth}px`;
        return;
      }

      formSticky.style.position = "fixed";
      formSticky.style.top = `${topOffset}px`;
      formSticky.style.left = `${columnRect.left}px`;
      formSticky.style.width = `${columnRect.width}px`;
    };

    const requestStickySync = () => {
      if (ticking) return;
      ticking = true;
      window.requestAnimationFrame(syncStickyState);
    };

    window.addEventListener("scroll", requestStickySync, { passive: true });
    window.addEventListener("resize", requestStickySync);
    desktopMq.addEventListener("change", requestStickySync);
    window.addEventListener("load", requestStickySync);
    requestStickySync();
  }
</script>

<style>
  .social-library-main {
    padding: clamp(3.5rem, 7vw, 6rem) 0 clamp(4rem, 7vw, 6.5rem);
  }

  .social-library-editorial,
  .social-library-form-section {
    height: 100%;
  }

  .social-library-editorial {
    padding: clamp(1.5rem, 2vw, 2rem) 0;
  }

  .social-library-section-kicker {
    margin-bottom: 0.85rem;
    color: var(--bs-primary);
    font-size: 0.84rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }

  .social-library-editorial__content {
    margin-top: 1.4rem;
    color: rgba(33, 38, 46, 0.88);
  }

  .social-library-editorial__content :global(p:last-child) {
    margin-bottom: 0;
  }

  .social-library-editorial__content :global(img) {
    display: block;
    max-width: 100%;
    height: auto;
    margin: 1.5rem 0;
    border-radius: 1.5rem;
  }

  .social-library-editorial__content :global(a) {
    color: inherit;
    text-decoration-thickness: 0.08em;
  }

  .social-library-editorial__content :global(h2),
  .social-library-editorial__content :global(h3),
  .social-library-editorial__content :global(h4) {
    margin-top: 1.5rem;
  }

  .social-library-form-column {
    align-self: flex-start;
  }

  @media (max-width: 1199.98px) {
    .social-library-editorial {
      padding-bottom: 0;
    }
  }
</style>
