---
import ChatPopSlider from "./ChatPopSlider.astro";

interface Props {
  showSlider?: boolean;
  className?: string;
  containerClass?: string;
  heroClass?: string;
  id?: string;
  show?: boolean;
  videoSrc?: string | null | false;
  imageSrc?: string;
  title?: string;
  subtitle?: string;
  ctaLabel?: string;
  ctaHref?: string;
  showTitle?: boolean;
  showSubtitle?: boolean;
  showCta?: boolean;
}

const {
  show = true,
  showSlider = true,
  className = "hero-sty-home",
  containerClass = "container-fluid hero-fluid px-3 px-md-4 px-lg-5",
  heroClass = "hero-card",
  id,
  videoSrc,
  imageSrc,
  title = "Ciao!",
  subtitle = "Animazione, creatività e un pizzico di magia digitale.",
  ctaLabel = "Scopri cosa facciamo",
  ctaHref = "#",
  showTitle = true,
  showSubtitle = true,
  showCta = true,
} = Astro.props;

const normalizeBool = (value: any, fallback: boolean) => {
  if (value === undefined || value === null) return fallback;
  if (typeof value === "string") return value.toLowerCase() === "true";
  return Boolean(value);
};

const resolvedVideoSrc =
  typeof videoSrc === "string" && videoSrc.trim() !== ""
    ? videoSrc
    : videoSrc === false || videoSrc === null
      ? undefined
      : imageSrc
        ? undefined
        : "/images/1021768637.mp4";

const resolvedImageSrc = imageSrc ?? "/images/hero-dettaglio-fallback.jpg";

const hasVideo = Boolean(resolvedVideoSrc);
const hasImage = !hasVideo && Boolean(resolvedImageSrc);
const isVisible = normalizeBool(show, true);
const hasSlider = normalizeBool(showSlider, true);
const hasTitle = normalizeBool(showTitle, true);
const hasSubtitle = normalizeBool(showSubtitle, true);
const hasCta = normalizeBool(showCta, true);
---

{
  isVisible && (
    <section class={className} id={id}>
      <div class={containerClass}>
        <div class={heroClass}>
          {hasVideo && (
            <video
              class="hero-bg-video"
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              aria-hidden="true"
            >
              <source src={resolvedVideoSrc} type="video/mp4" />
            </video>
          )}
          {hasImage && (
            <img
              class="hero-bg-video hero-bg-image"
              src={resolvedImageSrc}
              alt=""
              aria-hidden="true"
              loading="lazy"
            />
          )}
          <div class="hero-sty-home__body">
            {hasTitle && <h1>{title}</h1>}
            {hasSubtitle && <p>{subtitle}</p>}
            {hasCta && (
              <a href={ctaHref} class="btn btn-cta btn-cta--blue hero-cta">
                <i class="bi bi-play-fill" aria-hidden="true" /> {ctaLabel}
              </a>
            )}
          </div>
          {hasSlider && (
            <ChatPopSlider variant="hero" />
          )}
        </div>
      </div>
    </section>
  )
}

<style>
  .hero-sty-home {
    position: relative;
  }

  .hero-sty-home__body {
    position: relative;
    z-index: 1;
    color: white;
  }

  .hero-bg-image {
    object-position: center;
  }
</style>
