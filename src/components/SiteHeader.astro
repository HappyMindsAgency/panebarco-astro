---
import MenuOverlayRevamp from "./MenuOverlayRevamp.astro";
import logoDark from "../../public/images/panebarco-logo-dark.png";
import logoLight from "../../public/images/panebarco-logo-light.png";
import menuWhite from "../../public/images/hamburger-menu-bianco.png";
import menuBlack from "../../public/images/hamburger-menu-nero.png";
import type { Lang } from "../i18n/config";
import { customLabel } from "../i18n/labels";
import { buildPath } from "../i18n/routing";

interface Props {
  logoSrc?: string;
  logoHref?: string;
  logoAlt?: string;
  darkmode?: boolean;
  containerClass?: string;
  showLogo?: boolean;
  menuIconSrc?: string;
  lang?: Lang;
}

const {
  logoSrc,
  lang = "it",
  logoHref = buildPath("home", lang),
  darkmode = true,
  logoAlt = "Panebarco",
  containerClass = "container-fluid hero-fluid px-3 px-md-4 px-lg-5",
  showLogo = true,
  menuIconSrc,
} = Astro.props;

// darkmode=true  -> logo chiaro + hamburger bianco (per sfondi scuri) [default]
// darkmode=false -> logo scuro  + hamburger nero  (per sfondi chiari)
const imgLogo = logoSrc ?? (darkmode ? logoLight.src : logoDark.src);
const menuIcon = menuIconSrc ?? (darkmode ? menuWhite.src : menuBlack.src);
const stickyLogo = logoDark.src;
const stickyMenuIcon = menuBlack.src;

---

<header class="top-header fixed-top">
  <div class={containerClass}>
    <div class="hero-nav">
      <button class="menu-trigger" type="button" aria-label={customLabel("a11y.openMenu", lang)}>
        {menuIcon ? (
          <img
            class="menu-trigger-icon"
            src={menuIcon}
            data-default-src={menuIcon}
            data-sticky-src={stickyMenuIcon}
            alt=""
            aria-hidden="true"
          />
        ) : (
          <>
            <span></span>
            <span></span>
            <span></span>
          </>
        )}
      </button>
      {showLogo && (
        <a href={logoHref} class="hero-logo text-decoration-none" aria-label={logoAlt}>
          <img src={imgLogo} data-default-src={imgLogo} data-sticky-src={stickyLogo} alt={logoAlt} />
        </a>
      )}
    </div>
  </div>
</header>
<MenuOverlayRevamp lang={lang} />
