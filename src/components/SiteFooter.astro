---
import type { Lang } from "../i18n/config";
import { customLabel } from "../i18n/labels";
import { buildPath } from "../i18n/routing";
import imgLoghiBando from "../assets/images/loghi-er-bando.jpeg";

interface Props {
  lang?: Lang;
}

const {
  lang = "it",
} = Astro.props;

const footerHeading = customLabel("footer.heading", lang);
const footerHeadingStrong = customLabel("footer.headingStrong", lang);
const footerHeadingHighlight = lang === "it" && footerHeading.endsWith("progetto!")
  ? "progetto!"
  : "";
const footerHeadingPrefix = footerHeadingHighlight
  ? footerHeading.slice(0, -footerHeadingHighlight.length)
  : footerHeading;
---

<footer id="contatti" class="footer-cta">
  <div class="container">
    <div class="row g-4 footer-main align-items-center">
      <div class="col-lg-4">
        <img class="footer-logo" src="/images/logo-light-panebarco.svg" alt="Panebarco">
        <p class="contact-line mb-0">
          Panebarco &amp; C. S.r.l.<br>Via Molino, 9, 48121 Ravenna, Italia<br>
          <a href="tel:+390544451744">+39 0544 451744</a> |
          <a href="tel:+393383693558">+39 338 3693558</a><br>
          <a href="mailto:info@panebarco.it">info@panebarco.it</a>
        </p>
      </div>

      <div class="col-lg-3">
        <div class="social-row">
          <a class="social-circle social-facebook" href="https://www.facebook.com/PanebarcoMultimedia/" aria-label="Facebook" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-facebook"></i>
          </a>
          <a class="social-circle social-instagram" href="https://www.instagram.com/panebarcos" aria-label="Instagram" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-instagram"></i>
          </a>
          <a class="social-circle social-vimeo" href="https://vimeo.com/panebarco" aria-label="Vimeo" target="_blank" rel="noopener noreferrer">
            <i class="bi bi-vimeo"></i>
          </a>
        </div>
        <p class="legal-line">Codice SDI XL13LG4<br>P. Iva e C. F. IT01315670396<br>R.E.A. RA 135428<br>Capitale sociale euro 40.000,00 I.V.</p>
      </div>

      <div class="col-lg-5">
        <h3 class="footer-heading">
          {footerHeadingPrefix}
          {footerHeadingHighlight && <span class="footer-heading-strong">{footerHeadingHighlight}</span>}
          {footerHeadingStrong && (
            <>
              <br />
              <span class="footer-heading-strong">{footerHeadingStrong}</span>
            </>
          )}
        </h3>
        <a href={buildPath("contacts", lang)} class="btn btn-cta btn-cta--orange btn-pill">{customLabel("footer.contactCta", lang)}</a>
      </div>
    </div>
  </div>

  <div class="container-fluid bg-white">
    <div class="bg-white row">
      <div class="lg-col-8 col-12 mx-auto">
        <div class="text-container text-center py-4">
          <p class="mb-0 fs-6 text-black">{customLabel("footer.projectFondiEu", lang)}</p>
          <img src={imgLoghiBando.src} alt="Loghi Bando Fondi Europei" class="img-fluid mt-3" style="max-height: 80px;">

        </div>
      </div>
    </div>
  </div>

  <div class="container bg-primary">
    <div class="footer-meta">
      <p class="small-muted mb-0">
        Copyright &copy; Panebarco &amp; C. 2025 <span class="d-none d-lg-inline">|</span> <br class="d-lg-none"> <a href={buildPath("privacyPolicy", lang)}>{customLabel("footer.privacy", lang)}</a> - <a href={buildPath("cookiePolicy", lang)}>{customLabel("footer.cookies", lang)}</a> - <a href={buildPath("trasparenza", lang)}>{customLabel("footer.trasparenza", lang)}</a>
      </p>
    </div>
  </div>

  <div class="footer-signature">
    <div class="container">
      {customLabel("footer.signature", lang)}
      <a href="https://www.happyminds.it" target="_blank" rel="noopener noreferrer">HappyMinds</a>
    </div>
  </div>
</footer>
