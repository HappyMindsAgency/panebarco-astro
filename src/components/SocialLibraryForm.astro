---
import { buildPath } from "../i18n/routing";

interface Props {
  lang?: "it" | "en";
}

const { lang = "it" } = Astro.props;
const privacyHref = buildPath("privacyPolicyPsl", lang);
const newsletterPrivacyHref = buildPath("privacyPolicyNewsletter", lang);
---

<section class="social-library-form-section" aria-label="Modulo richiesta Social Library">
  <div class="social-library-form-card">
    <div class="social-library-form-alert alert alert-success" data-form-success hidden role="alert">
      Richiesta inviata con successo! Ti contatteremo a breve.
    </div>

    <div class="social-library-form-alert alert alert-danger" data-form-error hidden role="alert"></div>

    <form class="row g-3 needs-validation" data-social-library-form novalidate>
      <div class="col-12 col-md-6">
        <label class="form-label" for="socialLibraryNome">Nome*</label>
        <input class="form-control" id="socialLibraryNome" name="nome" type="text" autocomplete="given-name" required />
        <div class="invalid-feedback">Inserisci il nome.</div>
      </div>

      <div class="col-12 col-md-6">
        <label class="form-label" for="socialLibraryCognome">Cognome*</label>
        <input class="form-control" id="socialLibraryCognome" name="cognome" type="text" autocomplete="family-name" required />
        <div class="invalid-feedback">Inserisci il cognome.</div>
      </div>

      <div class="col-12 col-md-6">
        <label class="form-label" for="socialLibraryEmail">Email*</label>
        <input class="form-control" id="socialLibraryEmail" name="email" type="email" autocomplete="email" inputmode="email" required />
        <div class="invalid-feedback">Inserisci un indirizzo email valido.</div>
      </div>

      <div class="col-12 col-md-6">
        <label class="form-label" for="socialLibraryTelefono">Telefono*</label>
        <input class="form-control" id="socialLibraryTelefono" name="telefono" type="tel" autocomplete="tel" inputmode="tel" required />
        <div class="invalid-feedback">Inserisci il numero di telefono.</div>
      </div>

      <div class="col-12 col-md-6">
        <label class="form-label" for="socialLibraryLinkCatalogo">Vuoi ricevere il link con il catalogo?*</label>
        <input class="form-control" id="socialLibraryLinkCatalogo" name="linkCatalogo" type="url" inputmode="url" placeholder="https://" required />
        <div class="invalid-feedback">Inserisci un URL valido del catalogo o del riferimento.</div>
      </div>

      <div class="col-12 col-md-6">
        <label class="form-label" for="socialLibraryDataRitiro">Scrivici il giorno in cui preferiresti ritirare i libri*</label>
        <input
          class="form-control"
          id="socialLibraryDataRitiro"
          name="dataRitiro"
          type="text"
          autocomplete="off"
          required
        />
        <div class="invalid-feedback">Inserisci il giorno preferito per il ritiro.</div>
      </div>

      <div class="col-12">
        <label class="form-label" for="socialLibraryMessaggio">Messaggio*</label>
        <textarea class="form-control" id="socialLibraryMessaggio" name="messaggio" rows="5" required></textarea>
        <div class="invalid-feedback">Inserisci un messaggio.</div>
      </div>

      <div class="col-12">
        <div class="form-check">
          <input class="form-check-input" id="socialLibraryNewsletter" name="newsletter" type="checkbox" />
          <label class="form-check-label" for="socialLibraryNewsletter">
            Si, voglio iscrivermi alla newsletter e rimanere aggiornato sui progetti di Panebarco -
            <a href={newsletterPrivacyHref}>Informativa</a>
          </label>
        </div>
      </div>

      <div class="col-12">
        <div class="form-check">
          <input class="form-check-input" id="socialLibraryPrivacy" name="privacy" type="checkbox" required />
          <label class="form-check-label" for="socialLibraryPrivacy">
            Acconsento al trattamento dei dati personali cosi come definito all'interno delle
            <a href={privacyHref}>Privacy Policy*</a>
          </label>
          <div class="invalid-feedback">Devi accettare l'informativa privacy.</div>
        </div>
      </div>

      <div class="col-12">
        <button class="btn btn-cta btn-cta--blue btn-pill social-library-submit" type="submit" data-submit-button>
          <span data-submit-label>Invia richiesta</span>
          <span data-submit-loading hidden>
            <span class="spinner-border spinner-border-sm me-2" aria-hidden="true"></span>
            Invio in corso...
          </span>
        </button>
      </div>
    </form>
  </div>
</section>

<script>
  const form = document.querySelector("[data-social-library-form]");

  if (form instanceof HTMLFormElement) {
    const submitButton = form.querySelector("[data-submit-button]");
    const submitLabel = form.querySelector("[data-submit-label]");
    const submitLoading = form.querySelector("[data-submit-loading]");
    const successMessage = document.querySelector("[data-form-success]");
    const errorMessage = document.querySelector("[data-form-error]");

    const state = {
      nome: "",
      cognome: "",
      email: "",
      telefono: "",
      messaggio: "",
      linkCatalogo: "",
      dataRitiro: "",
      newsletter: false,
      privacy: false,
    };

    const urlPattern = /^https?:\/\/.+/i;

    const setLoading = (isLoading) => {
      if (!(submitButton instanceof HTMLButtonElement)) return;

      submitButton.disabled = isLoading;
      if (submitLabel instanceof HTMLElement) submitLabel.hidden = isLoading;
      if (submitLoading instanceof HTMLElement) submitLoading.hidden = !isLoading;
    };

    const showError = (message) => {
      if (!(errorMessage instanceof HTMLElement)) return;
      errorMessage.textContent = message;
      errorMessage.hidden = false;
    };

    const clearMessages = () => {
      if (successMessage instanceof HTMLElement) successMessage.hidden = true;
      if (errorMessage instanceof HTMLElement) {
        errorMessage.hidden = true;
        errorMessage.textContent = "";
      }
    };

    const syncState = () => {
      const formData = new FormData(form);

      state.nome = String(formData.get("nome") || "").trim();
      state.cognome = String(formData.get("cognome") || "").trim();
      state.email = String(formData.get("email") || "").trim();
      state.telefono = String(formData.get("telefono") || "").trim();
      state.messaggio = String(formData.get("messaggio") || "").trim();
      state.linkCatalogo = String(formData.get("linkCatalogo") || "").trim();
      state.dataRitiro = String(formData.get("dataRitiro") || "").trim();
      state.newsletter = formData.get("newsletter") !== null;
      state.privacy = formData.get("privacy") !== null;
    };

    const validateForm = () => {
      syncState();

      const hasValidCatalogLink = urlPattern.test(state.linkCatalogo);

      const linkField = form.elements.namedItem("linkCatalogo");
      if (linkField instanceof HTMLInputElement) {
        linkField.setCustomValidity(hasValidCatalogLink ? "" : "Inserisci un URL valido.");
      }

      const isNativeValid = form.checkValidity();
      form.classList.add("was-validated");
      return isNativeValid && hasValidCatalogLink;
    };

    const createPayload = () => ({
      nome: state.nome,
      cognome: state.cognome,
      email: state.email,
      telefono: state.telefono,
      messaggio: state.messaggio,
      linkCatalogo: state.linkCatalogo,
      dataRitiro: state.dataRitiro,
      newsletter: state.newsletter,
      privacy: state.privacy,
      source: "social-library",
      createdAt: new Date().toISOString(),
    });

    const handleSubmit = async (event) => {
      event.preventDefault();
      clearMessages();

      if (!validateForm()) {
        showError("Controlla i campi obbligatori evidenziati prima di inviare.");
        return;
      }

      setLoading(true);

      try {
        const payload = createPayload();

        const res = await fetch("/api/contacts", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ formType: "socialLibrary", data: payload }),
        });

        const json = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(json?.error ?? "Errore");

        form.reset();
        form.classList.remove("was-validated");

        if (successMessage instanceof HTMLElement) successMessage.hidden = false;
      } catch {
        showError("Invio non riuscito. Riprova o contattaci direttamente a info@panebarco.it.");
      } finally {
        setLoading(false);
      }
    };

    form.addEventListener("input", () => {
      syncState();
      clearMessages();
    });

    form.addEventListener("submit", handleSubmit);
  }
</script>

<style>
  .social-library-form-card {
    padding: clamp(1.25rem, 2.4vw, 2rem);
    border-radius: 1.5rem;
    background: #fff;
    box-shadow:
      0 1rem 2.5rem rgba(15, 23, 42, 0.08),
      inset 0 0 0 1px rgba(15, 23, 42, 0.06);
  }

  .social-library-form-alert {
    margin-bottom: 1rem;
    border-radius: 1rem;
  }

  [data-social-library-form] {
    --bs-gutter-x: 1rem;
    --bs-gutter-y: 0.9rem;
  }

  [data-social-library-form] .form-label,
  [data-social-library-form] .form-check-label {
    font-size: 0.98rem;
    line-height: 1.4;
  }

  [data-social-library-form] .form-label {
    margin-bottom: 0.35rem;
    font-weight: 700;
  }

  [data-social-library-form] .form-control {
    min-height: 3rem;
    padding: 0.7rem 0.9rem;
    border-radius: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.12);
  }

  [data-social-library-form] textarea.form-control {
    min-height: 8rem;
  }

  [data-social-library-form] .form-check {
    display: flex;
    align-items: flex-start;
    gap: 0.65rem;
    margin-bottom: 0;
    padding: 0.2rem 0;
    padding-left: 0;
  }

  [data-social-library-form] .form-check-input {
    float: none;
    margin-top: 0.22rem;
    margin-left: 0;
    flex: 0 0 auto;
  }

  [data-social-library-form] .form-check-label {
    margin-bottom: 0;
  }

  [data-social-library-form] .invalid-feedback {
    margin-top: 0.25rem;
    font-size: 0.86rem;
  }

  .social-library-submit {
    min-width: 14rem;
  }

  .social-library-submit[disabled] {
    opacity: 0.8;
    cursor: progress;
  }

  @media (min-width: 1200px) {
    .social-library-form-card {
      padding: 1.35rem 1.45rem 1.45rem;
    }

    [data-social-library-form] {
      --bs-gutter-x: 0.85rem;
      --bs-gutter-y: 0.75rem;
    }

    [data-social-library-form] .form-label,
    [data-social-library-form] .form-check-label {
      font-size: 0.95rem;
      line-height: 1.35;
    }

    [data-social-library-form] .form-label {
      margin-bottom: 0.3rem;
    }

    [data-social-library-form] .form-control {
      min-height: 2.9rem;
      padding: 0.62rem 0.8rem;
      font-size: 0.98rem;
      line-height: 1.3;
    }

    [data-social-library-form] textarea.form-control {
      min-height: 7rem;
    }

    [data-social-library-form] .form-check {
      gap: 0.55rem;
      padding: 0.2rem 0;
    }

    [data-social-library-form] .form-check-input {
      margin-top: 0.14rem;
    }

    [data-social-library-form] .invalid-feedback {
      font-size: 0.86rem;
      margin-top: 0.2rem;
    }

    .social-library-submit {
      font-size: 1rem;
      padding-top: 0.62rem;
      padding-bottom: 0.62rem;
    }
  }

  @media (max-width: 767.98px) {
    .social-library-form-card {
      padding: 1rem;
      border-radius: 1.25rem;
    }

    .social-library-submit {
      width: 100%;
    }
  }
</style>
