---
import { micromark } from "micromark";
const { block, className, pstyle }  = Astro.props;
const innerClassName = className ? className : "";
const content = block ? micromark(block) : "";
---
{block && 
<div class={`block-richtext custombody ${innerClassName}`} set:html={content}></div>
}

{pstyle && 
<style>
    .block-richtext.custombody p {
        ${pstyle}
    }
</style>
}
