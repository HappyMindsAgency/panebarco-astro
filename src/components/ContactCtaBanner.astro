---
import { buildPath } from "../i18n/routing";

interface Props {
  kicker: string;
  title: string;
  href?: string;
  buttonLabel?: string;
  figureSrc?: string;
  figureAlt?: string;
  background?: string;
}

const {
  kicker,
  title,
  href = buildPath("contacts", "it"),
  buttonLabel = "Contattaci",
  figureSrc = "/images/lo-animiamo-noi.png",
  figureAlt = "Mascotte Panebarco",
  background = "#9f5ea3",
} = Astro.props;
---

<!-- CTA finale riusabile per uniformare struttura e comportamento tra le pagine servizio. -->
<div class="contact-cta-card position-relative rounded-4" style={`--contact-cta-bg:${background};`}>
  <img
    class="contact-cta-figure"
    src={figureSrc}
    alt={figureAlt}
  />
  <div class="contact-cta-copy text-white text-start">
    <p class="contact-cta-kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">{kicker}</p>
    <h3 class="contact-cta-title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">{title}</h3>
    <a href={href} class="btn btn-cta btn-cta--blue btn-pill mt-3">{buttonLabel}</a>
  </div>
</div>

<style>
  .contact-cta-card {
    background: var(--contact-cta-bg, #9f5ea3);
    min-height: clamp(13rem, 24vw, 19rem);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding:
      clamp(1.2rem, 2.4vw, 2.1rem)
      clamp(1.2rem, 2.6vw, 2.2rem)
      clamp(1.2rem, 2.4vw, 2.1rem)
      calc(clamp(1.2rem, 4.2vw, 4.8rem) + clamp(11.5rem, 24vw, 18.5rem) + clamp(1.8rem, 3.2vw, 3rem));
    overflow: visible;
  }

  .contact-cta-figure {
    position: absolute;
    left: clamp(1.2rem, 4.2vw, 4.8rem);
    bottom: 0;
    width: clamp(11.5rem, 24vw, 18.5rem);
    height: auto;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  .contact-cta-copy {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: clamp(26rem, 54vw, 64rem);
    margin-left: clamp(1rem, 2vw, 2.2rem);
    min-width: 0;
  }

  .contact-cta-kicker,
  .contact-cta-title {
    max-width: 100%;
  }

  @media (max-width: 991.98px) {
    .contact-cta-card {
      min-height: clamp(10.8rem, 31vw, 14.4rem);
      padding-left: calc(clamp(0.9rem, 2.6vw, 2.4rem) + clamp(8.8rem, 27vw, 13rem) + clamp(1.2rem, 2.4vw, 2rem));
    }

    .contact-cta-figure {
      width: clamp(8.8rem, 27vw, 13rem);
      left: clamp(0.9rem, 2.6vw, 2.4rem);
    }

    .contact-cta-copy {
      max-width: clamp(18rem, 48vw, 34rem);
      margin-left: clamp(0.8rem, 1.6vw, 1.2rem);
    }
  }

  @media (max-width: 767.98px) {
    .contact-cta-card {
      min-height: clamp(6.8rem, 25vw, 8.5rem);
      padding: 0.8rem 1rem 0.8rem calc(clamp(0.35rem, 1.5vw, 0.9rem) + clamp(4.9rem, 18vw, 6.4rem) + 1.15rem);
    }

    .contact-cta-figure {
      width: clamp(4.9rem, 18vw, 6.4rem);
      left: clamp(0.35rem, 1.5vw, 0.9rem);
    }

    .contact-cta-copy {
      width: 100%;
      max-width: none;
      margin-left: 0.7rem;
    }
  }
</style>
