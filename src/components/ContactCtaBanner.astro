---
import { buildPath } from "../i18n/routing";

interface Props {
  kicker: string;
  title: string;
  href?: string;
  buttonLabel?: string;
  figureSrc?: string;
  figureAlt?: string;
  background?: string;
}

const {
  kicker,
  title,
  href = buildPath("contacts", "it"),
  buttonLabel = "Contattaci",
  figureSrc = "/images/lo-animiamo-noi.png",
  figureAlt = "Mascotte Panebarco",
  background = "#9f5ea3",
} = Astro.props;
---

<!-- CTA finale riusabile per uniformare struttura e comportamento tra le pagine servizio. -->
<div
  class="contact-cta-card position-relative rounded-4"
  style={`--contact-cta-bg:${background};`}
>
  <img
    class="contact-cta-figure"
    src={figureSrc}
    alt={figureAlt}
  />
  <div class="contact-cta-copy text-white text-start">
    <p class="contact-cta-kicker mb-0 fw-bold fs-2 fs-lg-1 lh-1">{kicker}</p>
    <h3 class="contact-cta-title mt-1 mb-0 text-white fw-bolder text-uppercase display-5 display-lg-4 lh-1">{title}</h3>
    <a href={href} class="btn btn-cta btn-cta--blue btn-pill mt-3">{buttonLabel}</a>
  </div>
</div>

<style>
  .contact-cta-card {
    background: var(--contact-cta-bg, #9f5ea3);
    min-height: clamp(13rem, 24vw, 19rem);
    display: flex;
    align-items: center;
    justify-content: flex-start;
    padding:
      clamp(1.2rem, 2.4vw, 2.1rem)
      clamp(1.2rem, 2.6vw, 2.2rem)
      clamp(1.2rem, 2.4vw, 2.1rem)
      calc(clamp(1.2rem, 4.2vw, 4.8rem) + clamp(11.5rem, 24vw, 18.5rem) + clamp(1.8rem, 3.2vw, 3rem));
    overflow: visible;
  }

  .contact-cta-figure {
    position: absolute;
    left: clamp(1.2rem, 4.2vw, 4.8rem);
    top: 0;
    bottom: auto;
    width: clamp(11.5rem, 24vw, 18.5rem);
    height: auto;
    display: block;
    pointer-events: none;
    user-select: none;
    transform: translateY(-30%);
  }

  .contact-cta-copy {
    position: relative;
    z-index: 1;
    width: 100%;
    max-width: clamp(26rem, 54vw, 64rem);
    margin-left: clamp(1rem, 2vw, 2.2rem);
    min-width: 0;
  }

  .contact-cta-kicker,
  .contact-cta-title {
    max-width: 100%;
  }

  @media (max-width: 991.98px) {
    .contact-cta-card {
      display: block;
      min-height: auto;
      padding:
        clamp(4.8rem, 10vw, 6.4rem)
        clamp(0.9rem, 2.6vw, 2.4rem)
        clamp(1.2rem, 2.8vw, 2rem);
    }

    .contact-cta-figure {
      position: absolute;
      width: clamp(6.8rem, 18vw, 9.5rem);
      left: 50%;
      top: 0;
      bottom: auto;
      display: block;
      margin: 0;
      transform: translate(-50%, -52%);
    }

    .contact-cta-copy {
      max-width: none;
      margin-left: 0;
    }
  }

  @media (max-width: 767.98px) {
    .contact-cta-card {
      display: block;
      min-height: auto;
      padding: 4.5rem 1rem 1rem;
    }

    .contact-cta-figure {
      position: absolute;
      width: clamp(5.8rem, 24vw, 7.4rem);
      left: 50%;
      top: 0;
      bottom: auto;
      display: block;
      margin: 0;
      transform: translate(-50%, -50%);
    }

    .contact-cta-copy {
      width: 100%;
      max-width: none;
      margin-left: 0;
    }
  }
</style>
